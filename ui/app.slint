// ui/app.slint — gmacFTP main UI. macOS Finder-inspired, theme-aware (light default,
// dark variant). Readability-first: solid selection + hover (no low-alpha "wall of gray"),
// strong text contrast, clear hairlines, accent chips for folder/file glyphs.
//
// NOTE: glyphs are ASCII / Latin-1 only (no emoji / rare unicode). The femtovg GPU renderer
// can't color emoji and the default font lacks many symbol glyphs — that made the earlier
// icon set invisible. "/", "·", "<", ">", "^", "+" all render reliably everywhere.

import { ListView, ScrollView } from "std-widgets.slint";
import "../assets/fonts/Inter-Regular.ttf";
import "../assets/fonts/JetBrainsMono-Regular.ttf";

import { Tokens, I18n, Fmt, ConnRow, EntryRow, LocalFavoriteRow, TransferRow, SyncRow, PathRow, SearchRow, ComparisonRow } from "foundation.slint";
export { Tokens, I18n, Fmt, ConnRow, EntryRow, LocalFavoriteRow, TransferRow, SyncRow, PathRow, SearchRow, ComparisonRow }
import { KeyboardActionArea, PrimaryButton, GhostButton, ChoiceSegment, ProgressBar } from "controls/actions.slint";
import { FileIcon, MetadataSizeCell, Icon, SelectAllBox, IconButton, RailButton, LabeledToolButton, ManagerActionButton, ToolDivider, ProtocolBadge, SidebarScrollBar, SidebarScrollView, TrafficButton, BrandWordmark, PaneBadge } from "controls/visuals.slint";
import { SearchField, CtxItem, Field, SettingsToggleRow, SortOpt, SortDirOpt, SortArrow, SortHeader } from "controls/fields.slint";

export component App inherits Window {
    title: "gmacFTP";
    no-frame: true;
    resize-border-width: 7px;
    preferred-width: 1180px;
    preferred-height: 740px;
    background: transparent;
    default-font-family: "Inter";

    in property <string> app-version: "";
    // Headless documentation renders use the real component but disable GPU-only shadows that
    // the deterministic RGB software renderer cannot alpha-composite correctly.
    in property <bool> snapshot-mode: false;
    in property <[ConnRow]> connections;
    in property <[ConnRow]> sessions;   // active background sessions (CONNECTED section)
    in property <[ConnRow]> filtered-connections;
    in property <[ConnRow]> filtered-sessions;
    in property <[ConnRow]> palette-connections;
    in property <[LocalFavoriteRow]> local-favorites;
    in-out property <[EntryRow]> local-entries;
    in-out property <[EntryRow]> remote-entries;
    in-out property <[EntryRow]> local-full;
    in-out property <[EntryRow]> remote-full;
    in-out property <string> local-cwd: "/";
    in-out property <string> remote-cwd: "/";
    in-out property <string> local-path-display: "/";
    in-out property <string> remote-path-display: "/";
    in-out property <string> local-file-filter: "";
    in-out property <string> remote-file-filter: "";
    in-out property <bool> path-editor-open: false;
    in-out property <int> path-editor-pane: 0;
    in-out property <string> path-editor-value: "";
    in-out property <bool> path-editor-remote: false;
    in-out property <[PathRow]> path-recent;
    in-out property <[PathRow]> path-places;
    in-out property <bool> remote-search-open: false;
    in-out property <bool> remote-search-running: false;
    in-out property <int> remote-search-pane: 1;
    in-out property <string> remote-search-query: "";
    in-out property <string> remote-search-summary: "";
    in-out property <[SearchRow]> remote-search-results;
    in-out property <bool> comparison-open: false;
    in-out property <bool> comparison-differences-only: true;
    in-out property <string> comparison-summary: "";
    in-out property <[ComparisonRow]> comparison-results;
    in-out property <bool> synchronized-browsing: false;
    in-out property <int> active-connection: -1;
    in-out property <bool> is-connecting: false;
    in-out property <bool> local-loading: false;
    in-out property <bool> remote-loading: false;
    property <int> metadata-pulse: 0;
    in-out property <string> status: "";
    in-out property <string> error: "";
    in-out property <string> active-host: "";

    Timer {
        interval: 320ms;
        running: true;
        triggered => { root.metadata-pulse = root.metadata-pulse == 2 ? 0 : root.metadata-pulse + 1; }
    }
    in-out property <int> local-selected: -1;
    in-out property <int> remote-selected: -1;
    // Command-A selects every visible entry in the active pane. Keep this separate from the
    // keyboard cursor (`*-selected`) so arrows, type-ahead and the existing context menu can
    // continue to operate on one row without changing their behaviour.
    in-out property <bool> local-all-selected: false;
    in-out property <bool> remote-all-selected: false;
    in-out property <int> local-selection-anchor: -1;
    in-out property <int> remote-selection-anchor: -1;
    in-out property <int> local-selection-end: -1;
    in-out property <int> remote-selection-end: -1;
    in-out property <bool> local-range-selected: false;
    in-out property <bool> remote-range-selected: false;
    in-out property <[bool]> local-selection;
    in-out property <[bool]> remote-selection;
    property <bool> selection-shift: false;
    property <bool> selection-command: false;
    in-out property <bool> transfer-active: false;
    in-out property <int> transfer-done: 0;
    in-out property <int> transfer-total: 0;
    in-out property <float> transfer-fraction: 0.0;
    in-out property <string> transfer-label: "";
    in-out property <string> transfer-progress-text: "";
    in-out property <bool> palette-open: false;
    in-out property <string> palette-query: "";
    in-out property <string> server-filter: "";
    in-out property <bool> manager-open: false;
    in-out property <bool> editor-open: false;
    in-out property <int> editor-id: -1;
    in-out property <string> editor-name: "";
    in-out property <string> editor-host: "";
    in-out property <string> editor-port: "21";
    in-out property <string> editor-user: "";
    in-out property <string> editor-password: "";
    in-out property <string> editor-initial-path: "";
    in-out property <string> editor-group: "";
    in-out property <string> editor-tags: "";
    in-out property <string> editor-timeout-secs: "0";
    in-out property <string> editor-keepalive-secs: "";
    in-out property <string> editor-protocol: "ftp";
    in-out property <string> editor-ftp-data-mode: "passive";
    in-out property <string> editor-ftp-filename-encoding: "auto";
    in-out property <string> editor-ftp-tls-mode: "explicit";
    in-out property <string> editor-proxy-url: "";
    in-out property <bool> editor-use-ssh-config: false;
    in-out property <string> editor-ssh-proxy-jump: "";
    in-out property <string> editor-sftp-auth: "password";
    in-out property <string> editor-sftp-key-path: "";
    in-out property <int> editor-transfer-concurrency: 0; // 0 = global default, 1..4 override
    // Plain FTP is a per-connection, deliberate exception for a legacy/LAN host. It never
    // inherits from another connection and defaults to disabled.
    in-out property <bool> editor-allow-plaintext-ftp: false;
    in-out property <string> editor-tls-pin: "";
    in-out property <string> editor-tls-client-cert: "";
    in-out property <string> editor-tls-client-key: "";
    in-out property <bool> editor-legacy-invalid-tls: false;
    in-out property <bool> editor-testing: false;
    in-out property <string> manager-message: "";
    in-out property <bool> accept-any-cert: false; // true means a saved pin or legacy exception exists
    in-out property <bool> show-hidden: false;
    in-out property <bool> show-advanced-columns: false;
    in-out property <string> local-sort-key: "name";
    in-out property <string> local-sort-dir: "asc";
    in-out property <string> remote-sort-key: "name";
    in-out property <string> remote-sort-dir: "asc";
    in-out property <string> selected-path: "";      // full path of the active pane's selected entry (bottom bar, copyable)
    in-out property <bool> overwrite-open: false;    // overwrite-conflict dialog open?
    in-out property <string> overwrite-name: "";     // name of the clashing file (shown in the dialog)
    in-out property <bool> overwrite-apply-all: false;
    in-out property <bool> transfer-error-open: false;
    in-out property <bool> transfer-error-needs-decision: false;
    in-out property <string> transfer-error-batch: "";
    in-out property <string> transfer-error-name: "";
    in-out property <string> transfer-error-message: "";
    in-out property <bool> passphrase-open: false;   // sync-passphrase dialog open?
    in-out property <string> passphrase-mode: "set"; // set | enter | backup_export | backup_import
    in-out property <string> passphrase-value: "";
    in-out property <string> passphrase-confirm: "";
    // A pulled vault can contain the legacy `(host, user)` credential format. Conversion to the
    // endpoint-bound format requires an explicit trust decision for the downloaded server list.
    in-out property <bool> credential-recovery-open: false;
    in-out property <int> credential-recovery-count: 0;
    in-out property <int> credential-recovery-ambiguous: 0;
    // First-contact SFTP host-key trust dialog. The fingerprint is supplied by the SSH layer
    // before password authentication and must be verified independently by the user.
    in-out property <bool> host-key-open: false;
    in-out property <string> host-key-endpoint: "";
    in-out property <string> host-key-fingerprint: "";
    in-out property <bool> ssh-auth-open: false;
    in-out property <string> ssh-auth-endpoint: "";
    in-out property <string> ssh-auth-title: "";
    in-out property <string> ssh-auth-instructions: "";
    in-out property <int> ssh-auth-prompt-count: 0;
    in-out property <string> ssh-auth-prompt-0: "";
    in-out property <string> ssh-auth-prompt-1: "";
    in-out property <string> ssh-auth-prompt-2: "";
    in-out property <string> ssh-auth-prompt-3: "";
    in-out property <bool> ssh-auth-echo-0: false;
    in-out property <bool> ssh-auth-echo-1: false;
    in-out property <bool> ssh-auth-echo-2: false;
    in-out property <bool> ssh-auth-echo-3: false;
    in-out property <string> ssh-auth-response-0: "";
    in-out property <string> ssh-auth-response-1: "";
    in-out property <string> ssh-auth-response-2: "";
    in-out property <string> ssh-auth-response-3: "";
    in-out property <bool> tls-cert-open: false;
    in-out property <string> tls-cert-endpoint: "";
    in-out property <string> tls-cert-fingerprint: "";
    in-out property <string> tls-cert-previous: "";
    in-out property <bool> sort-open: false;          // sort popover open?
    in-out property <string> sort-pane: "local";      // which pane the sort popover targets
    in-out property <int> local-count: 0;
    in-out property <int> remote-count: 0;
    // active pane ("local" | "remote"), sidebar selection (no auto-connect), transfer panel
    in-out property <string> active-pane: "local";
    in-out property <int> selected-connection: -1;
    in-out property <[TransferRow]> transfer-jobs;
    in-out property <string> transfer-summary: "0 transfers";
    in-out property <int> transfer-done-count: 0;     // completed (done) rows — drives the header pill
    in-out property <int> transfer-pending-count: 0;  // active + queued — drives the toolbar badge
    in-out property <bool> transfer-panel-open: false;
    in-out property <bool> transfers-paused: false;   // engine pause-all toggle (transfer panel)
    in-out property <string> transfer-view: "all";   // "all" | "queue"
    in-out property <int> transfer-concurrency: 3;    // simultaneous endpoints, clamped in Rust
    in-out property <bool> background-folder-metadata: false;
    // Tier 2: each pane is independently "local" or a remote host
    in-out property <string> left-kind: "local";
    in-out property <string> right-kind: "local";
    in-out property <string> left-host: "";
    in-out property <string> right-host: "";
    in-out property <string> left-protocol: "";
    in-out property <string> right-protocol: "";
    in-out property <int> left-conn-id: -1;
    in-out property <int> right-conn-id: -1;
    in-out property <bool> left-in-remote-trash: false;
    in-out property <bool> right-in-remote-trash: false;
    // draggable left/right pane split (left pane width in px)
    in-out property <length> pane-split: 440px;
    // context-menu state (custom overlay driven by right-click via pointer-event)
    in-out property <bool> ctx-open: false;
    in-out property <length> ctx-x: 0px;
    in-out property <length> ctx-y: 0px;
    in-out property <string> ctx-pane: "";       // "local" | "remote"
    in-out property <int> ctx-index: -1;
    in-out property <string> ctx-name: "";
    in-out property <bool> ctx-is-dir: false;
    // delete-confirmation dialog (right-click → Delete opens this before trashing/deleting)
    in-out property <bool> delete-open: false;
    in-out property <string> delete-pane: "";
    in-out property <int> delete-pane-index: 0;
    in-out property <string> delete-name: "";
    in-out property <string> delete-path: "";
    in-out property <bool> delete-is-dir: false;
    in-out property <bool> delete-dont-ask: false;   // "Don't ask again this session" checkbox
    in-out property <bool> delete-remote-quarantine: false;
    in-out property <bool> file-operation-open: false;
    in-out property <string> file-operation-mode: "rename"; // rename | mkdir | chmod
    in-out property <string> file-operation-pane: "local";
    in-out property <string> file-operation-name: "";
    in-out property <string> file-operation-value: "";
    in-out property <bool> file-operation-is-dir: false;
    in-out property <int> file-clipboard-count: 0;
    in-out property <bool> batch-rename-open: false;
    in-out property <string> batch-rename-pane: "local";
    in-out property <string> batch-rename-find: "";
    in-out property <string> batch-rename-replace: "";
    in-out property <string> batch-rename-summary: "";
    in-out property <bool> inspector-open: false;
    in-out property <bool> inspector-loading: false;
    in-out property <string> inspector-name: "";
    in-out property <string> inspector-path: "";
    in-out property <string> inspector-kind: "";
    in-out property <string> inspector-size: "";
    in-out property <string> inspector-modified: "";
    in-out property <string> inspector-permissions: "";
    in-out property <string> inspector-owner: "";
    in-out property <string> inspector-group: "";
    in-out property <bool> edit-conflict-open: false;
    in-out property <bool> edit-conflict-busy: false;
    in-out property <string> edit-conflict-name: "";
    in-out property <string> edit-conflict-summary: "";
    in-out property <string> edit-conflict-preview: "";
    in-out property <string> edit-conflict-local-path: "";
    in-out property <bool> sync-open: false;
    in-out property <bool> sync-scanning: false;
    in-out property <bool> sync-preview-ready: false;
    in-out property <string> sync-direction: "upload";
    in-out property <string> sync-mode: "one_way";
    in-out property <bool> sync-mirror-confirmed: false;
    in-out property <string> sync-exclusions: ".git, .DS_Store, *.part, *.tmp";
    in-out property <string> sync-comparison: "size_mtime";
    in-out property <string> sync-mtime-tolerance: "2";
    in-out property <string> sync-server-clock-offset: "0";
    in-out property <string> sync-summary: "Choose a direction, then preview the changes.";
    in-out property <[SyncRow]> sync-rows;
    in-out property <string> sync-profile-name: "";
    in-out property <[string]> sync-profile-names;
    in-out property <int> sync-profile-selected: -1;
    // Native Settings sheet. Values are copied from validated persisted settings by Rust and are
    // committed atomically only when Save is pressed.
    in-out property <bool> settings-open: false;
    in-out property <string> settings-section: "general";
    in-out property <string> settings-theme: "light";
    in-out property <string> settings-locale: "en";
    in-out property <bool> settings-show-hidden: false;
    in-out property <bool> settings-show-advanced-columns: false;
    in-out property <bool> settings-background-metadata: false;
    in-out property <bool> settings-confirm-deletes: true;
    in-out property <bool> settings-remote-quarantine-deletes: true;
    in-out property <bool> settings-restore-workspace: true;
    in-out property <bool> settings-open-manager-on-launch: false;
    in-out property <bool> settings-check-updates-automatically: false;
    in-out property <bool> settings-updates-supported: true;
    in-out property <string> settings-left-path: "";
    in-out property <string> settings-right-path: "";
    in-out property <string> settings-pane-split: "440";
    in-out property <string> settings-window-width: "1180";
    in-out property <string> settings-window-height: "740";
    in-out property <int> settings-transfer-concurrency: 3;
    in-out property <int> settings-server-concurrency: 2;
    in-out property <string> settings-retry-count: "3";
    in-out property <string> settings-retry-backoff: "1000";
    in-out property <string> settings-bandwidth-limit: "0";
    in-out property <string> settings-existing-file-policy: "ask";
    in-out property <string> settings-batch-error-policy: "ask";
    in-out property <string> settings-queue-recovery-policy: "ask";
    in-out property <bool> settings-notify-transfer-completion: false;
    in-out property <bool> settings-notify-transfer-failure: false;
    in-out property <bool> settings-preserve-transfer-timestamps: false;
    in-out property <bool> settings-preserve-transfer-permissions: false;
    in-out property <string> settings-sync-comparison: "size_mtime";
    in-out property <string> settings-sync-tolerance: "2";
    in-out property <string> settings-sync-exclusions: ".git, .DS_Store, *.part, *.tmp";
    in-out property <string> settings-editor-max-mib: "64";
    in-out property <bool> settings-editor-auto-upload: true;
    in-out property <bool> settings-editor-retain-on-error: true;
    in-out property <string> settings-editor-mappings: "";
    in-out property <string> settings-editor-conflict-action: "retain_local";
    in-out property <string> settings-editor-temp-retention: "on_error";
    in-out property <string> settings-storage-summary: "Calculating storage use…";
    in-out property <string> settings-sync-folder: "";
    in-out property <string> settings-message: "";
    // A release returned by the updater is kept in Rust; only display text crosses into Slint.
    // Release notes are rendered as plain text and never interpreted as markup or a URL.
    in-out property <bool> update-open: false;
    in-out property <bool> update-busy: false;
    in-out property <string> update-version: "";
    in-out property <string> update-notes: "";
    in-out property <string> update-message: "";

    // drag & drop state (internal, pane-to-pane transfer). A plain click never activates a
    // drag — only a left-press moved > 5px does — so existing click/double-click behaviour
    // is untouched. On release over the opposite pane, the matching upload/download fires.
    in-out property <bool> drag-active: false;
    in-out property <bool> native-drag-started: false;
    in-out property <bool> external-drop-active: false;
    in-out property <int> external-drop-pane: -1;
    in-out property <bool> drag-pressed: false;
    in-out property <length> drag-x: 0px;
    in-out property <length> drag-y: 0px;
    in-out property <length> drag-start-x: 0px;
    in-out property <length> drag-start-y: 0px;
    in-out property <string> drag-source: "";    // "local" | "remote"
    in-out property <int> drag-index: -1;
    in-out property <string> drag-name: "";
    in-out property <bool> drag-is-dir: false;
    in-out property <int> favorite-drag-index: -1;
    in-out property <int> favorite-drop-index: -1;
    in-out property <length> favorite-list-y: 0px;
    in-out property <int> saved-drag-index: -1;
    in-out property <int> saved-drag-id: -1;
    in-out property <int> saved-drop-index: -1;
    in-out property <length> saved-list-y: 0px;
    // pane under the cursor while dragging ("" when idle). Sidebar=240px; the local pane is
    // `pane-split` wide, then a 48px center divider, then the remote pane — so the real
    // boundary is 240px + pane-split (+half the divider). Using the old 50/50 midpoint
    // mis-targeted drops whenever the user resized the splitter.
    out property <string> drag-target:
        !root.drag-active ? "" : (root.drag-x > 240px + root.pane-split + 24px ? "remote" : "local");
    out property <bool> drag-source-local-dir:
        root.drag-is-dir && ((root.drag-source == "local" && root.left-kind == "local") || (root.drag-source == "remote" && root.right-kind == "local"));
    out property <bool> drag-over-favorites:
        root.drag-active && root.drag-source-local-dir && root.drag-x < 240px && root.drag-y > 100px && root.drag-y < 330px;
    out property <bool> favorite-dragging:
        root.drag-active && root.drag-source == "favorite";
    out property <bool> favorite-drag-over-list:
        root.favorite-dragging && root.drag-x < 240px && root.drag-y >= root.favorite-list-y - 8px && root.drag-y <= root.favorite-list-y + root.local-favorites.length * 30px + 8px;
    out property <bool> favorite-remove-target:
        root.favorite-dragging && !root.favorite-drag-over-list;
    out property <bool> saved-dragging:
        root.drag-active && root.drag-source == "server";
    out property <bool> saved-drag-over-list:
        root.saved-dragging && root.drag-x < 240px && root.drag-y >= root.saved-list-y - 8px && root.drag-y <= root.saved-list-y + root.filtered-connections.length * 36px + 8px;

    callback connect-to(int);
    callback disconnect();
    callback refresh();
    callback navigate-local(string);
    callback navigate-remote(string);
    callback nav-local-back();
    callback nav-local-forward();
    callback nav-local-up();
    callback nav-remote-back();
    callback nav-remote-forward();
    callback nav-remote-up();
    callback open-path-editor(int);
    callback navigate-path(int, string);
    callback open-remote-trash(int);
    callback restore-remote-trash(string, string);
    callback add-current-remote-place(int);
    callback remove-remote-place(int);
    callback filter-files(int, string);
    callback start-remote-search(int, string);
    callback cancel-remote-search();
    callback open-remote-search-result(int, string, bool);
    callback open-directory-comparison();
    callback set-comparison-differences-only(bool);
    callback reveal-comparison-row(string);
    callback toggle-synchronized-browsing();
    callback download();
    callback upload();
    callback toggle-locale();
    callback toggle-tls();
    callback toggle-hidden();
    callback toggle-advanced-columns();
    callback toggle-background-metadata();
    callback toggle-theme();
    callback sort-local(string);
    callback sort-remote(string);
    callback new-connection();
    callback edit-connection(int);
    callback delete-connection(int);
    callback save-connection();
    callback test-connection();
    callback reset-editor-tls-trust();
    callback choose-private-key();
    callback choose-tls-client-cert();
    callback choose-tls-client-key();
    pure callback localize-runtime(string, string) -> string;
    callback filter-palette(string);
    callback import-forklift();
    callback copy-path(string, string);   // (pane, name) → Rust surfaces the path in status
    callback calculate-folder-size(string, string); // explicit bounded recursive metadata request
    callback update-selected-path();      // recompute the bottom-bar path for the active pane's selection
    callback copy-selected-path();        // copy the bottom-bar path to the clipboard
    callback apply-sort-field(string);    // set the sort-pane's sort key + re-apply the view
    callback toggle-sort-dir();           // toggle the sort-pane's asc/desc + re-apply
    callback resolve-overwrite(int);      // overwrite dialog: 0=cancel, 1=overwrite, 2=save-as-new
    callback resolve-transfer-error(bool); // true=skip failed file and continue, false=stop batch
    callback resolve-passphrase(string, string); // passphrase dialog: (value, confirm); empty value = cancel
    callback resolve-credential-recovery(bool);  // true only after trusting the synced server list
    callback resolve-host-key-trust(bool);       // true only after user verified the displayed fingerprint
    callback resolve-keyboard-interactive(bool); // Rust reads and immediately clears responses
    callback resolve-tls-certificate(int);       // 0 cancel, 1 trust once, 2 pin and save
    callback request-send-sync();             // menu "Send Servers to iCloud" → migrate all passwords into the vault, then sync
    callback request-delete(string, string, bool); // intend-to-delete (pane, name, is_dir) → opens dialog or deletes if "don't ask" is on
    callback confirm-delete(bool);         // permanent_remote; quarantine/local Trash otherwise
    callback confirm-file-operation(string, string, string, string, bool);
    callback copy-file-selection(string);
    callback paste-file-selection(string);
    callback duplicate-selection(string);
    callback move-selection-other-pane(string);
    callback open-batch-rename(string);
    callback apply-batch-rename(string, string, string);
    callback open-inspector(string, string);
    callback edit-remote-file(string, string); // pane alias, filename
    callback resolve-editor-conflict(int); // 0=retain local, 1=upload copy, 2=overwrite after recheck
    callback open-folder-sync();
    callback preview-folder-sync(string, string, string, string, string, string); // direction, exclusions, comparison, tolerance, server clock offset, mode
    callback apply-folder-sync(string, string, string, string, string, string, bool); // same + explicit mirror confirmation
    callback toggle-sync-row(int);
    callback save-sync-profile(string);
    callback load-sync-profile(int);
    callback delete-sync-profile(int);
    callback export-sync-report();
    callback activate-pane(string);        // "local" | "remote"
    callback select-connection(int);       // sidebar select (no connect)
    callback connect-selected-to-pane(string); // open the selected server into a pane
    callback clear-finished-transfers();   // remove done/failed rows from the transfer panel
    callback dismiss-transfer(int);        // remove one transfer row by id (the per-row ✕)
    callback cancel-transfer(int);         // cancel one queued/active transfer
    callback retry-transfer(int);          // retry; downloads resume from their private fragment
    callback pause-transfer(int, bool);    // pause/resume one not-yet-started transfer
    callback set-transfer-priority(int, string);
    callback move-transfer(int, int);      // queued row, -1=up / 1=down within its priority
    callback export-transfer-report();     // privacy-safe report without paths, hosts or filenames
    callback set-transfers-paused(bool);   // engine: pause/resume dequeue of new transfers
    callback set-transfer-concurrency(int); // engine: simultaneous endpoint limit (1..6)
    callback set-pane-local(int);          // switch a pane (0|1) back to the local filesystem
    callback disconnect-pane(int);         // disconnect a specific pane (0|1) — sidebar eject
    callback switch-to-session(int);       // click a CONNECTED session → show it in the active pane
    callback disconnect-session(int);      // eject a session from the background pool entirely
    callback open-local-favorite(string);  // open a concrete local favorite path in the left pane
    callback add-local-favorite(string, int); // (pane alias, row index) → persist selected local folder in Favorites
    callback reorder-local-favorite(int, int); // from index, insertion index
    callback remove-local-favorite(int);       // remove from Favorites only; never deletes disk folder
    callback reorder-saved-connection(int, int); // connection id, insertion index in current Saved view
    callback select-entry(string, int, bool, bool); // pane, row, extend-range (Shift), toggle (Command)
    callback select-all(string, bool);        // pane, selected
    callback move-selection(int, bool);    // keyboard: move by ±1, optionally extending with Shift
    callback type-ahead(string);           // keyboard: jump to first entry starting with letter
    callback pane-preview();               // keyboard: Quick Look (space)
    callback pane-enter();                 // keyboard: copy selected to the other pane (enter)
    callback pane-delete();                // keyboard: delete selected in active pane (del)
    callback filter-servers(string);        // sidebar search filter
    callback start-window-drag();           // frameless titlebar drag, handled by winit on macOS
    callback minimize-window();
    callback toggle-window-fullscreen();
    callback close-window();
    callback start-external-drag(string, int);
    callback save-settings();
    callback reload-settings();
    callback clear-performance-caches();
    callback refresh-storage-stats();
    callback cleanup-abandoned-temporary-files();
    callback choose-sync-folder();
    callback clear-sync-folder();
    callback export-redacted-diagnostics();
    callback export-encrypted-settings();
    callback import-encrypted-settings();
    callback check-for-updates();
    callback download-update();
    callback dismiss-update();

    FocusScope {
        key-pressed(e) => {
            // Global shortcuts — on macOS the Command key is Slint's `control` modifier.
            if (e.modifiers.control && (e.text == "k" || e.text == "K")) { root.palette-open = true; accept }
            else if (e.modifiers.control && (e.text == "l" || e.text == "L")) { root.open-path-editor(root.active-pane == "remote" ? 1 : 0); accept }
            else if (e.modifiers.control && e.text == ",") { root.reload-settings(); root.refresh-storage-stats(); root.settings-open = true; accept }
            else if (e.modifiers.control && e.modifiers.shift && (e.text == "n" || e.text == "N")) { root.file-operation-mode = "mkdir"; root.file-operation-pane = root.active-pane; root.file-operation-name = ""; root.file-operation-value = "New Folder"; root.file-operation-is-dir = true; root.file-operation-open = true; accept }
            else if (e.modifiers.control && (e.text == "n" || e.text == "N")) { root.new-connection(); accept }
            else if (e.modifiers.control && (e.text == "t" || e.text == "T")) { root.toggle-theme(); accept }
            else if (e.text == Key.Escape) { if (root.update-open && !root.update-busy) { root.dismiss-update(); } if (root.ssh-auth-open) { root.resolve-keyboard-interactive(false); } if (root.remote-search-running) { root.cancel-remote-search(); } if (root.edit-conflict-open && !root.edit-conflict-busy) { root.resolve-editor-conflict(0); } root.remote-search-open = false; root.comparison-open = false; root.batch-rename-open = false; root.inspector-open = false; root.palette-open = false; root.manager-open = false; root.settings-open = false; root.editor-password = ""; root.editor-sftp-key-path = ""; root.editor-tls-client-cert = ""; root.editor-tls-client-key = ""; root.editor-open = false; root.ctx-open = false; root.sort-open = false; root.delete-open = false; root.file-operation-open = false; root.path-editor-open = false; root.sync-open = false; root.drag-active = false; root.drag-pressed = false; root.selection-shift = false; root.selection-command = false; accept }
            // keyboard control of the active file pane (only when no overlay/input is open)
            else if (!root.update-open && !root.palette-open && !root.manager-open && !root.settings-open && !root.editor-open && !root.ctx-open && !root.path-editor-open && !root.remote-search-open && !root.comparison-open && !root.batch-rename-open && !root.inspector-open && !root.edit-conflict-open && !root.ssh-auth-open) {
                if (e.modifiers.control && (e.text == "c" || e.text == "C")) { root.copy-file-selection(root.active-pane); accept }
                else if (e.modifiers.control && (e.text == "v" || e.text == "V")) { root.paste-file-selection(root.active-pane); accept }
                else if (e.modifiers.control && (e.text == "d" || e.text == "D")) { root.duplicate-selection(root.active-pane); accept }
                else if (e.modifiers.control && (e.text == "a" || e.text == "A")) {
                    root.select-all(root.active-pane, true);
                    root.update-selected-path();
                    accept
                }
                else if (e.text == Key.UpArrow) { root.move-selection(-1, e.modifiers.shift); accept }
                else if (e.text == Key.DownArrow) { root.move-selection(1, e.modifiers.shift); accept }
                else if (e.text == Key.Return) { root.pane-enter(); accept }
                else if (e.text == Key.Delete || e.text == Key.Backspace) { root.pane-delete(); accept }
                else if (e.text == Key.Space || e.text == " ") { root.pane-preview(); accept }
                else { root.type-ahead(e.text); reject }
            }
            else { reject }
        }

        Rectangle {
            background: Tokens.bg;
            border-width: 1px;
            border-color: Tokens.border;
            border-radius: 10px;
            clip: true;

            VerticalLayout {
                // ── toolbar ──
                Rectangle {
                height: 52px; background: Tokens.surface;
                border-width: 1px; border-color: Tokens.border;

                toolbar_drag := TouchArea {
                    mouse-cursor: default;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            root.start-window-drag();
                        }
                    }
                }

                HorizontalLayout {
                    padding-left: 13px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px; spacing: 5px;
                    VerticalLayout {
                        width: 14px; alignment: center;
                        TrafficButton { fill: #FF5F57; mark: "x"; accessible-name: @tr("Close window"); clicked => { root.close-window(); } }
                    }
                    VerticalLayout {
                        width: 14px; alignment: center;
                        TrafficButton { fill: #FFBD2E; mark: "-"; accessible-name: @tr("Minimize window"); clicked => { root.minimize-window(); } }
                    }
                    VerticalLayout {
                        width: 14px; alignment: center;
                        TrafficButton { fill: #28C840; mark: "+"; accessible-name: @tr("Toggle full screen"); clicked => { root.toggle-window-fullscreen(); } }
                    }
                    Rectangle { width: 4px; background: transparent; }
                    BrandWordmark { }
                    // Host pill keeps the toolbar geometry stable even before a pane is connected.
                    VerticalLayout {
                        width: 188px; alignment: center;
                        Rectangle {
                            width: 188px; height: 28px; border-radius: Tokens.r-button;
                            background: Tokens.field-bg;
                            border-width: 1px;
                            border-color: Tokens.border;
                            HorizontalLayout { padding-left: 10px; padding-right: 10px; spacing: 8px; alignment: center;
                                Rectangle {
                                    width: 7px; height: 28px; background: transparent;
                                    VerticalLayout { alignment: center;
                                        Rectangle {
                                            width: 7px; height: 7px; border-radius: 4px;
                                            background: (root.left-kind == "remote" || root.right-kind == "remote" || root.active-host != "") ? Tokens.success : Tokens.text-ter;
                                        }
                                    }
                                }
                                Text {
                                    text: root.active-host != "" ? root.active-host
                                        : (root.active-pane == "local" && root.left-kind == "remote" ? root.left-host
                                        : (root.active-pane == "remote" && root.right-kind == "remote" ? root.right-host
                                        : (root.left-kind == "remote" ? root.left-host
                                        : (root.right-kind == "remote" ? root.right-host : I18n.not-connected))));
                                    color: (root.left-kind == "remote" || root.right-kind == "remote" || root.active-host != "") ? Tokens.text : Tokens.text-sec;
                                    font-family: "JetBrains Mono"; font-size: 10px; vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                Rectangle {
                                    width: 1px; height: 28px; background: transparent;
                                    Rectangle { y: 7px; width: 1px; height: 14px; background: Tokens.border-strong; }
                                }
                                Text {
                                    text: (root.active-pane == "local" && root.left-protocol != "") ? root.left-protocol
                                        : ((root.active-pane == "remote" && root.right-protocol != "") ? root.right-protocol
                                        : (root.left-protocol != "" ? root.left-protocol : (root.right-protocol != "" ? root.right-protocol : "FTP")));
                                    color: (root.left-kind == "remote" || root.right-kind == "remote" || root.active-host != "") ? Tokens.accent-text : Tokens.text-sec;
                                    font-size: 9px; font-weight: 700; vertical-alignment: center;
                                }
                            }
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    LabeledToolButton { width: 94px; icon: "refresh"; text: I18n.refresh; clicked => { root.refresh(); } }
                    LabeledToolButton { width: 122px; icon: "transfer"; text: @tr("Sync"); disabled: !((root.left-kind == "local" && root.right-kind == "remote") || (root.left-kind == "remote" && root.right-kind == "local")); clicked => { root.open-folder-sync(); } }
                    ToolDivider { }
                    LabeledToolButton { width: 116px; icon: "activity"; text: @tr("Transfers"); badge: root.transfer-pending-count; clicked => { root.transfer-panel-open = !root.transfer-panel-open; } }
                    ToolDivider { }
                    LabeledToolButton { width: 95px; icon: "log-in"; text: I18n.connect; emphasized: true; disabled: root.selected-connection < 0 || (root.active-pane == "local" && root.local-loading) || (root.active-pane == "remote" && root.remote-loading); clicked => { root.connect-selected-to-pane(root.active-pane); } }
                    LabeledToolButton { width: 111px; icon: "log-out"; text: I18n.disconnect; danger-emphasis: true; disabled: (root.active-pane == "local" && root.local-loading) || (root.active-pane == "remote" && root.remote-loading) || !((root.active-pane == "local" && root.left-kind == "remote") || (root.active-pane == "remote" && root.right-kind == "remote")); clicked => { root.disconnect(); } }
                    ToolDivider { }
                    IconButton { icon: "shield"; accessible-name: @tr("Allow unsafe TLS certificates for this server"); checkable: true; on: root.accept-any-cert; clicked => { root.toggle-tls(); } }
                    IconButton { icon: "eye"; accessible-name: @tr("Show hidden files"); checkable: true; on: root.show-hidden; clicked => { root.toggle-hidden(); } }
                    IconButton { icon: Tokens.theme == "dark" ? "sun" : "moon"; accessible-name: @tr("Toggle light and dark theme"); clicked => { root.toggle-theme(); } }
                    ToolDivider { }
                    LabeledToolButton { width: 94px; icon: "server"; text: @tr("Servers"); clicked => { root.manager-open = true; root.manager-message = ""; } }
                }
            }

            // ── body ──
            HorizontalLayout {
                // sidebar
                Rectangle {
                    width: 240px; background: Tokens.bg-alt;
                    border-width: 1px; border-color: Tokens.border;
                    VerticalLayout {
                        padding-top: 12px; padding-left: 14px; padding-right: 6px; padding-bottom: 12px; spacing: 10px;
                        SearchField { text <=> root.server-filter; placeholder: @tr("Filter servers…"); edited(query) => { root.filter-servers(query); } }
                        SidebarScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 5px;
                                // ── CONNECTED: active background sessions. Click a row to focus it into the active
                                // pane (the previous session stays alive); click the eject icon to disconnect it. ──
                                if (root.filtered-sessions.length > 0) : Rectangle {
                                    height: 26px;
                                    Text { text: I18n.connected + " · " + root.filtered-sessions.length; color: Tokens.text-ter; font-size: 10px; font-weight: 700; vertical-alignment: bottom; }
                                }
                                for s in root.filtered-sessions : Rectangle {
                                    height: 44px; border-radius: Tokens.r-row;
                                    background: (s.id == root.left-conn-id || s.id == root.right-conn-id) ? Tokens.sidebar-active : (session_action.has-hover || session_action.has-focus ? Tokens.row-hover : transparent);
                                    // status dot — absolute, on the SAME x-axis as the CONNECTIONS rows (x16)
                                    Rectangle { x: 12px; y: 19px; width: 6px; height: 6px; border-radius: 3px; background: Tokens.success; }
                                    session_action := KeyboardActionArea {
                                        accessible-name: @tr("Switch to connected server {}", s.label);
                                        accessible-help: s.sub;
                                        clicked => { root.switch-to-session(s.id); }
                                    }
                                    HorizontalLayout { padding-left: 29px; padding-right: 5px; padding-top: 5px; padding-bottom: 5px; spacing: 6px; alignment: center;
                                        VerticalLayout { spacing: 2px; horizontal-stretch: 1;
                                            Text { text: s.label; color: Tokens.text; font-size: 12px; font-weight: 700; vertical-alignment: center; overflow: elide; }
                                            Text { text: s.sub; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 9px; overflow: elide; }
                                        }
                                        ProtocolBadge { protocol: s.protocol; compact: true; }
                                        IconButton {
                                            width: Tokens.control-compact; height: Tokens.control-compact;
                                            icon: "eject"; icon-size: Tokens.icon-small;
                                            fg: Tokens.text-ter; hover-fg: Tokens.danger;
                                            hover-background: Tokens.danger-soft; focus-color: Tokens.danger;
                                            accessible-name: @tr("Disconnect {}", s.label);
                                            clicked => { root.disconnect-session(s.id); }
                                        }
                                    }
                                }
                                if root.server-filter == "" : Rectangle {
                                    height: 28px;
                                    background: root.drag-over-favorites || root.favorite-drag-over-list ? Tokens.accent-soft : transparent;
                                    border-radius: Tokens.r-row;
                                    Text { x: 10px; width: parent.width - 20px; text: I18n.favorites; color: root.drag-over-favorites || root.favorite-drag-over-list ? Tokens.accent-text : Tokens.text-ter; font-size: 10px; font-weight: 700; horizontal-alignment: left; vertical-alignment: bottom; }
                                }
                                if root.server-filter == "" : Rectangle {
                                    height: root.local-favorites.length * 30px + (root.favorite-drag-over-list ? 2px : 0px);
                                    background: root.favorite-remove-target ? Tokens.danger-soft : transparent;
                                    border-radius: Tokens.r-row;
                                    if root.favorite-drag-over-list : Rectangle {
                                        x: 8px; y: root.favorite-drop-index * 30px; width: parent.width - 16px; height: 2px;
                                        background: Tokens.accent;
                                        border-radius: 1px;
                                    }
                                    VerticalLayout {
                                        spacing: 0px;
                                        for f[i] in root.local-favorites : Rectangle {
                                            height: 30px; border-radius: Tokens.r-row;
                                            opacity: root.favorite-dragging && root.favorite-drag-index == i ? 0.36 : 1.0;
                                            background: root.favorite-dragging && root.favorite-drag-index == i ? Tokens.accent-soft : (favorite_action.has-hover || favorite_action.has-focus ? Tokens.row-hover : transparent);
                                            animate opacity { duration: 120ms; easing: ease-out; }
                                            favorite_action := KeyboardActionArea {
                                                accessible-name: @tr("Open favorite {}", f.label);
                                                accessible-help: f.path;
                                                clicked => { if (!root.favorite-dragging) { root.open-local-favorite(f.path); } }
                                                pointer-event(pe) => {
                                                    if (pe.button == PointerEventButton.left || pe.kind == PointerEventKind.move || pe.kind == PointerEventKind.up) {
                                                        if (pe.kind == PointerEventKind.down) {
                                                            root.drag-source = "favorite"; root.drag-index = i; root.favorite-drag-index = i; root.favorite-drop-index = i;
                                                            root.drag-name = f.label; root.drag-is-dir = true;
                                                            root.drag-pressed = true; root.drag-active = false;
                                                            root.drag-start-x = self.absolute-position.x + self.mouse-x;
                                                            root.drag-start-y = self.absolute-position.y + self.mouse-y;
                                                            root.favorite-list-y = self.absolute-position.y - i * 30px;
                                                        } else if (pe.kind == PointerEventKind.move && root.drag-pressed && root.drag-source == "favorite") {
                                                            root.drag-x = self.absolute-position.x + self.mouse-x;
                                                            root.drag-y = self.absolute-position.y + self.mouse-y;
                                                            if (!root.drag-active &&
                                                                (abs(root.drag-x - root.drag-start-x) > 5px ||
                                                                 abs(root.drag-y - root.drag-start-y) > 5px)) {
                                                                root.drag-active = true;
                                                            }
                                                            if (root.drag-active && root.favorite-drag-over-list) {
                                                                root.favorite-drop-index = Fmt.favorite-drop-index(root.drag-y, root.favorite-list-y, root.local-favorites.length);
                                                            }
                                                        } else if (pe.kind == PointerEventKind.up && root.drag-source == "favorite") {
                                                            if (root.drag-active) {
                                                                if (root.favorite-remove-target) {
                                                                    root.remove-local-favorite(root.favorite-drag-index);
                                                                } else if (root.favorite-drag-over-list) {
                                                                    root.reorder-local-favorite(root.favorite-drag-index, root.favorite-drop-index);
                                                                }
                                                            }
                                                            root.drag-pressed = false; root.drag-active = false; root.drag-source = "";
                                                            root.favorite-drag-index = -1; root.favorite-drop-index = -1;
                                                        }
                                                    }
                                                }
                                            }
                                            HorizontalLayout { padding-left: 8px; padding-right: 8px; spacing: 9px; alignment: start;
                                                if f.path == "~" : Rectangle {
                                                    width: 20px; height: 30px; background: transparent;
                                                    Icon { kind: "home"; x: 1px; y: 7px; width: 16px; height: 16px; fg: Tokens.folder; }
                                                }
                                                if f.path != "~" : FileIcon { is-dir: true; }
                                                Text { text: f.label; color: Tokens.text; font-size: 12px; vertical-alignment: center; overflow: elide; }
                                            }
                                        }
                                    }
                                }
                                Rectangle {
                                    height: 28px;
                                    Text { x: 10px; width: parent.width - 56px; text: @tr("SERVERS"); color: Tokens.text-ter; font-size: 10px; font-weight: 700; horizontal-alignment: left; vertical-alignment: bottom; }
                                    IconButton {
                                        x: parent.width - 34px; y: 2px; width: 28px; height: 24px;
                                        icon: "plus"; icon-size: Tokens.icon-small;
                                        accessible-name: @tr("Add server");
                                        clicked => { root.new-connection(); }
                                    }
                                }
                                // ── SAVED ──
                                Rectangle {
                                    height: 28px;
                                    Text { x: 10px; width: parent.width - 20px; text: I18n.saved + " · " + root.filtered-connections.length; color: Tokens.text-ter; font-size: 10px; font-weight: 700; horizontal-alignment: left; vertical-alignment: bottom; }
                                }
                                if root.filtered-connections.length == 0 : Rectangle {
                                    height: 64px;
                                    Text { text: root.server-filter == "" ? @tr("No servers yet.\nUse CONNECTIONS to add\nor import from ForkLift.") : @tr("No matching servers."); color: Tokens.text-sec; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; wrap: word-wrap; }
                                }
                                if root.filtered-connections.length > 0 : Rectangle {
                                    height: root.filtered-connections.length * 36px + (root.saved-drag-over-list ? 2px : 0px);
                                    border-radius: Tokens.r-row;
                                    background: root.saved-drag-over-list ? Tokens.accent-soft : transparent;
                                    if root.saved-drag-over-list : Rectangle {
                                        x: 8px; y: root.saved-drop-index * 36px; width: parent.width - 16px; height: 2px;
                                        background: Tokens.accent;
                                        border-radius: 1px;
                                    }
                                    VerticalLayout {
                                        spacing: 0px;
                                        for c[i] in root.filtered-connections : Rectangle {
                                            height: 36px;
                                            opacity: root.saved-dragging && root.saved-drag-id == c.id ? 0.36 : 1.0;
                                            animate opacity { duration: 120ms; easing: ease-out; }
                                            // connected saved-servers show just the green dot here; the live "active" tint lives
                                            // in the CONNECTED section above, so the two states no longer look identical.
                                            background: root.saved-dragging && root.saved-drag-id == c.id ? Tokens.accent-soft : (c.id == root.selected-connection ? Tokens.row-hover : (server_action.has-hover || server_action.has-focus ? Tokens.row-hover : transparent));
                                            border-radius: Tokens.r-row;
                                            if (c.id == root.left-conn-id || c.id == root.right-conn-id) : Rectangle { x: 0; y: 10px; width: 3px; height: 16px; background: Tokens.accent; border-radius: 2px; }
                                            if c.id == root.selected-connection && !(c.id == root.left-conn-id || c.id == root.right-conn-id) : Rectangle { x: 0; y: 10px; width: 3px; height: 16px; background: Tokens.text-ter; border-radius: 2px; }
                                            // Connection-status dot. Positioned absolutely (like the stripe above) because a
                                            // y-pinned child of the HorizontalLayout did not render in the software renderer.
                                            Rectangle { x: 12px; y: 15px; width: 6px; height: 6px; border-radius: 3px; background: (c.id == root.left-conn-id || c.id == root.right-conn-id) ? Tokens.success : Tokens.border-strong; }
                                            server_action := KeyboardActionArea {
                                                accessible-name: @tr("Select server {}", c.label);
                                                accessible-help: c.sub;
                                                clicked => { root.selected-connection = c.id; root.select-connection(c.id); }
                                                double-clicked => { root.selected-connection = c.id; root.connect-selected-to-pane(root.active-pane); }
                                                pointer-event(pe) => {
                                                    if (pe.button == PointerEventButton.left || pe.kind == PointerEventKind.move || pe.kind == PointerEventKind.up) {
                                                        if (pe.kind == PointerEventKind.down) {
                                                            root.drag-source = "server"; root.drag-index = i; root.saved-drag-index = i; root.saved-drag-id = c.id; root.saved-drop-index = i;
                                                            root.drag-name = c.label; root.drag-is-dir = false;
                                                            root.drag-pressed = true; root.drag-active = false;
                                                            root.drag-start-x = self.absolute-position.x + self.mouse-x;
                                                            root.drag-start-y = self.absolute-position.y + self.mouse-y;
                                                            root.saved-list-y = self.absolute-position.y - i * 36px;
                                                        } else if (pe.kind == PointerEventKind.move && root.drag-pressed && root.drag-source == "server") {
                                                            root.drag-x = self.absolute-position.x + self.mouse-x;
                                                            root.drag-y = self.absolute-position.y + self.mouse-y;
                                                            if (!root.drag-active &&
                                                                (abs(root.drag-x - root.drag-start-x) > 5px ||
                                                                 abs(root.drag-y - root.drag-start-y) > 5px)) {
                                                                root.drag-active = true;
                                                            }
                                                            if (root.drag-active && root.saved-drag-over-list) {
                                                                root.saved-drop-index = Fmt.saved-drop-index(root.drag-y, root.saved-list-y, root.filtered-connections.length);
                                                            }
                                                        } else if (pe.kind == PointerEventKind.up && root.drag-source == "server") {
                                                            if (root.drag-active && root.saved-drag-over-list) {
                                                                root.reorder-saved-connection(root.saved-drag-id, root.saved-drop-index);
                                                            }
                                                            root.drag-pressed = false; root.drag-active = false; root.drag-source = "";
                                                            root.saved-drag-index = -1; root.saved-drag-id = -1; root.saved-drop-index = -1;
                                                        }
                                                    }
                                                }
                                            }
                                            Text {
                                                x: 29px; y: 0px; width: parent.width - 110px; height: parent.height;
                                                text: c.label; color: Tokens.text; font-size: 12px; font-weight: c.id == root.active-connection ? 800 : 600;
                                                vertical-alignment: center; overflow: elide;
                                            }
                                            ProtocolBadge { x: parent.width - 72px; y: 10px; protocol: c.protocol; compact: true; }
                                            IconButton {
                                                x: parent.width - 31px; y: 4px;
                                                width: Tokens.control-compact; height: Tokens.control-compact;
                                                icon: "log-in"; icon-size: Tokens.icon-small;
                                                fg: Tokens.text-ter; hover-fg: Tokens.accent;
                                                hover-background: Tokens.accent-soft;
                                                accessible-name: @tr("Connect to {}", c.label);
                                                clicked => { root.selected-connection = c.id; root.connect-selected-to-pane(root.active-pane); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        // (Connect/Disconnect moved to the toolbar)
                    }
                }

                // dual pane
                HorizontalLayout {
                    // local
                    VerticalLayout {
                        width: root.pane-split;
                        Rectangle {
                            height: 48px;
                            background: root.active-pane == "local"
                                ? Tokens.pane-active
                                : (root.drag-active && root.drag-source == "remote" && root.drag-target == "local" ? #007AFF26 : Tokens.surface);
                            border-width: 1px;
                            border-color: (root.drag-active && root.drag-source == "remote" && root.drag-target == "local") ? Tokens.accent : Tokens.border;
                            if root.active-pane == "local" : Rectangle { x: 0; y: 0; width: parent.width; height: 2px; background: Tokens.accent; }
                            TouchArea { clicked => { root.active-pane = "local"; root.activate-pane("local"); } }
                            HorizontalLayout { padding-left: 12px; padding-right: 10px; padding-top: 8px; padding-bottom: 8px; spacing: 10px; alignment: center;
                                PaneBadge { text: root.left-kind == "local" ? I18n.local : I18n.remote; fill: root.left-kind == "local" ? Tokens.accent : Tokens.brand; }
                                Rectangle {
                                    horizontal-stretch: 1; height: 30px; border-radius: 6px;
                                    background: local_path_action.has-hover ? Tokens.row-hover : transparent;
                                    forward-focus: local_path_action;
                                    accessible-role: button;
                                    accessible-label: @tr("Edit path in left pane");
                                    accessible-description: root.local-path-display;
                                    accessible-action-default => { root.active-pane = "local"; root.activate-pane("local"); root.open-path-editor(0); }
                                    Text {
                                        x: 7px; width: parent.width - 14px; height: parent.height;
                                        text: root.local-path-display;
                                        color: local_path_action.has-hover ? Tokens.text : Tokens.text-sec;
                                        font-family: "JetBrains Mono"; font-size: 12px; vertical-alignment: center; horizontal-alignment: left; overflow: elide;
                                    }
                                    local_path_action := KeyboardActionArea { clicked => { root.active-pane = "local"; root.activate-pane("local"); root.open-path-editor(0); } }
                                }
                                IconButton { icon: "arrow-left"; accessible-name: @tr("Back in left pane"); disabled: root.local-loading; clicked => { root.nav-local-back(); } }
                                IconButton { icon: "arrow-right"; accessible-name: @tr("Forward in left pane"); disabled: root.local-loading; clicked => { root.nav-local-forward(); } }
                                IconButton { icon: "chevron-up"; accessible-name: @tr("Parent folder in left pane"); disabled: root.local-loading; clicked => { root.nav-local-up(); } }
                                IconButton { icon: "home"; accessible-name: @tr("Open local home in left pane"); disabled: root.local-loading; clicked => { root.set-pane-local(0); } }
                            }
                        }
                        Rectangle {
                            height: 36px; background: Tokens.surface;
                            HorizontalLayout { padding-left: 10px; padding-right: 10px; padding-top: 3px; padding-bottom: 3px; spacing: 6px;
                                SearchField { horizontal-stretch: 1; text <=> root.local-file-filter; placeholder: @tr("Filter this folder…"); accessible-name: @tr("Filter files in left pane"); edited(value) => { root.filter-files(0, value); } }
                                if root.left-kind == "remote" : GhostButton { height: 30px; text: @tr("Trash"); clicked => { root.open-remote-trash(0); } }
                                if root.left-kind == "remote" : GhostButton { height: 30px; text: @tr("Recursive"); clicked => { root.start-remote-search(0, root.local-file-filter); } }
                                GhostButton { height: 30px; text: @tr("Columns"); checkable: true; active: root.show-advanced-columns; clicked => { root.toggle-advanced-columns(); } }
                            }
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                        }
                        // column headers — clickable: sort by that column (toggle asc/desc if active)
                        Rectangle {
                            height: 24px; background: Tokens.bg;
                            HorizontalLayout { padding-left: 14px; padding-right: 14px; spacing: 10px; alignment: center;
                                Rectangle {
                                    width: 20px;
                                    SelectAllBox {
                                        checked: root.local-all-selected;
                                        accessible-name: @tr("Select all items in left pane");
                                        x: 2px; y: (parent.height - self.height) / 2;
                                        toggled => {
                                            root.active-pane = "local"; root.activate-pane("local");
                                            root.select-all("local", !root.local-all-selected);
                                            root.update-selected-path();
                                        }
                                    }
                                }
                                SortHeader { horizontal-stretch: 1; label: "NAME"; key: "name"; active-key: root.local-sort-key; active-dir: root.local-sort-dir; clicked-with(k) => { root.sort-local(k); } }
                                if !root.show-advanced-columns : SortHeader { width: 84px; label: "MODIFIED"; key: "date"; active-key: root.local-sort-key; active-dir: root.local-sort-dir; right-align: true; clicked-with(k) => { root.sort-local(k); } }
                                if root.show-advanced-columns : SortHeader { width: 58px; label: "OWNER"; key: "owner"; active-key: root.local-sort-key; active-dir: root.local-sort-dir; clicked-with(k) => { root.sort-local(k); } }
                                if root.show-advanced-columns : SortHeader { width: 58px; label: "GROUP"; key: "group"; active-key: root.local-sort-key; active-dir: root.local-sort-dir; clicked-with(k) => { root.sort-local(k); } }
                                if root.show-advanced-columns : SortHeader { width: 52px; label: "MODE"; key: "permissions"; active-key: root.local-sort-key; active-dir: root.local-sort-dir; right-align: true; clicked-with(k) => { root.sort-local(k); } }
                                SortHeader { width: 52px; label: "SIZE"; key: "size"; active-key: root.local-sort-key; active-dir: root.local-sort-dir; right-align: true; clicked-with(k) => { root.sort-local(k); } }
                            }
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                        }
                        Rectangle {
                            background: Tokens.bg; horizontal-stretch: 1;
                            if root.local-loading : Rectangle {
                                width: parent.width; height: parent.height; background: Tokens.bg;
                                Icon { kind: "activity"; width: 24px; height: 24px; fg: Tokens.accent; x: (parent.width - self.width) / 2; y: parent.height / 2 - 26px; }
                                Text { text: @tr("Loading…"); color: Tokens.text-sec; font-size: 12px; font-weight: 600; width: parent.width; height: 18px; y: parent.height / 2 + 6px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            // ListView recycles only the visible delegates. A 50k-entry directory
                            // therefore keeps selection in the Rust model without constructing
                            // 50k rectangles, text nodes, and pointer handlers.
                            if !root.local-loading : ListView {
                                width: parent.width; height: parent.height;
                                accessible-label: @tr("Files in left pane");
                                for e[i] in root.local-entries : l_row := Rectangle {
                                    property <bool> row-selected: i < root.local-selection.length && root.local-selection[i];
                                    accessible-role: list-item;
                                    accessible-label: e.name;
                                    accessible-description: e.is-dir ? @tr("Folder") : @tr("File");
                                    accessible-item-selectable: true;
                                    accessible-item-selected: l_row.row-selected;
                                    accessible-item-index: i;
                                    accessible-action-default => {
                                        root.select-entry("local", i, false, false);
                                        root.active-pane = "local";
                                        root.activate-pane("local");
                                        root.update-selected-path();
                                    }
                                        height: 30px;
                                        background: l_row.row-selected
                                            ? (root.active-pane == "local" ? Tokens.selection : Tokens.row-hover)
                                            : (l_touch.has-hover ? Tokens.row-hover : transparent);
                                        l_touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.select-entry("local", i, root.selection-shift, root.selection-command); root.selection-shift = false; root.selection-command = false; root.active-pane = "local"; root.activate-pane("local"); root.update-selected-path(); }
                                            double-clicked => { if (e.is-dir) { root.navigate-local(e.name); } }
                                            pointer-event(pe) => {
                                                if (pe.button == PointerEventButton.right && pe.kind == PointerEventKind.down) {
                                                    if (!l_row.row-selected) { root.select-entry("local", i, false, false); }
                                                    root.ctx-pane = "local"; root.ctx-index = i; root.ctx-name = e.name; root.ctx-is-dir = e.is-dir;
                                                    root.ctx-x = self.absolute-position.x + self.mouse-x;
                                                    root.ctx-y = self.absolute-position.y + self.mouse-y;
                                                    root.ctx-open = true;
                                                } else if (pe.button == PointerEventButton.left || pe.kind == PointerEventKind.move || pe.kind == PointerEventKind.up) {
                                                    if (pe.kind == PointerEventKind.down) {
                                                        root.selection-shift = pe.modifiers.shift;
                                                        root.selection-command = pe.modifiers.control;
                                                        if (!root.selection-shift && !root.selection-command && !l_row.row-selected) {
                                                            root.select-entry("local", i, false, false);
                                                            root.update-selected-path();
                                                        }
                                                        root.drag-source = "local"; root.drag-index = i; root.drag-name = e.name;
                                                        root.drag-is-dir = e.is-dir;
                                                        root.drag-pressed = true; root.drag-active = false;
                                                        root.drag-start-x = self.absolute-position.x + self.mouse-x;
                                                        root.drag-start-y = self.absolute-position.y + self.mouse-y;
                                                    } else if (pe.kind == PointerEventKind.move && root.drag-pressed) {
                                                        root.drag-x = self.absolute-position.x + self.mouse-x;
                                                        root.drag-y = self.absolute-position.y + self.mouse-y;
                                                        if (!root.drag-active &&
                                                            (abs(root.drag-x - root.drag-start-x) > 5px ||
                                                             abs(root.drag-y - root.drag-start-y) > 5px)) {
                                                            root.drag-active = true;
                                                        }
                                                        if (root.drag-active && !root.native-drag-started &&
                                                            (root.drag-x < 0px || root.drag-x > root.width || root.drag-y < 0px || root.drag-y > root.height)) {
                                                            root.native-drag-started = true;
                                                            root.start-external-drag("local", i);
                                                        }
                                                    } else if (pe.kind == PointerEventKind.up) {
                                                        // dropped — complete transfer if it ended over the remote pane
                                                        if (root.drag-active) {
                                                            if (root.drag-over-favorites) {
                                                                root.add-local-favorite(root.drag-source, root.drag-index);
                                                            } else if (root.drag-source == "local" && root.drag-target == "remote") {
                                                                root.local-selected = root.drag-index; root.upload();
                                                            } else if (root.drag-source == "remote" && root.drag-target == "local") {
                                                                root.remote-selected = root.drag-index; root.download();
                                                            }
                                                        }
                                                        root.drag-pressed = false; root.drag-active = false;
                                                        root.native-drag-started = false;
                                                    }
                                                }
                                            }
                                        }
                                        HorizontalLayout { padding-left: 14px; padding-right: 14px; spacing: 10px;
                                            FileIcon { is-dir: e.is-dir; selected: l_row.row-selected && root.active-pane == "local"; }
                                            Text { text: e.name; color: l_row.row-selected && root.active-pane == "local" ? Tokens.selection-text : Tokens.text; font-size: 13px; font-weight: l_row.row-selected ? 600 : 400; horizontal-stretch: 1; vertical-alignment: center; overflow: elide; }
                                            if !root.show-advanced-columns : Text { text: e.date; color: l_row.row-selected && root.active-pane == "local" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 84px; vertical-alignment: center; horizontal-alignment: right; }
                                            if root.show-advanced-columns : Text { text: e.owner; color: l_row.row-selected && root.active-pane == "local" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 58px; vertical-alignment: center; overflow: elide; }
                                            if root.show-advanced-columns : Text { text: e.group; color: l_row.row-selected && root.active-pane == "local" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 58px; vertical-alignment: center; overflow: elide; }
                                            if root.show-advanced-columns : Text { text: e.permissions; color: l_row.row-selected && root.active-pane == "local" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 52px; vertical-alignment: center; horizontal-alignment: right; }
                                            MetadataSizeCell {
                                                text: e.size-text;
                                                state: e.metadata-state;
                                                selected: l_row.row-selected && root.active-pane == "local";
                                                pulse: root.metadata-pulse;
                                            }
                                        }
                                }
                            }
                            if !root.local-loading && root.local-entries.length == 0 : Text { text: " "; color: Tokens.text-ter; }
                            if root.external-drop-active && root.external-drop-pane == 0 : Rectangle {
                                width: parent.width; height: parent.height;
                                background: Tokens.accent-soft.transparentize(0.18);
                                border-width: 2px; border-color: Tokens.accent; border-radius: 6px;
                                Icon { kind: "download"; width: 24px; height: 24px; fg: Tokens.accent; x: (parent.width - self.width) / 2; y: parent.height / 2 - 28px; }
                                Text { text: @tr("Copy here"); color: Tokens.accent-text; font-size: 13px; font-weight: 700; width: parent.width; height: 20px; y: parent.height / 2 + 6px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }

                    // center transfer column: drag to resize panes; click arrows to transfer
                    Rectangle {
                        width: 48px; background: Tokens.bg-alt;
                        Rectangle { x: (parent.width - 1px) / 2; width: splitter_focus.has-focus ? 3px : 1px; height: parent.height; background: splitter_focus.has-focus ? Tokens.accent : Tokens.border; }
                        TouchArea {
                            mouse-cursor: pointer;
                            pointer-event(pe) => {
                                if (pe.kind == PointerEventKind.move && self.pressed) {
                                    root.pane-split = clamp(self.absolute-position.x + self.mouse-x - 240px, 220px, root.width - 240px - 240px);
                                }
                            }
                        }
                        splitter_focus := FocusScope {
                            x: 20px; y: 96px; width: 8px; height: max(32px, parent.height - 192px);
                            accessible-role: slider;
                            accessible-label: @tr("Pane divider position");
                            accessible-value: root.pane-split / 1px;
                            accessible-value-minimum: 220;
                            accessible-value-maximum: max(220, (root.width - 480px) / 1px);
                            accessible-value-step: 20;
                            accessible-action-increment => { root.pane-split = min(root.width - 480px, root.pane-split + 20px); }
                            accessible-action-decrement => { root.pane-split = max(220px, root.pane-split - 20px); }
                            accessible-action-set-value(value) => { if value.is-float() { root.pane-split = clamp(value.to-float() * 1px, 220px, root.width - 480px); } }
                            key-pressed(event) => {
                                if event.text == Key.LeftArrow { root.pane-split = max(220px, root.pane-split - 20px); accept }
                                else if event.text == Key.RightArrow { root.pane-split = min(root.width - 480px, root.pane-split + 20px); accept }
                                else { reject }
                            }
                        }
                        RailButton {
                            x: 2px; y: 8px; icon: "compare";
                            text: @tr("COMPARE");
                            disabled: root.local-loading || root.remote-loading;
                            clicked => { root.open-directory-comparison(); }
                        }
                        RailButton {
                            x: 2px; y: 55px; icon: "link"; text: @tr("LINK");
                            checkable: true;
                            on: root.synchronized-browsing;
                            disabled: root.local-loading || root.remote-loading;
                            clicked => { root.toggle-synchronized-browsing(); }
                        }
                        dl := IconButton { icon: "arrow-left"; accessible-name: @tr("Copy selected items to left pane"); x: (parent.width - dl.width) / 2; y: parent.height / 2 - dl.height - 4px; clicked => { root.download(); } }
                        ul := IconButton { icon: "arrow-right"; accessible-name: @tr("Copy selected items to right pane"); x: (parent.width - ul.width) / 2; y: parent.height / 2 + 4px; clicked => { root.upload(); } }
                    }

                    // remote
                    VerticalLayout {
                        Rectangle {
                            height: 48px;
                            background: root.active-pane == "remote"
                                ? (root.right-kind == "local" ? Tokens.pane-active : (Tokens.theme == "dark" ? #281B36 : #F5EAFE))
                                : (root.drag-active && root.drag-source == "local" && root.drag-target == "remote" ? #007AFF26 : Tokens.surface);
                            border-width: 1px;
                            border-color: (root.drag-active && root.drag-source == "local" && root.drag-target == "remote") ? Tokens.accent : Tokens.border;
                            if root.active-pane == "remote" : Rectangle { x: 0; y: 0; width: parent.width; height: 2px; background: root.right-kind == "local" ? Tokens.accent : Tokens.brand; }
                            TouchArea { clicked => { root.active-pane = "remote"; root.activate-pane("remote"); } }
                            HorizontalLayout { padding-left: 12px; padding-right: 10px; padding-top: 8px; padding-bottom: 8px; spacing: 10px; alignment: center;
                                PaneBadge { text: root.right-kind == "local" ? I18n.local : I18n.remote; fill: root.right-kind == "local" ? Tokens.accent : Tokens.brand; }
                                Rectangle {
                                    horizontal-stretch: 1; height: 30px; border-radius: 6px;
                                    background: remote_path_action.has-hover ? Tokens.row-hover : transparent;
                                    forward-focus: remote_path_action;
                                    accessible-role: button;
                                    accessible-label: @tr("Edit path in right pane");
                                    accessible-description: root.remote-path-display;
                                    accessible-action-default => { root.active-pane = "remote"; root.activate-pane("remote"); root.open-path-editor(1); }
                                    Text {
                                        x: 7px; width: parent.width - 14px; height: parent.height;
                                        text: root.remote-path-display;
                                        color: root.remote-loading ? Tokens.accent : (remote_path_action.has-hover ? Tokens.text : Tokens.text-sec);
                                        font-family: "JetBrains Mono"; font-size: 12px; vertical-alignment: center; horizontal-alignment: left; overflow: elide;
                                    }
                                    remote_path_action := KeyboardActionArea { clicked => { root.active-pane = "remote"; root.activate-pane("remote"); root.open-path-editor(1); } }
                                }
                                IconButton { icon: "arrow-left"; accessible-name: @tr("Back in right pane"); disabled: root.remote-loading; clicked => { root.nav-remote-back(); } }
                                IconButton { icon: "arrow-right"; accessible-name: @tr("Forward in right pane"); disabled: root.remote-loading; clicked => { root.nav-remote-forward(); } }
                                IconButton { icon: "chevron-up"; accessible-name: @tr("Parent folder in right pane"); disabled: root.remote-loading; clicked => { root.nav-remote-up(); } }
                                IconButton { icon: "home"; accessible-name: @tr("Open local home in right pane"); disabled: root.remote-loading; clicked => { root.set-pane-local(1); } }
                            }
                        }
                        Rectangle {
                            height: 36px; background: Tokens.surface;
                            HorizontalLayout { padding-left: 10px; padding-right: 10px; padding-top: 3px; padding-bottom: 3px; spacing: 6px;
                                SearchField { horizontal-stretch: 1; text <=> root.remote-file-filter; placeholder: @tr("Filter this folder…"); accessible-name: @tr("Filter files in right pane"); edited(value) => { root.filter-files(1, value); } }
                                if root.right-kind == "remote" : GhostButton { height: 30px; text: @tr("Trash"); clicked => { root.open-remote-trash(1); } }
                                if root.right-kind == "remote" : GhostButton { height: 30px; text: @tr("Recursive"); clicked => { root.start-remote-search(1, root.remote-file-filter); } }
                                GhostButton { height: 30px; text: @tr("Columns"); checkable: true; active: root.show-advanced-columns; clicked => { root.toggle-advanced-columns(); } }
                            }
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                        }
                        // column headers — clickable: sort by that column (toggle asc/desc if active)
                        Rectangle {
                            height: 24px; background: Tokens.bg;
                            HorizontalLayout { padding-left: 14px; padding-right: 14px; spacing: 10px; alignment: center;
                                Rectangle {
                                    width: 20px;
                                    SelectAllBox {
                                        checked: root.remote-all-selected;
                                        accessible-name: @tr("Select all items in right pane");
                                        x: 2px; y: (parent.height - self.height) / 2;
                                        toggled => {
                                            root.active-pane = "remote"; root.activate-pane("remote");
                                            root.select-all("remote", !root.remote-all-selected);
                                            root.update-selected-path();
                                        }
                                    }
                                }
                                SortHeader { horizontal-stretch: 1; label: "NAME"; key: "name"; active-key: root.remote-sort-key; active-dir: root.remote-sort-dir; clicked-with(k) => { root.sort-remote(k); } }
                                if !root.show-advanced-columns : SortHeader { width: 84px; label: "MODIFIED"; key: "date"; active-key: root.remote-sort-key; active-dir: root.remote-sort-dir; right-align: true; clicked-with(k) => { root.sort-remote(k); } }
                                if root.show-advanced-columns : SortHeader { width: 58px; label: "OWNER"; key: "owner"; active-key: root.remote-sort-key; active-dir: root.remote-sort-dir; clicked-with(k) => { root.sort-remote(k); } }
                                if root.show-advanced-columns : SortHeader { width: 58px; label: "GROUP"; key: "group"; active-key: root.remote-sort-key; active-dir: root.remote-sort-dir; clicked-with(k) => { root.sort-remote(k); } }
                                if root.show-advanced-columns : SortHeader { width: 52px; label: "MODE"; key: "permissions"; active-key: root.remote-sort-key; active-dir: root.remote-sort-dir; right-align: true; clicked-with(k) => { root.sort-remote(k); } }
                                SortHeader { width: 52px; label: "SIZE"; key: "size"; active-key: root.remote-sort-key; active-dir: root.remote-sort-dir; right-align: true; clicked-with(k) => { root.sort-remote(k); } }
                            }
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                        }
                        Rectangle {
                            background: Tokens.bg; horizontal-stretch: 1;
                            if root.remote-loading : Rectangle {
                                width: parent.width; height: parent.height; background: Tokens.bg;
                                Icon { kind: "activity"; width: 24px; height: 24px; fg: Tokens.accent; x: (parent.width - self.width) / 2; y: parent.height / 2 - 26px; }
                                Text { text: @tr("Loading…"); color: Tokens.text-sec; font-size: 12px; font-weight: 600; width: parent.width; height: 18px; y: parent.height / 2 + 6px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            if !root.remote-loading : ListView {
                                width: parent.width; height: parent.height;
                                accessible-label: @tr("Files in right pane");
                                for e[i] in root.remote-entries : r_row := Rectangle {
                                    property <bool> row-selected: i < root.remote-selection.length && root.remote-selection[i];
                                    accessible-role: list-item;
                                    accessible-label: e.name;
                                    accessible-description: e.is-dir ? @tr("Folder") : @tr("File");
                                    accessible-item-selectable: true;
                                    accessible-item-selected: r_row.row-selected;
                                    accessible-item-index: i;
                                    accessible-action-default => {
                                        root.select-entry("remote", i, false, false);
                                        root.active-pane = "remote";
                                        root.activate-pane("remote");
                                        root.update-selected-path();
                                    }
                                        height: 30px;
                                        background: r_row.row-selected
                                            ? (root.active-pane == "remote" ? Tokens.selection : Tokens.row-hover)
                                            : (r_touch.has-hover ? Tokens.row-hover : transparent);
                                        r_touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.select-entry("remote", i, root.selection-shift, root.selection-command); root.selection-shift = false; root.selection-command = false; root.active-pane = "remote"; root.activate-pane("remote"); root.update-selected-path(); }
                                            double-clicked => { if (e.is-dir) { root.navigate-remote(e.name); } }
                                            pointer-event(pe) => {
                                                if (pe.button == PointerEventButton.right && pe.kind == PointerEventKind.down) {
                                                    if (!r_row.row-selected) { root.select-entry("remote", i, false, false); }
                                                    root.ctx-pane = "remote"; root.ctx-index = i; root.ctx-name = e.name; root.ctx-is-dir = e.is-dir;
                                                    root.ctx-x = self.absolute-position.x + self.mouse-x;
                                                    root.ctx-y = self.absolute-position.y + self.mouse-y;
                                                    root.ctx-open = true;
                                                } else if (pe.button == PointerEventButton.left || pe.kind == PointerEventKind.move || pe.kind == PointerEventKind.up) {
                                                    if (pe.kind == PointerEventKind.down) {
                                                        root.selection-shift = pe.modifiers.shift;
                                                        root.selection-command = pe.modifiers.control;
                                                        if (!root.selection-shift && !root.selection-command && !r_row.row-selected) {
                                                            root.select-entry("remote", i, false, false);
                                                            root.update-selected-path();
                                                        }
                                                        root.drag-source = "remote"; root.drag-index = i; root.drag-name = e.name;
                                                        root.drag-is-dir = e.is-dir;
                                                        root.drag-pressed = true; root.drag-active = false;
                                                        root.drag-start-x = self.absolute-position.x + self.mouse-x;
                                                        root.drag-start-y = self.absolute-position.y + self.mouse-y;
                                                    } else if (pe.kind == PointerEventKind.move && root.drag-pressed) {
                                                        root.drag-x = self.absolute-position.x + self.mouse-x;
                                                        root.drag-y = self.absolute-position.y + self.mouse-y;
                                                        if (!root.drag-active &&
                                                            (abs(root.drag-x - root.drag-start-x) > 5px ||
                                                             abs(root.drag-y - root.drag-start-y) > 5px)) {
                                                            root.drag-active = true;
                                                        }
                                                        if (root.drag-active && !root.native-drag-started &&
                                                            (root.drag-x < 0px || root.drag-x > root.width || root.drag-y < 0px || root.drag-y > root.height)) {
                                                            root.native-drag-started = true;
                                                            root.start-external-drag("remote", i);
                                                        }
                                                    } else if (pe.kind == PointerEventKind.up) {
                                                        // dropped — complete transfer if it ended over the local pane
                                                        if (root.drag-active) {
                                                            if (root.drag-over-favorites) {
                                                                root.add-local-favorite(root.drag-source, root.drag-index);
                                                            } else if (root.drag-source == "local" && root.drag-target == "remote") {
                                                                root.local-selected = root.drag-index; root.upload();
                                                            } else if (root.drag-source == "remote" && root.drag-target == "local") {
                                                                root.remote-selected = root.drag-index; root.download();
                                                            }
                                                        }
                                                        root.drag-pressed = false; root.drag-active = false;
                                                        root.native-drag-started = false;
                                                    }
                                                }
                                            }
                                        }
                                        HorizontalLayout { padding-left: 14px; padding-right: 14px; spacing: 10px;
                                            FileIcon { is-dir: e.is-dir; selected: r_row.row-selected && root.active-pane == "remote"; }
                                            Text { text: e.name; color: r_row.row-selected && root.active-pane == "remote" ? Tokens.selection-text : Tokens.text; font-size: 13px; font-weight: r_row.row-selected ? 600 : 400; horizontal-stretch: 1; vertical-alignment: center; overflow: elide; }
                                            if !root.show-advanced-columns : Text { text: e.date; color: r_row.row-selected && root.active-pane == "remote" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 84px; vertical-alignment: center; horizontal-alignment: right; }
                                            if root.show-advanced-columns : Text { text: e.owner; color: r_row.row-selected && root.active-pane == "remote" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 58px; vertical-alignment: center; overflow: elide; }
                                            if root.show-advanced-columns : Text { text: e.group; color: r_row.row-selected && root.active-pane == "remote" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 58px; vertical-alignment: center; overflow: elide; }
                                            if root.show-advanced-columns : Text { text: e.permissions; color: r_row.row-selected && root.active-pane == "remote" ? #FFFFFFCC : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; width: 52px; vertical-alignment: center; horizontal-alignment: right; }
                                            MetadataSizeCell {
                                                text: e.size-text;
                                                state: e.metadata-state;
                                                selected: r_row.row-selected && root.active-pane == "remote";
                                                pulse: root.metadata-pulse;
                                            }
                                        }
                                }
                            }
                            if !root.remote-loading && root.remote-entries.length == 0 : Text { text: " "; color: Tokens.text-ter; }
                            if root.external-drop-active && root.external-drop-pane == 1 : Rectangle {
                                width: parent.width; height: parent.height;
                                background: Tokens.accent-soft.transparentize(0.18);
                                border-width: 2px; border-color: Tokens.accent; border-radius: 6px;
                                Icon { kind: "download"; width: 24px; height: 24px; fg: Tokens.accent; x: (parent.width - self.width) / 2; y: parent.height / 2 - 28px; }
                                Text { text: @tr("Copy here"); color: Tokens.accent-text; font-size: 13px; font-weight: 700; width: parent.width; height: 20px; y: parent.height / 2 + 6px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }

            // ── status / transfer bar ──
            Rectangle {
                height: 40px; background: Tokens.surface;
                border-width: 1px; border-color: Tokens.border;
                Rectangle {
                    x: 14px; y: 6px; height: 28px; width: 339px;
                    background: copy_path_action.has-hover ? Tokens.row-hover : Tokens.field-bg;
                    border-radius: 6px;
                    forward-focus: copy_path_action;
                    accessible-role: button;
                    accessible-label: @tr("Copy selected path");
                    accessible-description: root.selected-path != "" ? root.selected-path : (root.active-pane == "local" ? root.local-cwd : root.remote-cwd);
                    accessible-action-default => { root.copy-selected-path(); }
                    HorizontalLayout { padding-left: 9px; padding-right: 9px; spacing: 7px; alignment: center;
                        VerticalLayout {
                            width: 14px; alignment: center;
                            Icon { kind: "copy"; width: 14px; height: 14px; fg: copy_path_action.has-hover ? Tokens.text : Tokens.text-sec; }
                        }
                        Text {
                            text: root.selected-path != "" ? root.selected-path : (root.active-pane == "local" ? root.local-cwd : root.remote-cwd);
                            color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 11px; horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: left; overflow: elide;
                        }
                    }
                    copy_path_action := KeyboardActionArea { clicked => { root.copy-selected-path(); } }
                }
                Rectangle { x: 363px; y: 11px; width: 1px; height: 18px; background: Tokens.border; }
                if root.transfer-active : ProgressBar { x: 374px; y: 18px; width: 150px; fraction: root.transfer-fraction; }
                if root.transfer-active : Text { x: 534px; y: 0px; width: 146px; height: parent.height; text: root.transfer-label; color: Tokens.text; font-weight: 500; font-size: 11px; vertical-alignment: center; overflow: elide; }
                if root.transfer-active && root.transfer-total > 0 : Text {
                    x: 690px; y: 0px; width: 122px; height: parent.height;
                    text: root.transfer-progress-text;
                    color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; vertical-alignment: center;
                }
                if root.status != "" && !root.transfer-active : Text { x: 384px; y: 0px; width: 360px; height: parent.height; text: root.localize-runtime(root.status, I18n.locale); color: Tokens.success; font-size: 11px; vertical-alignment: center; overflow: elide; }
                if root.error != "" : Text {
                    x: root.width - 620px; y: 0px; width: 260px; height: parent.height;
                    text: @tr("error: {}", root.localize-runtime(root.error, I18n.locale)); color: Tokens.danger; font-size: 11px; vertical-alignment: center; overflow: elide;
                }
                Text {
                    x: root.width - 254px; y: 0px; width: 84px; height: parent.height;
                    text: @tr("{n} item" | "{n} items" % (root.active-pane == "local" ? root.local-count : root.remote-count)); color: Tokens.text-ter; font-size: 12px; vertical-alignment: center; horizontal-alignment: right;
                }
                if (root.active-pane == "local" && root.left-kind == "remote") || (root.active-pane == "remote" && root.right-kind == "remote") : Rectangle {
                    x: root.width - 139px; y: 8px; height: 24px; width: 125px; border-radius: 4px; background: Tokens.accent-soft;
                    HorizontalLayout { padding-left: 8px; padding-right: 8px; spacing: 6px; alignment: center;
                        Rectangle {
                            width: 7px; height: 18px; background: transparent;
                            VerticalLayout { alignment: center;
                                Rectangle { width: 7px; height: 7px; border-radius: 4px; background: Tokens.success; }
                            }
                        }
                        Text { text: @tr("Connected · {}", root.active-pane == "local" ? root.left-protocol : root.right-protocol); color: Tokens.accent-text; font-size: 11px; font-weight: 600; vertical-alignment: center; overflow: elide; }
                    }
                }
            }
        }

        // Editable path bar (`Command-L`) with bounded session history and endpoint-bound Places.
        if root.path-editor-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { root.path-editor-open = false; } }
            path_card := Rectangle {
                x: (root.width - self.width) / 2;
                y: max(24px, (root.height - self.height) / 2);
                width: 560px; height: 520px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 12px;
                    Text {
                        text: @tr("Go to Folder");
                        color: Tokens.text; font-size: 16px; font-weight: 700;
                    }
                    Text {
                        text: root.path-editor-remote
                            ? (@tr("Absolute path on the active server"))
                            : (@tr("Absolute local path or ~/…"));
                        color: Tokens.text-sec; font-size: 11px;
                    }
                    path_entry := Field {
                        text <=> root.path-editor-value;
                        placeholder: root.path-editor-remote ? "/var/www" : "~/Documents";
                        accessible-name: @tr("Destination path");
                        accepted => {
                            root.path-editor-open = false;
                            root.navigate-path(root.path-editor-pane, root.path-editor-value);
                        }
                    }
                    Timer {
                        interval: 1ms;
                        running: true;
                        triggered => { self.running = false; path_entry.focus-and-select(); }
                    }
                    Rectangle { height: 1px; background: Tokens.border; }
                    ScrollView { vertical-stretch: 1;
                        VerticalLayout { spacing: 5px;
                            Text { text: @tr("RECENT IN THIS SESSION"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; height: 19px; vertical-alignment: center; }
                            if root.path-recent.length == 0 : Text { text: @tr("No earlier paths yet."); color: Tokens.text-sec; font-size: 11px; height: 28px; vertical-alignment: center; }
                            for item in root.path-recent : Rectangle {
                                height: 30px; border-radius: 6px; background: recent_path_action.has-hover || recent_path_action.has-focus ? Tokens.row-hover : transparent;
                                Icon { kind: "clock"; x: 7px; y: 7px; width: 16px; height: 16px; fg: Tokens.text-ter; }
                                Text { x: 31px; width: parent.width - 40px; height: parent.height; text: item.label; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 11px; overflow: elide; vertical-alignment: center; }
                                recent_path_action := KeyboardActionArea { accessible-name: @tr("Open recent path {}", item.label); accessible-help: item.path; clicked => { root.path-editor-open = false; root.navigate-path(root.path-editor-pane, item.path); } }
                            }
                            if root.path-editor-remote : Rectangle { height: 12px; background: transparent; }
                            if root.path-editor-remote : Text { text: @tr("PLACES"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; height: 19px; vertical-alignment: center; }
                            if root.path-editor-remote && root.path-places.length == 0 : Text { text: @tr("No saved places for this server."); color: Tokens.text-sec; font-size: 11px; height: 28px; vertical-alignment: center; }
                            for place[i] in root.path-places : Rectangle {
                                height: 30px; border-radius: 6px; background: place_action.has-hover || place_action.has-focus ? Tokens.row-hover : transparent;
                                Icon { kind: "folder"; x: 7px; y: 7px; width: 16px; height: 16px; fg: Tokens.folder; }
                                Text { x: 31px; width: parent.width - 72px; height: parent.height; text: place.label; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 11px; overflow: elide; vertical-alignment: center; }
                                place_action := KeyboardActionArea { x: 0px; width: parent.width - 36px; accessible-name: @tr("Open place {}", place.label); accessible-help: place.path; clicked => { root.path-editor-open = false; root.navigate-path(root.path-editor-pane, place.path); } }
                                Rectangle {
                                    x: parent.width - 32px; y: 2px; width: 28px; height: 26px; border-radius: 5px;
                                    background: remove_place_action.has-hover || remove_place_action.has-focus ? Tokens.danger-soft : transparent;
                                    Icon { kind: "x"; x: 7px; y: 6px; width: 14px; height: 14px; fg: remove_place_action.has-hover ? Tokens.danger : Tokens.text-ter; }
                                    remove_place_action := KeyboardActionArea { accessible-name: @tr("Remove place {}", place.label); clicked => { root.remove-remote-place(i); } }
                                }
                            }
                        }
                    }
                    Rectangle { height: 1px; background: Tokens.border; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        if root.path-editor-remote : GhostButton { text: @tr("Add Current to Places"); clicked => { root.add-current-remote-place(root.path-editor-pane); } }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        GhostButton { text: I18n.cancel-cap; clicked => { root.path-editor-open = false; } }
                        PrimaryButton { text: @tr("Go"); clicked => { root.path-editor-open = false; root.navigate-path(root.path-editor-pane, root.path-editor-value); } }
                    }
                }
            }
        }

        if root.remote-search-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: max(24px, (root.height - self.height) / 2);
                width: 620px; height: 520px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 11px;
                    Text { text: @tr("Search Remote Tree"); color: Tokens.text; font-size: 16px; font-weight: 700; }
                    Text { text: @tr("The recursive scan is bounded, time-limited, and cancellable."); color: Tokens.text-sec; font-size: 11px; }
                    HorizontalLayout { spacing: 8px;
                        remote_search_field := Field {
                            horizontal-stretch: 1;
                            text <=> root.remote-search-query;
                            placeholder: @tr("At least 2 characters");
                            accessible-name: @tr("Remote search query");
                            accepted => { if (!root.remote-search-running) { root.start-remote-search(root.remote-search-pane, root.remote-search-query); } }
                        }
                        Timer {
                            interval: 1ms;
                            running: true;
                            triggered => { self.running = false; remote_search_field.focus-and-select(); }
                        }
                        if !root.remote-search-running : PrimaryButton { text: @tr("Search"); clicked => { root.start-remote-search(root.remote-search-pane, root.remote-search-query); } }
                        if root.remote-search-running : GhostButton { text: I18n.cancel-cap; text-color: Tokens.danger; clicked => { root.cancel-remote-search(); } }
                    }
                    Text { text: root.localize-runtime(root.remote-search-summary, I18n.locale); color: root.remote-search-running ? Tokens.accent : Tokens.text-sec; font-size: 11px; height: 20px; vertical-alignment: center; overflow: elide; }
                    Rectangle { height: 1px; background: Tokens.border; }
                    Rectangle { vertical-stretch: 1; background: Tokens.bg; border-radius: 8px; border-width: 1px; border-color: Tokens.border; clip: true;
                        if root.remote-search-running : Rectangle {
                            Icon { kind: "activity"; width: 24px; height: 24px; fg: Tokens.accent; x: (parent.width - self.width) / 2; y: parent.height / 2 - 28px; }
                            Text { text: @tr("Scanning directories…"); color: Tokens.text-sec; font-size: 12px; width: parent.width; height: 20px; y: parent.height / 2 + 6px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        if !root.remote-search-running : ListView {
                            width: parent.width; height: parent.height;
                            accessible-label: @tr("Remote search results");
                            for result in root.remote-search-results : Rectangle {
                                height: 32px; background: search_result_action.has-hover || search_result_action.has-focus ? Tokens.row-hover : transparent;
                                forward-focus: search_result_action;
                                accessible-role: list-item;
                                accessible-label: result.path;
                                accessible-description: result.is-dir ? @tr("Folder") : @tr("File");
                                accessible-action-default => { root.remote-search-open = false; root.open-remote-search-result(root.remote-search-pane, result.path, result.is-dir); }
                                FileIcon { x: 7px; y: 1px; is-dir: result.is-dir; }
                                Text { x: 35px; width: parent.width - 128px; height: parent.height; text: result.path; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 10px; overflow: elide; vertical-alignment: center; }
                                Text { x: parent.width - 86px; width: 76px; height: parent.height; text: result.size-text; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; horizontal-alignment: right; vertical-alignment: center; }
                                search_result_action := KeyboardActionArea { clicked => { root.remote-search-open = false; root.open-remote-search-result(root.remote-search-pane, result.path, result.is-dir); } }
                                Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                            }
                        }
                        if !root.remote-search-running && root.remote-search-results.length == 0 : Text { text: @tr("No results."); color: Tokens.text-ter; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    HorizontalLayout { alignment: end;
                        GhostButton { text: I18n.close-cap; clicked => { if (root.remote-search-running) { root.cancel-remote-search(); } root.remote-search-open = false; } }
                    }
                }
            }
        }

        if root.comparison-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: max(24px, (root.height - self.height) / 2);
                width: 780px; height: 560px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 20px; spacing: 10px;
                    HorizontalLayout { height: 34px; alignment: center;
                        VerticalLayout { horizontal-stretch: 1;
                            Text { text: @tr("Current Directory Comparison"); color: Tokens.text; font-size: 16px; font-weight: 700; }
                            Text { text: @tr("Names are matched exactly; files use type, size, and modified time."); color: Tokens.text-sec; font-size: 10px; }
                        }
                        GhostButton { text: I18n.close-cap; clicked => { root.comparison-open = false; } }
                    }
                    HorizontalLayout { height: 50px; alignment: center;
                        Text { text: root.localize-runtime(root.comparison-summary, I18n.locale); color: Tokens.accent-text; font-size: 11px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; overflow: elide; }
                        SettingsToggleRow {
                            width: 230px; title: @tr("Differences only");
                            checked <=> root.comparison-differences-only;
                            toggled => { root.set-comparison-differences-only(root.comparison-differences-only); }
                        }
                    }
                    Rectangle { height: 28px; background: Tokens.surface; border-radius: 6px;
                        HorizontalLayout { padding-left: 10px; padding-right: 10px; spacing: 10px; alignment: center;
                            Text { width: 210px; text: @tr("NAME"); color: Tokens.text-ter; font-size: 9px; font-weight: 800; vertical-alignment: center; }
                            Text { width: 160px; text: @tr("LEFT PANE"); color: Tokens.text-ter; font-size: 9px; font-weight: 800; vertical-alignment: center; }
                            Text { width: 160px; text: @tr("RIGHT PANE"); color: Tokens.text-ter; font-size: 9px; font-weight: 800; vertical-alignment: center; }
                            Text { horizontal-stretch: 1; text: @tr("RESULT"); color: Tokens.text-ter; font-size: 9px; font-weight: 800; vertical-alignment: center; }
                        }
                    }
                    Rectangle { vertical-stretch: 1; background: Tokens.bg; border-radius: 8px; border-width: 1px; border-color: Tokens.border; clip: true;
                        ListView { width: parent.width; height: parent.height; accessible-label: @tr("Directory comparison results");
                            for row in root.comparison-results : Rectangle {
                                height: 40px; background: comparison_action.has-hover || comparison_action.has-focus ? Tokens.row-hover : transparent;
                                forward-focus: comparison_action;
                                accessible-role: list-item;
                                accessible-label: row.name;
                                accessible-description: row.status-label + ", " + row.left-detail + ", " + row.right-detail;
                                accessible-action-default => { root.comparison-open = false; root.reveal-comparison-row(row.name); }
                                HorizontalLayout { padding-left: 10px; padding-right: 10px; spacing: 10px; alignment: center;
                                    HorizontalLayout { width: 210px; spacing: 7px; alignment: center;
                                        FileIcon { is-dir: row.is-dir; }
                                        Text { text: row.name; color: Tokens.text; font-size: 11px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; overflow: elide; }
                                    }
                                    Text { width: 160px; text: row.left-detail; color: row.left-detail == "—" ? Tokens.text-ter : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 9px; vertical-alignment: center; overflow: elide; }
                                    Text { width: 160px; text: row.right-detail; color: row.right-detail == "—" ? Tokens.text-ter : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 9px; vertical-alignment: center; overflow: elide; }
                                    Text { horizontal-stretch: 1; text: row.status-label; color: row.status == "same" ? Tokens.success-text : (row.status == "type" ? Tokens.danger-text : Tokens.warning); font-size: 10px; font-weight: 700; vertical-alignment: center; overflow: elide; }
                                }
                                comparison_action := KeyboardActionArea { pointer-activates: false; clicked => { root.comparison-open = false; root.reveal-comparison-row(row.name); } double-clicked => { root.comparison-open = false; root.reveal-comparison-row(row.name); } }
                                Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                            }
                        }
                        if root.comparison-results.length == 0 : Text { text: @tr("No entries for the selected filter."); color: Tokens.text-ter; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Text { text: @tr("Double-click a row to select that name in both panes."); color: Tokens.text-ter; font-size: 10px; }
                }
            }
        }

        // ── context menu (custom overlay) ──
        if root.ctx-open : Rectangle {
            // backdrop: click anywhere closes
            background: transparent;
            bg := TouchArea { mouse-cursor: pointer; clicked => { root.ctx-open = false; } }
            // clamp so the menu stays on-screen
            ctx_card := Rectangle {
                x: min(root.ctx-x, root.width - 174px);
                y: min(root.ctx-y, root.height - 440px);
                width: 170px;
                height: ((root.ctx-pane == "local" && root.left-kind == "remote" && root.left-in-remote-trash)
                    || (root.ctx-pane == "remote" && root.right-kind == "remote" && root.right-in-remote-trash)) ? 432px : 406px;
                background: Tokens.surface-raised;
                border-radius: 8px;
                border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 24px; drop-shadow-offset-y: 6px; drop-shadow-color: #00000044;
                // stop clicks on the card from closing
                TouchArea { clicked => { } }
                VerticalLayout { padding: 4px; spacing: 0px;
                    if (root.ctx-pane == "local" && root.left-kind == "remote" && root.left-in-remote-trash)
                        || (root.ctx-pane == "remote" && root.right-kind == "remote" && root.right-in-remote-trash) : CtxItem {
                        text: @tr("Restore from Trash");
                        triggered => { root.ctx-open = false; root.restore-remote-trash(root.ctx-pane, root.ctx-name); }
                    }
                    if root.ctx-is-dir : CtxItem {
                        text: I18n.open-cap;
                        triggered => { root.ctx-open = false; if (root.ctx-pane == "local") { root.navigate-local(root.ctx-name); } else { root.navigate-remote(root.ctx-name); } }
                    }
                    if root.ctx-is-dir : CtxItem {
                        text: @tr("Calculate Size");
                        triggered => { root.ctx-open = false; root.calculate-folder-size(root.ctx-pane, root.ctx-name); }
                    }
                    if root.ctx-pane == "remote" && !root.ctx-is-dir : CtxItem {
                        text: I18n.download;
                        triggered => { root.ctx-open = false; root.remote-selected = root.ctx-index; root.download(); }
                    }
                    if root.ctx-pane == "local" && !root.ctx-is-dir : CtxItem {
                        text: I18n.upload;
                        triggered => { root.ctx-open = false; root.local-selected = root.ctx-index; root.upload(); }
                    }
                    CtxItem {
                        text: @tr("New Folder");
                        triggered => { root.ctx-open = false; root.file-operation-mode = "mkdir"; root.file-operation-pane = root.ctx-pane; root.file-operation-name = ""; root.file-operation-value = "New Folder"; root.file-operation-is-dir = true; root.file-operation-open = true; }
                    }
                    CtxItem {
                        text: @tr("Rename");
                        triggered => { root.ctx-open = false; root.file-operation-mode = "rename"; root.file-operation-pane = root.ctx-pane; root.file-operation-name = root.ctx-name; root.file-operation-value = root.ctx-name; root.file-operation-is-dir = root.ctx-is-dir; root.file-operation-open = true; }
                    }
                    CtxItem {
                        text: @tr("Batch Rename…");
                        triggered => { root.ctx-open = false; root.open-batch-rename(root.ctx-pane); }
                    }
                    CtxItem {
                        text: @tr("Duplicate");
                        triggered => { root.ctx-open = false; root.duplicate-selection(root.ctx-pane); }
                    }
                    if root.left-kind == "remote" && root.right-kind == "remote" && root.left-conn-id == root.right-conn-id : CtxItem {
                        text: @tr("Move to Other Pane");
                        triggered => { root.ctx-open = false; root.move-selection-other-pane(root.ctx-pane); }
                    }
                    if root.ctx-pane == "remote" && !root.ctx-is-dir : CtxItem {
                        text: @tr("Edit in Default App");
                        triggered => { root.ctx-open = false; root.edit-remote-file(root.ctx-pane, root.ctx-name); }
                    }
                    CtxItem {
                        text: @tr("Permissions");
                        triggered => { root.ctx-open = false; root.file-operation-mode = "chmod"; root.file-operation-pane = root.ctx-pane; root.file-operation-name = root.ctx-name; root.file-operation-value = root.ctx-is-dir ? "755" : "644"; root.file-operation-is-dir = root.ctx-is-dir; root.file-operation-open = true; }
                    }
                    CtxItem {
                        text: @tr("Copy");
                        triggered => { root.ctx-open = false; root.copy-file-selection(root.ctx-pane); }
                    }
                    if root.file-clipboard-count > 0 : CtxItem {
                        text: @tr("Paste");
                        triggered => { root.ctx-open = false; root.paste-file-selection(root.ctx-pane); }
                    }
                    CtxItem {
                        text: @tr("Inspector");
                        triggered => { root.ctx-open = false; root.open-inspector(root.ctx-pane, root.ctx-name); }
                    }
                    CtxItem {
                        text: I18n.copy-path;
                        triggered => { root.ctx-open = false; root.copy-path(root.ctx-pane, root.ctx-name); }
                    }
                    CtxItem {
                        text: I18n.del-cap;
                        danger: true;
                        triggered => {
                            root.ctx-open = false;
                            root.request-delete(root.ctx-pane, root.ctx-name, root.ctx-is-dir);
                        }
                    }
                }
            }
        }

        // ── folder synchronization (always previewed; mirror deletion is separately confirmed) ──
        if root.sync-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 700px; height: min(root.height - 24px, 760px); background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                clip: true;
                TouchArea { clicked => { } }
                VerticalLayout { spacing: 0px;
                    Rectangle {
                        height: 56px; background: transparent;
                        Rectangle { x: 18px; y: 13px; width: 30px; height: 30px; border-radius: 6px; background: Tokens.accent-soft;
                            Icon { kind: "transfer"; fg: Tokens.accent; x: 7px; y: 7px; }
                        }
                        Text { x: 58px; y: 0px; width: 450px; height: parent.height; text: @tr("Folder Synchronization"); color: Tokens.text; font-size: 15px; font-weight: 700; vertical-alignment: center; }
                        IconButton { icon: "x"; accessible-name: @tr("Close synchronization"); disabled: root.sync-scanning; x: 650px; y: 13px; clicked => { if (!root.sync-scanning) { root.sync-open = false; } } }
                        Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                    }
                    VerticalLayout { padding-left: 20px; padding-right: 20px; padding-top: 14px; padding-bottom: 10px; spacing: 10px;
                        Text { text: @tr("A dry-run always comes first. One-way mode never deletes; mirror mode requires separate confirmation and rechecks every file."); color: Tokens.text-sec; font-size: 11px; wrap: word-wrap; }
                        VerticalLayout { spacing: 5px;
                            Text { text: @tr("SYNC PROFILES"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                            HorizontalLayout { spacing: 8px;
                                Field { horizontal-stretch: 1; text <=> root.sync-profile-name; placeholder: @tr("Profile name"); accessible-name: @tr("Synchronization profile name"); }
                                GhostButton { width: 82px; text: @tr("Save"); clicked => { if (!root.sync-scanning) { root.save-sync-profile(root.sync-profile-name); } } }
                            }
                            if root.sync-profile-names.length > 0 : ListView {
                                height: 58px; width: parent.width;
                                accessible-label: @tr("Synchronization profiles");
                                for profile-name[i] in root.sync-profile-names : profile-row := Rectangle {
                                    height: 28px; border-radius: 5px; background: root.sync-profile-selected == i ? Tokens.accent-soft : (profile_action.has-hover || profile_action.has-focus ? Tokens.row-hover : transparent);
                                    Text { x: 9px; width: parent.width - 46px; height: parent.height; text: profile-name; color: root.sync-profile-selected == i ? Tokens.accent-text : Tokens.text; font-size: 10px; font-weight: root.sync-profile-selected == i ? 700 : 500; vertical-alignment: center; overflow: elide; }
                                    profile_action := KeyboardActionArea { width: parent.width - 34px; enabled: !root.sync-scanning; accessible-name: @tr("Load synchronization profile {}", profile-name); clicked => { root.load-sync-profile(i); } }
                                    Text { x: parent.width - 28px; width: 22px; height: parent.height; text: "x"; color: Tokens.danger-text; font-size: 10px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                    KeyboardActionArea { x: parent.width - 34px; width: 34px; enabled: !root.sync-scanning; accessible-name: @tr("Delete synchronization profile {}", profile-name); clicked => { root.delete-sync-profile(i); } }
                                }
                            }
                        }
                        VerticalLayout { spacing: 5px;
                            Text { text: @tr("DIRECTION"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                            Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                HorizontalLayout { padding: 3px; spacing: 3px;
                                    ChoiceSegment { text: @tr("LOCAL  →  SERVER"); text-size: 11px; selected: root.sync-direction == "upload"; enabled: !root.sync-scanning; chosen => { root.sync-direction = "upload"; root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                    ChoiceSegment { text: @tr("SERVER  →  LOCAL"); text-size: 11px; selected: root.sync-direction == "download"; enabled: !root.sync-scanning; chosen => { root.sync-direction = "download"; root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                }
                            }
                        }
                        VerticalLayout { spacing: 5px;
                            Text { text: @tr("MODE"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                            Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                HorizontalLayout { padding: 3px; spacing: 3px;
                                    ChoiceSegment { text: @tr("ONE-WAY — KEEP TARGET-ONLY"); selected: root.sync-mode == "one_way"; enabled: !root.sync-scanning; chosen => { root.sync-mode = "one_way"; root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                    ChoiceSegment { text: @tr("MIRROR — DELETE TARGET-ONLY"); danger: true; selected: root.sync-mode == "mirror"; enabled: !root.sync-scanning; chosen => { root.sync-mode = "mirror"; root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                }
                            }
                        }
                        VerticalLayout { spacing: 5px;
                            Text { text: @tr("COMPARISON"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                            Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                HorizontalLayout { padding: 3px; spacing: 3px;
                                    ChoiceSegment { text: @tr("SIZE + MODIFIED"); text-size: 11px; selected: root.sync-comparison == "size_mtime"; enabled: !root.sync-scanning; chosen => { root.sync-comparison = "size_mtime"; root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                    ChoiceSegment { text: @tr("SIZE ONLY"); text-size: 11px; selected: root.sync-comparison == "size_only"; enabled: !root.sync-scanning; chosen => { root.sync-comparison = "size_only"; root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                    ChoiceSegment { text: "SHA-256"; text-size: 11px; selected: root.sync-comparison == "checksum"; enabled: !root.sync-scanning; chosen => { root.sync-comparison = "checksum"; root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                }
                            }
                        }
                        HorizontalLayout { spacing: 10px;
                            VerticalLayout { spacing: 5px; horizontal-stretch: 1;
                                Text { text: @tr("DATE TOLERANCE (SECONDS)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Field { text <=> root.sync-mtime-tolerance; placeholder: "2"; accessible-name: @tr("Date tolerance in seconds"); edited => { root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                            }
                            VerticalLayout { spacing: 5px; horizontal-stretch: 1;
                                Text { text: @tr("SERVER CLOCK OFFSET (S)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Field { text <=> root.sync-server-clock-offset; placeholder: "0"; accessible-name: @tr("Server clock offset in seconds"); edited => { root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                            }
                        }
                        VerticalLayout { spacing: 5px;
                            Text { text: @tr("EXCLUDE (COMMA-SEPARATED; * AND ? SUPPORTED)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                            Field { text <=> root.sync-exclusions; placeholder: ".git, .DS_Store, *.part"; accessible-name: @tr("Excluded file patterns"); edited => { root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                            HorizontalLayout { height: 22px; spacing: 5px;
                                Text { text: @tr("PRESET:"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                                for preset[i] in 4 : Rectangle { width: 72px; border-radius: 5px; background: preset_action.has-hover || preset_action.has-focus ? Tokens.row-hover : Tokens.surface;
                                    Text { text: i == 0 ? (@tr("DEFAULT")) : (i == 1 ? "WEB" : (i == 2 ? "NODE" : (@tr("NONE")))); color: Tokens.text-sec; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                    preset_action := KeyboardActionArea { enabled: !root.sync-scanning; accessible-name: @tr("Use exclusion preset {}", i == 0 ? (@tr("DEFAULT")) : (i == 1 ? "WEB" : (i == 2 ? "NODE" : (@tr("NONE"))))); clicked => { root.sync-exclusions = i == 0 ? ".git, .DS_Store, *.part, *.tmp" : (i == 1 ? ".git, .DS_Store, node_modules, vendor, *.map, *.tmp" : (i == 2 ? ".git, .DS_Store, node_modules, dist, coverage, *.log, *.tmp" : "")); root.sync-mirror-confirmed = false; root.sync-preview-ready = false; } }
                                }
                            }
                        }
                        Rectangle { height: 34px; border-radius: 6px; background: Tokens.accent-soft;
                            if root.sync-scanning : Icon { kind: "refresh"; fg: Tokens.accent; x: 10px; y: 9px; }
                            Text { x: 34px; width: parent.width - 44px; height: parent.height; text: root.localize-runtime(root.sync-summary, I18n.locale); color: Tokens.accent-text; font-size: 11px; font-weight: 600; vertical-alignment: center; overflow: elide; }
                        }
                        if root.sync-mode == "mirror" && root.sync-preview-ready : Rectangle {
                            height: 38px; border-radius: 6px; background: Tokens.danger-soft;
                            Text { x: 10px; y: 2px; width: 590px; height: 16px; text: @tr("I confirm deletion of selected files that exist only at the target"); color: Tokens.danger-text; font-size: 10px; font-weight: 700; vertical-alignment: center; }
                            Text { x: 10px; y: 20px; width: 590px; height: 14px; text: @tr("Deletion runs only after successful copies and a fresh metadata check."); color: Tokens.text-sec; font-size: 9px; vertical-alignment: center; }
                            Rectangle { x: 610px; y: 8px; width: 38px; height: 22px; border-radius: 11px; background: root.sync-mirror-confirmed ? Tokens.danger : Tokens.border-strong;
                                forward-focus: mirror_confirm_action;
                                accessible-role: switch;
                                accessible-label: @tr("Confirm mirror deletions");
                                accessible-checkable: true;
                                accessible-checked: root.sync-mirror-confirmed;
                                accessible-action-default => { root.sync-mirror-confirmed = !root.sync-mirror-confirmed; }
                                Rectangle { width: 16px; height: 16px; border-radius: 8px; x: root.sync-mirror-confirmed ? 19px : 3px; y: 3px; background: #FFFFFF; }
                                mirror_confirm_action := KeyboardActionArea { clicked => { root.sync-mirror-confirmed = !root.sync-mirror-confirmed; } }
                            }
                        }
                    }
                    Rectangle { height: 26px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                        Text { x: 16px; width: 370px; height: parent.height; text: @tr("FILE"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                        Text { x: 405px; width: 92px; height: parent.height; text: @tr("ACTION"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                        Text { x: 505px; width: 105px; height: parent.height; text: @tr("REASON"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                        Text { x: 614px; width: 68px; height: parent.height; text: @tr("SIZE"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; horizontal-alignment: right; vertical-alignment: center; }
                    }
                    ScrollView { vertical-stretch: 1;
                        VerticalLayout { spacing: 0px;
                            if root.sync-rows.length == 0 : Rectangle { height: 185px;
                                Text { text: root.sync-scanning ? (@tr("Comparing folders…")) : (@tr("Run Preview to see the plan.")); color: Tokens.text-ter; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            for row[i] in root.sync-rows : Rectangle { height: 30px; background: sync_row_action.has-hover ? Tokens.row-hover : transparent; border-width: 1px; border-color: sync_row_action.has-focus ? Tokens.accent : Tokens.border;
                                forward-focus: sync_row_action;
                                accessible-role: checkbox;
                                accessible-label: row.path;
                                accessible-description: row.action + ", " + row.reason + ", " + row.size-text;
                                accessible-enabled: !root.sync-scanning;
                                accessible-checkable: true;
                                accessible-checked: row.included;
                                accessible-action-default => { if (!root.sync-scanning) { root.toggle-sync-row(i); } }
                                sync_row_action := KeyboardActionArea { enabled: !root.sync-scanning; clicked => { root.toggle-sync-row(i); } }
                                Rectangle { x: 10px; y: 8px; width: 14px; height: 14px; border-radius: 3px; border-width: 1px; border-color: row.included ? Tokens.accent : Tokens.border-strong; background: row.included ? Tokens.accent : transparent;
                                    Text { text: row.included ? "✓" : ""; color: #FFFFFF; font-size: 10px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                }
                                Text { x: 32px; width: 354px; height: parent.height; text: row.path; color: row.included ? Tokens.text : Tokens.text-ter; font-family: "JetBrains Mono"; font-size: 10px; overflow: elide; vertical-alignment: center; }
                                Text { x: 405px; width: 92px; height: parent.height; text: row.action; color: row.action == "DELETE" ? Tokens.danger-text : (row.action == "UPLOAD" ? Tokens.brand : Tokens.accent-text); font-size: 10px; font-weight: 700; vertical-alignment: center; }
                                Text { x: 505px; width: 105px; height: parent.height; text: row.reason; color: Tokens.text-sec; font-size: 10px; vertical-alignment: center; overflow: elide; }
                                Text { x: 614px; width: 68px; height: parent.height; text: row.size-text; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; horizontal-alignment: right; vertical-alignment: center; }
                            }
                        }
                    }
                    Rectangle { height: 60px; background: transparent; border-width: 1px; border-color: Tokens.border;
                        HorizontalLayout { padding-left: 16px; padding-right: 16px; padding-top: 13px; padding-bottom: 13px; spacing: 10px; alignment: end;
                            GhostButton { text: I18n.close-cap; clicked => { if (!root.sync-scanning) { root.sync-open = false; } } }
                            if root.sync-preview-ready && !root.sync-scanning : GhostButton { text: @tr("Export Report"); clicked => { root.export-sync-report(); } }
                            GhostButton { text: root.sync-preview-ready ? (@tr("Refresh Preview")) : (@tr("Dry-run Preview")); clicked => { if (!root.sync-scanning) { root.preview-folder-sync(root.sync-direction, root.sync-exclusions, root.sync-comparison, root.sync-mtime-tolerance, root.sync-server-clock-offset, root.sync-mode); } } }
                            if root.sync-preview-ready && !root.sync-scanning && root.sync-rows.length > 0 : PrimaryButton { text: @tr("Recheck & Apply"); clicked => { root.apply-folder-sync(root.sync-direction, root.sync-exclusions, root.sync-comparison, root.sync-mtime-tolerance, root.sync-server-clock-offset, root.sync-mode, root.sync-mirror-confirmed); } }
                        }
                    }
                }
            }
        }

        if root.file-operation-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 420px; height: 220px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 12px;
                    Text {
                        text: root.file-operation-mode == "mkdir" ? (@tr("New Folder")) : (root.file-operation-mode == "chmod" ? (@tr("Change Permissions")) : (@tr("Rename")));
                        color: Tokens.text; font-size: 15px; font-weight: 700;
                    }
                    Text {
                        text: root.file-operation-mode == "chmod" ? (@tr("Octal mode (for example 644 or 755)")) : (root.file-operation-mode == "rename" ? root.file-operation-name : (@tr("Folder name")));
                        color: Tokens.text-sec; font-size: 11px; overflow: elide;
                    }
                    Field { text <=> root.file-operation-value; placeholder: root.file-operation-mode == "chmod" ? "644" : "name"; accessible-name: root.file-operation-mode == "chmod" ? @tr("Permissions") : (root.file-operation-mode == "mkdir" ? @tr("Folder name") : @tr("New name")); }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: I18n.cancel-cap; clicked => { root.file-operation-open = false; } }
                        PrimaryButton { text: root.file-operation-mode == "mkdir" ? (@tr("Create")) : I18n.save-cap; clicked => {
                            root.file-operation-open = false;
                            root.confirm-file-operation(root.file-operation-mode, root.file-operation-pane, root.file-operation-name, root.file-operation-value, root.file-operation-is-dir);
                        } }
                    }
                }
            }
        }

        if root.batch-rename-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2; y: (root.height - self.height) / 2;
                width: 480px; height: 286px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 10px;
                    Text { text: @tr("Batch Rename"); color: Tokens.text; font-size: 15px; font-weight: 700; }
                    Text { text: root.localize-runtime(root.batch-rename-summary, I18n.locale); color: Tokens.text-sec; font-size: 11px; overflow: elide; }
                    Text { text: @tr("FIND IN NAME"); color: Tokens.text-ter; font-size: 9px; font-weight: 800; }
                    batch_find := Field { text <=> root.batch-rename-find; placeholder: @tr("Required text"); accessible-name: @tr("Text to find in file names"); }
                    Text { text: @tr("REPLACE WITH (MAY BE EMPTY)"); color: Tokens.text-ter; font-size: 9px; font-weight: 800; }
                    Field { text <=> root.batch-rename-replace; placeholder: @tr("Replacement"); accessible-name: @tr("Replacement text"); }
                    HorizontalLayout { alignment: end; spacing: 10px;
                        GhostButton { text: I18n.cancel-cap; clicked => { root.batch-rename-open = false; } }
                        PrimaryButton { text: @tr("Rename All"); clicked => { root.batch-rename-open = false; root.apply-batch-rename(root.batch-rename-pane, root.batch-rename-find, root.batch-rename-replace); } }
                    }
                }
                Timer { interval: 1ms; running: true; triggered => { self.running = false; batch_find.focus-and-select(); } }
            }
        }

        if root.inspector-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2; y: (root.height - self.height) / 2;
                width: 520px; height: 430px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 10px;
                    HorizontalLayout { height: 34px; alignment: center;
                        Text { text: @tr("Metadata Inspector"); color: Tokens.text; font-size: 15px; font-weight: 700; horizontal-stretch: 1; }
                        GhostButton { text: I18n.close-cap; clicked => { root.inspector-open = false; } }
                    }
                    HorizontalLayout { height: 42px; spacing: 10px; alignment: center;
                        FileIcon { is-dir: root.inspector-kind == "folder"; }
                        VerticalLayout { horizontal-stretch: 1;
                            Text { text: root.inspector-name; color: Tokens.text; font-size: 13px; font-weight: 700; overflow: elide; }
                            Text { text: root.inspector-path; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 9px; overflow: elide; }
                        }
                        if root.inspector-loading : Icon { kind: "activity"; fg: Tokens.accent; }
                    }
                    Rectangle { height: 1px; background: Tokens.border; }
                    for detail in [
                        { label: @tr("Kind"), value: root.inspector-kind },
                        { label: @tr("Size"), value: root.inspector-size },
                        { label: @tr("Modified"), value: root.inspector-modified },
                        { label: @tr("Permissions"), value: root.inspector-permissions },
                        { label: @tr("Owner"), value: root.inspector-owner },
                        { label: @tr("Group"), value: root.inspector-group },
                    ] : Rectangle {
                        height: 38px; background: transparent;
                        Text { x: 0px; width: 150px; height: parent.height; text: detail.label; color: Tokens.text-ter; font-size: 10px; font-weight: 700; vertical-alignment: center; }
                        Text { x: 160px; width: parent.width - 160px; height: parent.height; text: detail.value == "" ? "—" : detail.value; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 11px; vertical-alignment: center; overflow: elide; }
                        Rectangle { x: 0px; y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                    }
                    Rectangle { vertical-stretch: 1; }
                    Text { text: @tr("A missing value means the filesystem or protocol did not expose it."); color: Tokens.text-ter; font-size: 10px; }
                }
            }
        }

        // ── delete-confirmation dialog (trash local / delete remote) ──
        if root.delete-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }   // modal — force an explicit choice
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 440px; height: root.delete-remote-quarantine ? 325px : 305px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 24px; spacing: 16px;
                    Rectangle {
                        width: 44px; height: 44px; border-radius: 22px; background: Tokens.danger-soft;
                        Icon { kind: "trash"; fg: Tokens.danger; width: 22px; height: 22px; x: 11px; y: 11px; }
                    }
                    Text {
                        text: root.delete-remote-quarantine
                            ? (@tr("Move to Remote Trash?"))
                            : (root.delete-is-dir
                                ? (@tr("Delete folder?"))
                                : (@tr("Delete file?")));
                        color: Tokens.text; font-size: 16px; font-weight: 700; height: 19px; vertical-alignment: center;
                    }
                    VerticalLayout { spacing: 8px;
                        Text {
                            height: 34px;
                            text: root.delete-remote-quarantine
                                ? @tr("\"{}\" will be moved to the hidden .gmacftp-trash folder on this server.", root.delete-name)
                                : (root.delete-pane == "remote"
                                    ? @tr("\"{}\" will be permanently deleted from the server. This cannot be undone.", root.delete-name)
                                    : @tr("\"{}\" will be moved to the Trash. You can restore it later from Finder.", root.delete-name));
                            color: Tokens.text-sec; font-size: 12px; wrap: word-wrap;
                        }
                        Rectangle {
                            height: 26px; width: 194px; border-radius: 4px; background: Tokens.bg;
                            HorizontalLayout { padding-left: 9px; padding-right: 9px; spacing: 7px; alignment: center;
                                Icon { kind: "copy"; width: 13px; height: 13px; fg: Tokens.text-ter; }
                                Text {
                                    text: root.delete-path != "" ? root.delete-path : root.delete-name;
                                    color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; overflow: elide; horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: left;
                                }
                            }
                        }
                        // "Don't ask again this session" — sticky until the connection ends
                        Rectangle {
                            height: 22px;
                            forward-focus: delete_confirm_action;
                            accessible-role: checkbox;
                            accessible-label: I18n.delete-dont-ask;
                            accessible-checkable: true;
                            accessible-checked: root.delete-dont-ask;
                            accessible-action-default => { root.delete-dont-ask = !root.delete-dont-ask; }
                            delete_confirm_action := KeyboardActionArea { clicked => { root.delete-dont-ask = !root.delete-dont-ask; } }
                            HorizontalLayout { spacing: 8px; alignment: start;
                                Rectangle {
                                    width: 15px; height: 15px; y: (parent.height - self.height) / 2;
                                    border-radius: 4px; border-width: 1px;
                                    border-color: root.delete-dont-ask ? Tokens.accent : Tokens.border-strong;
                                    background: root.delete-dont-ask ? Tokens.accent : transparent;
                                    if root.delete-dont-ask : Path {
                                        x: 3px; y: 4px; width: 9px; height: 7px;
                                        commands: "M0 3.4 L3.2 6.6 L9 0.6";
                                        fill: transparent; stroke: #FFFFFF; stroke-width: 2px;
                                    }
                                }
                                Text { text: I18n.delete-dont-ask; color: Tokens.text-sec; font-size: 12px; vertical-alignment: center; }
                            }
                        }
                    }
                    Rectangle { height: 0px; vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        Rectangle {
                            width: 68px; height: 32px; border-radius: 6px;
                            background: delete_cancel_action.has-hover ? Tokens.row-hover : Tokens.bg;
                            border-width: 1px; border-color: delete_cancel_action.has-focus ? Tokens.accent : Tokens.border-strong;
                            Text { text: I18n.cancel-cap; color: Tokens.text; font-size: 12px; font-weight: 500; horizontal-alignment: center; vertical-alignment: center; }
                            delete_cancel_action := KeyboardActionArea { accessible-name: I18n.cancel-cap; clicked => { root.delete-open = false; } }
                        }
                        if root.delete-remote-quarantine : Rectangle {
                            width: 119px; height: 32px; border-radius: 6px;
                            background: delete_permanent_action.has-hover ? Tokens.danger-soft : transparent;
                            border-width: delete_permanent_action.has-focus ? 2px : 1px; border-color: Tokens.danger;
                            Text { text: @tr("Delete Permanently"); color: Tokens.danger-text; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                            delete_permanent_action := KeyboardActionArea { accessible-name: @tr("Delete Permanently"); clicked => { root.confirm-delete(true); } }
                        }
                        Rectangle {
                            width: root.delete-remote-quarantine ? 118px : 91px; height: 32px; border-radius: 6px;
                            background: delete_ok_action.has-hover
                                ? (root.delete-remote-quarantine ? Tokens.primary-fill-hover : Tokens.danger-fill-hover)
                                : (root.delete-remote-quarantine ? Tokens.primary-fill : Tokens.danger-fill);
                            border-width: delete_ok_action.has-focus ? 2px : 0px; border-color: #FFFFFF;
                            Text {
                                text: root.delete-remote-quarantine
                                    ? (@tr("Move to Trash"))
                                    : I18n.del-cap;
                                color: #FFFFFF; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center;
                            }
                            delete_ok_action := KeyboardActionArea { accessible-name: root.delete-remote-quarantine ? (@tr("Move to Trash")) : I18n.del-cap; clicked => { root.confirm-delete(false); } }
                        }
                    }
                }
            }
        }

        // ── failed file in a multi-file copy: pause the batch until the user decides ──
        if root.transfer-error-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 440px; height: 270px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 24px; spacing: 14px;
                    Rectangle {
                        width: 44px; height: 44px; border-radius: 22px; background: Tokens.danger-soft;
                        Icon { kind: "x"; fg: Tokens.danger; width: 21px; height: 21px; x: 11.5px; y: 11.5px; }
                    }
                    Text {
                        text: @tr("A file could not be copied");
                        color: Tokens.text; font-size: 16px; font-weight: 700; height: 20px;
                    }
                    Text {
                        text: root.transfer-error-name;
                        color: Tokens.text; font-family: "JetBrains Mono"; font-size: 11px;
                        height: 18px; overflow: elide;
                    }
                    Text {
                        text: root.localize-runtime(root.transfer-error-message, I18n.locale);
                        color: Tokens.danger-text; font-size: 11px; height: 32px;
                        wrap: word-wrap; overflow: elide;
                    }
                    Text {
                        text: root.transfer-error-needs-decision
                            ? (@tr("Skip this file and continue, or stop the entire batch?"))
                            : (@tr("This file transfer was stopped. Details remain available in the transfer panel."));
                        color: Tokens.text-sec; font-size: 12px; height: 32px; wrap: word-wrap;
                    }
                    Rectangle { height: 0px; vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        if root.transfer-error-needs-decision : Rectangle {
                            width: 142px; height: 32px; border-radius: 6px;
                            background: stop_batch_action.has-hover ? Tokens.danger-fill-hover : Tokens.danger-fill;
                            border-width: stop_batch_action.has-focus ? 2px : 0px; border-color: #FFFFFF;
                            Text { text: @tr("Stop batch"); color: #FFFFFF; font-size: 12px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                            stop_batch_action := KeyboardActionArea { accessible-name: @tr("Stop batch"); clicked => { root.resolve-transfer-error(false); } }
                        }
                        if root.transfer-error-needs-decision : Rectangle {
                            width: 164px; height: 32px; border-radius: 6px;
                            background: skip_file_action.has-hover ? Tokens.primary-fill-hover : Tokens.primary-fill;
                            border-width: skip_file_action.has-focus ? 2px : 0px; border-color: #FFFFFF;
                            Text { text: @tr("Skip and continue"); color: #FFFFFF; font-size: 12px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                            skip_file_action := KeyboardActionArea { accessible-name: @tr("Skip and continue"); clicked => { root.resolve-transfer-error(true); } }
                        }
                        if !root.transfer-error-needs-decision : Rectangle {
                            width: 82px; height: 32px; border-radius: 6px;
                            background: dismiss_error_action.has-hover ? Tokens.primary-fill-hover : Tokens.primary-fill;
                            border-width: dismiss_error_action.has-focus ? 2px : 0px; border-color: #FFFFFF;
                            Text { text: @tr("OK"); color: #FFFFFF; font-size: 12px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                            dismiss_error_action := KeyboardActionArea { accessible-name: @tr("OK"); clicked => { root.transfer-error-open = false; root.transfer-error-message = ""; root.transfer-error-name = ""; } }
                        }
                    }
                }
            }
        }

        // ── sort popover (Name / Size / Date + Ascending/Descending) ──
        if root.sort-open && !root.manager-open && !root.editor-open && !root.palette-open : Rectangle {
            background: transparent;
            TouchArea { clicked => { root.sort-open = false; } }
            Rectangle {
                x: root.sort-pane == "local" ? 258px : 700px;
                y: 96px; width: 184px; height: 165px;
                background: Tokens.card; border-radius: 10px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 28px; drop-shadow-offset-y: 10px; drop-shadow-color: #00000033;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 6px; spacing: 2px;
                    Rectangle { height: 22px; HorizontalLayout { padding-left: 8px; alignment: start; Text { text: @tr("SORT BY"); color: Tokens.text-sec; font-size: 9px; font-weight: 700; letter-spacing: 1.2px; vertical-alignment: center; } } }
                    SortOpt { label: @tr("Name"); active: (root.sort-pane == "local" ? root.local-sort-key : root.remote-sort-key) == "name"; triggered => { root.apply-sort-field("name"); root.sort-open = false; } }
                    SortOpt { label: @tr("Size"); active: (root.sort-pane == "local" ? root.local-sort-key : root.remote-sort-key) == "size"; triggered => { root.apply-sort-field("size"); root.sort-open = false; } }
                    SortOpt { label: @tr("Date"); active: (root.sort-pane == "local" ? root.local-sort-key : root.remote-sort-key) == "date"; triggered => { root.apply-sort-field("date"); root.sort-open = false; } }
                    Rectangle { height: 1px; background: Tokens.border; }
                    SortDirOpt {
                        asc: (root.sort-pane == "local" ? root.local-sort-dir : root.remote-sort-dir) == "asc";
                        label: (root.sort-pane == "local" ? root.local-sort-dir : root.remote-sort-dir) == "asc" ? (@tr("Ascending")) : (@tr("Descending"));
                        triggered => { root.toggle-sort-dir(); }
                    }
                }
            }
        }

        // ── remote edit conflict: bounded internal diff plus explicit safe resolution ──
        if root.edit-conflict-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 720px; height: 550px; background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: Tokens.warning;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 12px;
                    Text { text: @tr("Remote edit conflict"); color: Tokens.warning; font-size: 16px; font-weight: 700; }
                    Text { text: root.edit-conflict-name; color: Tokens.text; font-size: 14px; font-weight: 700; overflow: elide; }
                    Text { text: @tr("The server file changed while you were editing. Neither version has been overwritten."); color: Tokens.text-sec; font-size: 12px; wrap: word-wrap; }
                    Text { text: root.localize-runtime(root.edit-conflict-summary, I18n.locale); color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; wrap: word-wrap; }
                    Rectangle { vertical-stretch: 1; background: Tokens.field-bg; border-radius: 8px; border-width: 1px; border-color: Tokens.border-strong; clip: true;
                        ScrollView { width: parent.width; height: parent.height;
                            Text { width: parent.width - 24px; text: root.edit-conflict-preview; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 10px; wrap: word-wrap; }
                        }
                    }
                    Text { text: (@tr("Local edit: ")) + root.edit-conflict-local-path; color: Tokens.text-ter; font-family: "JetBrains Mono"; font-size: 9px; overflow: elide; }
                    if root.edit-conflict-busy : Text { text: @tr("Rechecking the server…"); color: Tokens.accent; font-size: 11px; horizontal-alignment: right; }
                    if !root.edit-conflict-busy : HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: @tr("Overwrite after recheck"); text-color: Tokens.danger-text; clicked => { root.resolve-editor-conflict(2); } }
                        GhostButton { text: @tr("Upload as Copy"); clicked => { root.resolve-editor-conflict(1); } }
                        PrimaryButton { text: @tr("Keep Local"); clicked => { root.resolve-editor-conflict(0); } }
                    }
                }
            }
        }

        // ── overwrite conflict dialog (Overwrite / Cancel / Save as new) — centered via absolute x/y ──
        if root.overwrite-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } } // modal — force a choice (no backdrop close)
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 420px; height: 242px; background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 14px;
                    Text { text: I18n.overwrite-title; color: Tokens.text; font-size: 15px; font-weight: 700; }
                    Text { text: root.overwrite-name; color: Tokens.accent; font-size: 14px; font-weight: 700; overflow: elide; }
                    Text { text: I18n.overwrite-msg; color: Tokens.text-sec; font-size: 12px; wrap: word-wrap; }
                    HorizontalLayout { height: 20px; spacing: 8px; alignment: start;
                        SelectAllBox { checked: root.overwrite-apply-all; accessible-name: @tr("Apply this decision to all conflicts"); toggled => { root.overwrite-apply-all = !root.overwrite-apply-all; } }
                        Text { text: @tr("Apply this decision to remaining conflicts in this queue"); color: Tokens.text-sec; font-size: 10px; vertical-alignment: center; }
                    }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: I18n.cancel-cap; clicked => { root.resolve-overwrite(0); } }
                        GhostButton { text: I18n.save-new-cap; clicked => { root.resolve-overwrite(2); } }
                        PrimaryButton { text: I18n.overwrite-cap; clicked => { root.resolve-overwrite(1); } }
                    }
                }
            }
        }

        // ── sync passphrase dialog (set on first enable / enter to unlock a pulled vault) ──
        if root.passphrase-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } } // modal — force a choice
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 420px; height: (root.passphrase-mode == "set" || root.passphrase-mode == "backup_export") ? 300px : 240px;
                background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 12px;
                    Text {
                        text: root.passphrase-mode == "set" ? I18n.passphrase-set-title : (root.passphrase-mode == "backup_export" ? (@tr("Encrypt Settings Export")) : (root.passphrase-mode == "backup_import" ? (@tr("Decrypt Settings Import")) : I18n.passphrase-enter-title));
                        color: Tokens.text; font-size: 15px; font-weight: 700;
                    }
                    Text {
                        text: root.passphrase-mode == "set" ? I18n.passphrase-set-msg : (root.passphrase-mode == "backup_export" ? (@tr("Set a separate passphrase for this file. The export contains no server passwords or vault keys.")) : (root.passphrase-mode == "backup_import" ? (@tr("Enter the passphrase used when the settings were exported.")) : I18n.passphrase-enter-msg));
                        color: Tokens.text-sec; font-size: 12px; wrap: word-wrap;
                    }
                    VerticalLayout { spacing: 6px;
                        Text { text: I18n.encryption-entry-label; color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                        Field {
                            text <=> root.passphrase-value;
                            placeholder: @tr("passphrase");
                            accessible-name: I18n.encryption-entry-label;
                            input-type: password;
                        }
                    }
                    if root.passphrase-mode == "set" || root.passphrase-mode == "backup_export" : VerticalLayout { spacing: 6px;
                        Text { text: I18n.encryption-confirm-label; color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                        Field {
                            text <=> root.passphrase-confirm;
                            placeholder: @tr("passphrase");
                            accessible-name: I18n.encryption-confirm-label;
                            input-type: password;
                        }
                    }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton {
                            text: I18n.cancel-cap;
                            clicked => { root.passphrase-value = ""; root.passphrase-confirm = ""; root.resolve-passphrase("", ""); }
                        }
                        PrimaryButton {
                            text: root.passphrase-mode == "set" ? I18n.passphrase-ok-cap : (root.passphrase-mode == "backup_export" ? (@tr("Export")) : (root.passphrase-mode == "backup_import" ? (@tr("Import")) : I18n.passphrase-unlock-cap));
                            clicked => { root.resolve-passphrase(root.passphrase-value, root.passphrase-confirm); }
                        }
                    }
                }
            }
        }

        // ── explicit recovery of legacy credentials pulled from iCloud ──
        if root.credential-recovery-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 470px; height: root.credential-recovery-ambiguous > 0 ? 340px : 312px;
                background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 24px; spacing: 13px;
                    Rectangle {
                        width: 42px; height: 42px; border-radius: 21px; background: Tokens.accent-soft;
                        Icon { kind: "shield"; fg: Tokens.accent; width: 21px; height: 21px; x: 10px; y: 10px; }
                    }
                    Text { text: @tr("Recover synced passwords?"); color: Tokens.text; font-size: 16px; font-weight: 700; }
                    Text {
                        text: @tr("{n} saved password can be recovered" | "{n} saved passwords can be recovered" % root.credential-recovery-count);
                        color: Tokens.accent-text; font-size: 12px; font-weight: 700;
                    }
                    Text {
                        text: @tr("The encrypted vault uses an older credential format. Continue only if you recognize and trust the server profiles downloaded from iCloud.");
                        color: Tokens.text-sec; font-size: 12px; wrap: word-wrap;
                    }
                    Text {
                        text: @tr("Recovery creates endpoint-bound records inside the encrypted vault. Password values are never displayed or sent to a server during recovery.");
                        color: Tokens.text-ter; font-size: 10px; wrap: word-wrap;
                    }
                    if root.credential-recovery-ambiguous > 0 : Text {
                        text: @tr("{n} ambiguous password requires manual re-entry" | "{n} ambiguous passwords require manual re-entry" % root.credential-recovery-ambiguous);
                        color: Tokens.warning; font-size: 10px; wrap: word-wrap;
                    }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: @tr("Not Now"); clicked => { root.resolve-credential-recovery(false); } }
                        PrimaryButton { text: @tr("Trust & Recover"); clicked => { root.resolve-credential-recovery(true); } }
                    }
                }
            }
        }

        // ── SFTP keyboard-interactive / 2FA challenge ──
        if root.ssh-auth-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 480px; height: 230px + root.ssh-auth-prompt-count * 62px;
                background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 10px;
                    Text { text: @tr("SFTP Authentication / 2FA"); color: Tokens.text; font-size: 15px; font-weight: 700; }
                    Text { text: root.ssh-auth-endpoint; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; overflow: elide; }
                    if root.ssh-auth-title != "" : Text { text: root.ssh-auth-title; color: Tokens.text; font-size: 12px; font-weight: 600; wrap: word-wrap; }
                    if root.ssh-auth-instructions != "" : Text { text: root.ssh-auth-instructions; color: Tokens.text-sec; font-size: 11px; wrap: word-wrap; }
                    if root.ssh-auth-prompt-count > 0 : VerticalLayout { spacing: 5px;
                        Text { text: root.ssh-auth-prompt-0 == "" ? (@tr("RESPONSE 1")) : root.ssh-auth-prompt-0; color: Tokens.text-ter; font-size: 9px; font-weight: 700; }
                        Field { text <=> root.ssh-auth-response-0; accessible-name: root.ssh-auth-prompt-0; input-type: root.ssh-auth-echo-0 ? text : password; }
                    }
                    if root.ssh-auth-prompt-count > 1 : VerticalLayout { spacing: 5px;
                        Text { text: root.ssh-auth-prompt-1 == "" ? (@tr("RESPONSE 2")) : root.ssh-auth-prompt-1; color: Tokens.text-ter; font-size: 9px; font-weight: 700; }
                        Field { text <=> root.ssh-auth-response-1; accessible-name: root.ssh-auth-prompt-1; input-type: root.ssh-auth-echo-1 ? text : password; }
                    }
                    if root.ssh-auth-prompt-count > 2 : VerticalLayout { spacing: 5px;
                        Text { text: root.ssh-auth-prompt-2 == "" ? (@tr("RESPONSE 3")) : root.ssh-auth-prompt-2; color: Tokens.text-ter; font-size: 9px; font-weight: 700; }
                        Field { text <=> root.ssh-auth-response-2; accessible-name: root.ssh-auth-prompt-2; input-type: root.ssh-auth-echo-2 ? text : password; }
                    }
                    if root.ssh-auth-prompt-count > 3 : VerticalLayout { spacing: 5px;
                        Text { text: root.ssh-auth-prompt-3 == "" ? (@tr("RESPONSE 4")) : root.ssh-auth-prompt-3; color: Tokens.text-ter; font-size: 9px; font-weight: 700; }
                        Field { text <=> root.ssh-auth-response-3; accessible-name: root.ssh-auth-prompt-3; input-type: root.ssh-auth-echo-3 ? text : password; }
                    }
                    Rectangle { vertical-stretch: 1; }
                    Text { text: @tr("Responses are never saved or logged."); color: Tokens.text-ter; font-size: 10px; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: I18n.cancel-cap; clicked => { root.resolve-keyboard-interactive(false); } }
                        PrimaryButton { text: @tr("Respond"); clicked => { root.resolve-keyboard-interactive(true); } }
                    }
                }
            }
        }

        // ── FTPS certificate pinning confirmation ──
        if root.tls-cert-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 520px; height: 360px;
                background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: root.tls-cert-previous == "" ? Tokens.border-strong : Tokens.danger;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 12px;
                    Text { text: root.tls-cert-previous == "" ? (@tr("Verify FTPS certificate")) : (@tr("FTPS certificate changed")); color: root.tls-cert-previous == "" ? Tokens.text : Tokens.danger-text; font-size: 15px; font-weight: 700; }
                    Text {
                        text: root.tls-cert-previous == ""
                            ? (@tr("Normal system verification rejected this certificate. Compare the fingerprint with your hosting panel or administrator. Your password has not been sent."))
                            : (@tr("The fingerprint differs from the saved pin. This may be a certificate renewal or an attack. Do not continue without independent verification."));
                        color: Tokens.text-sec; font-size: 12px; wrap: word-wrap;
                    }
                    VerticalLayout { spacing: 4px;
                        Text { text: @tr("SERVER"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                        Text { text: root.tls-cert-endpoint; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 11px; overflow: elide; }
                    }
                    if root.tls-cert-previous != "" : VerticalLayout { spacing: 4px;
                        Text { text: @tr("PREVIOUS FINGERPRINT"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                        Text { text: root.tls-cert-previous; color: Tokens.danger-text; font-family: "JetBrains Mono"; font-size: 9px; wrap: word-wrap; }
                    }
                    VerticalLayout { spacing: 4px;
                        Text { text: @tr("NEW SHA-256 FINGERPRINT"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                        Text { text: root.tls-cert-fingerprint; color: Tokens.accent-text; font-family: "JetBrains Mono"; font-size: 9px; wrap: word-wrap; }
                    }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: I18n.cancel-cap; clicked => { root.resolve-tls-certificate(0); } }
                        GhostButton { text: @tr("Trust Once"); clicked => { root.resolve-tls-certificate(1); } }
                        PrimaryButton { text: @tr("Pin & Save"); clicked => { root.resolve-tls-certificate(2); } }
                    }
                }
            }
        }

        // ── SFTP first-contact host-key confirmation ──
        if root.host-key-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } } // modal — trust decisions must be explicit
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 460px; height: 290px;
                background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 12px;
                    Text { text: @tr("Verify SFTP host key"); color: Tokens.text; font-size: 15px; font-weight: 700; }
                    Text {
                        text: @tr("The server is new to gmacFTP. Confirm this fingerprint with the server administrator or another trusted channel before trusting it. Your password has not been sent.");
                        color: Tokens.text-sec; font-size: 12px; wrap: word-wrap;
                    }
                    VerticalLayout { spacing: 4px;
                        Text { text: @tr("SERVER"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                        Text { text: root.host-key-endpoint; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 11px; overflow: elide; }
                    }
                    VerticalLayout { spacing: 4px;
                        Text { text: @tr("SHA-256 FINGERPRINT"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                        Text { text: root.host-key-fingerprint; color: Tokens.accent; font-family: "JetBrains Mono"; font-size: 10px; wrap: word-wrap; }
                    }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: I18n.cancel-cap; clicked => { root.resolve-host-key-trust(false); } }
                        PrimaryButton { text: @tr("Trust and connect"); clicked => { root.resolve-host-key-trust(true); } }
                    }
                }
            }
        }

        // ── drag badge (follows the cursor while dragging a file across panes) ──
        if root.drag-active : Rectangle {
            x: root.drag-x + 14px; y: root.drag-y + 4px;
            height: 26px; width: 220px;
            background: root.favorite-remove-target ? Tokens.danger : (root.drag-source == "local" || root.favorite-dragging || root.saved-dragging ? Tokens.accent : Tokens.brand);
            border-radius: 6px;
            border-width: 1px; border-color: #FFFFFF66;
            drop-shadow-blur: 14px; drop-shadow-offset-y: 3px; drop-shadow-color: #00000066;
            HorizontalLayout { padding-left: 10px; padding-right: 10px; alignment: start;
                Text {
                    text: root.favorite-remove-target ? @tr("remove from Favorites  {}", root.drag-name) : (root.saved-dragging ? @tr("move server  {}", root.drag-name) : (root.favorite-dragging ? @tr("move favorite  {}", root.drag-name) : (root.drag-over-favorites ? @tr("+ favorite  {}", root.drag-name) : (root.drag-source == "local" ? @tr("upload >  {}", root.drag-name) : @tr("< download  {}", root.drag-name)))));
                    color: #FFFFFF; font-size: 11px; font-weight: 600; vertical-alignment: center; overflow: elide;
                }
            }
        }

        // ── transfer panel ──
        if root.transfer-panel-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { root.transfer-panel-open = false; } }
            panel := Rectangle {
                x: (root.width - self.width) / 2;
                y: 36px;
                width: 640px;
                height: 610px;
                background: Tokens.card;
                border-radius: 14px;
                border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                clip: true;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 0px; spacing: 0px;
                    Rectangle {
                        height: 60px; background: transparent;
                        Rectangle {
                            x: 18px; y: 15px; width: 30px; height: 30px; border-radius: 6px; background: Tokens.accent-soft;
                            Icon { kind: "transfer"; fg: Tokens.accent; width: 17px; height: 17px; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                        }
                        Text { x: 58px; y: 0px; width: 82px; height: parent.height; text: @tr("Transfers"); color: Tokens.text; font-size: 15px; font-weight: 700; vertical-alignment: center; horizontal-alignment: left; }
                        if root.transfer-jobs.length > 0 : Rectangle {
                            x: 132px; y: 19px; height: 22px; width: hdr-badge-text.preferred-width + 16px;
                            border-radius: 11px; background: Tokens.accent;
                            hdr-badge-text := Text {
                                x: 0px; y: 0px; width: parent.width; height: parent.height;
                                text: root.transfer-done-count + " / " + root.transfer-jobs.length;
                                color: #FFFFFF; font-size: 10px; font-weight: 700; vertical-alignment: center; horizontal-alignment: center;
                            }
                        }
                        ChoiceSegment { x: 310px; y: 17px; width: 34px; height: 26px; text: @tr("All"); selected: root.transfer-view == "all"; chosen => { root.transfer-view = "all"; } }
                        ChoiceSegment { x: 350px; y: 17px; width: 55px; height: 26px; text: @tr("Queue"); selected: root.transfer-view == "queue"; chosen => { root.transfer-view = "queue"; } }
                        Text { x: 414px; y: 0px; width: 65px; height: parent.height; text: @tr("Export"); color: Tokens.text-sec; font-size: 10px; font-weight: 500; vertical-alignment: center; horizontal-alignment: center; }
                        KeyboardActionArea { x: 410px; y: 17px; width: 73px; height: 26px; accessible-name: @tr("Export transfer report"); clicked => { root.export-transfer-report(); } }
                        Icon { kind: "trash"; fg: Tokens.text-sec; width: 13px; height: 13px; x: 494px; y: 23px; }
                        Text { x: 511px; y: 0px; width: 70px; height: parent.height; text: @tr("Clear"); color: Tokens.text-sec; font-size: 10px; font-weight: 500; vertical-alignment: center; horizontal-alignment: left; }
                        KeyboardActionArea { x: 488px; y: 17px; width: 96px; height: 26px; accessible-name: @tr("Clear finished transfers"); clicked => { root.clear-finished-transfers(); } }
                        IconButton { icon: "x"; accessible-name: @tr("Close transfer queue"); x: 594px; y: 15px; clicked => { root.transfer-panel-open = false; } }
                        Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                    }
                    ScrollView { vertical-stretch: 1; VerticalLayout { padding-left: 10px; padding-right: 10px; padding-top: 8px; padding-bottom: 8px; spacing: 8px;
                        if root.transfer-jobs.length == 0 : Rectangle {
                            height: 474px;
                            Text { text: @tr("No transfers yet.\nDrag between panes or use the center arrows."); color: Tokens.text-ter; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; wrap: word-wrap; }
                        }
                        for j in root.transfer-jobs : transfer_row := Rectangle {
                            property <bool> included: root.transfer-view == "all" || j.state == "active" || j.state == "queued" || j.state == "paused";
                            visible: self.included;
                            width: 620px; height: self.included ? 116px : 0px; border-radius: 8px; background: Tokens.bg;
                            border-width: 1px; border-color: Tokens.border;
                            Rectangle {
                                x: 12px; y: 11px; width: 596px; height: 32px; background: transparent;
                                Rectangle {
                                    x: 0px; y: 0px; width: 32px; height: 32px; border-radius: 8px;
                                    background: j.direction == "download" ? Tokens.accent-soft : Tokens.brand-soft;
                                    Icon { kind: j.direction == "download" ? "arrow-down-line" : "arrow-up-line"; width: 16px; height: 16px; fg: j.direction == "download" ? Tokens.accent : Tokens.brand; x: 8px; y: 8px; }
                                }
                                Rectangle {
                                    x: 43px; y: 0px; width: 396px; height: 34px; background: transparent;
                                    Text { x: 0px; y: 0px; width: 396px; height: 18px; text: j.name; color: Tokens.text; font-size: 13px; font-weight: 600; overflow: elide; vertical-alignment: center; horizontal-alignment: left; }
                                    Text { x: 0px; y: 18px; width: 396px; height: 16px; text: j.route; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; overflow: elide; vertical-alignment: center; horizontal-alignment: left; }
                                }
                                Rectangle {
                                    x: 445px; y: 9px; width: 86px; height: 14px; background: transparent;
                                    Rectangle { x: 0px; y: 4px; width: 6px; height: 6px; border-radius: 3px; background: j.state == "done" ? Tokens.success : (j.state == "failed" ? Tokens.danger : ((j.state == "cancelled" || j.state == "recovered" || j.state == "paused") ? Tokens.warning : (j.state == "active" ? Tokens.accent : Tokens.text-ter))); }
                                    Text {
                                        x: 11px; y: 0px; height: 14px; width: 75px;
                                        text: j.state == "active" ? @tr("Active") : (j.state == "done" ? @tr("Done") : (j.state == "failed" ? @tr("Failed") : (j.state == "cancelled" ? @tr("Stopped") : (j.state == "recovered" ? @tr("Recovered") : (j.state == "paused" ? @tr("Paused") : @tr("Queued"))))));
                                        color: j.state == "done" ? Tokens.success-text : (j.state == "failed" ? Tokens.danger-text : ((j.state == "cancelled" || j.state == "recovered" || j.state == "paused") ? Tokens.warning : (j.state == "active" ? Tokens.accent-text : Tokens.text-sec)));
                                        font-size: 10px; font-weight: 600; vertical-alignment: center; horizontal-alignment: left; overflow: elide;
                                    }
                                }
                                if j.state == "failed" || j.state == "cancelled" || j.state == "recovered" : Rectangle {
                                    x: 542px; y: 4px; width: 24px; height: 24px; border-radius: 4px; background: discard_action.has-hover || discard_action.has-focus ? Tokens.row-hover : transparent;
                                    Icon { kind: "x"; width: 14px; height: 14px; fg: Tokens.text-ter; x: 5px; y: 5px; }
                                    discard_action := KeyboardActionArea { accessible-name: @tr("Dismiss transfer {}", j.name); clicked => { root.dismiss-transfer(j.id); } }
                                }
                                Rectangle {
                                    x: 572px; y: 4px; width: 24px; height: 24px; border-radius: 4px; background: transfer_action.has-hover || transfer_action.has-focus ? Tokens.row-hover : transparent;
                                    Icon { kind: (j.state == "failed" || j.state == "cancelled" || j.state == "recovered") ? "refresh" : (j.state == "paused" ? "arrow-down-line" : (j.state == "done" ? "check" : "x")); width: 15px; height: 15px; fg: (j.state == "failed" || j.state == "cancelled" || j.state == "recovered" || j.state == "paused") ? Tokens.accent : Tokens.text-ter; x: 4.5px; y: 4.5px; }
                                    transfer_action := KeyboardActionArea { accessible-name: (j.state == "failed" || j.state == "cancelled" || j.state == "recovered") ? @tr("Retry transfer {}", j.name) : (j.state == "paused" ? @tr("Resume transfer {}", j.name) : ((j.state == "active" || j.state == "queued") ? @tr("Cancel transfer {}", j.name) : @tr("Dismiss transfer {}", j.name))); clicked => {
                                        if (j.state == "failed" || j.state == "cancelled" || j.state == "recovered") { root.retry-transfer(j.id); }
                                        else if (j.state == "paused") { root.pause-transfer(j.id, false); }
                                        else if (j.state == "active" || j.state == "queued") { root.cancel-transfer(j.id); }
                                        else { root.dismiss-transfer(j.id); }
                                    } }
                                }
                            }
                            Rectangle {
                                x: 12px; y: 52px; width: 596px; height: 5px; border-radius: 3px; background: Tokens.border;
                                accessible-role: progress-indicator;
                                accessible-label: @tr("Progress for {}", j.name);
                                accessible-value: clamp(j.fraction, 0, 1);
                                accessible-value-minimum: 0;
                                accessible-value-maximum: 1;
                                Rectangle {
                                    x: 0px; y: 0px; height: 5px; width: parent.width * clamp(j.fraction, 0, 1);
                                    border-radius: 3px; background: j.state == "failed" ? Tokens.danger : ((j.state == "cancelled" || j.state == "recovered") ? Tokens.warning : (j.state == "done" ? Tokens.success : Tokens.accent));
                                }
                            }
                            Rectangle {
                                x: 12px; y: 66px; width: 596px; height: 13px; background: transparent;
                                Text { x: 0px; y: -1px; width: 472px; height: 15px; text: j.progress-text != "" ? j.progress-text : Fmt.human-size(j.done) + " / " + Fmt.human-size(j.total); color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; font-weight: 400; vertical-alignment: center; horizontal-alignment: left; }
                                Text { x: 482px; y: -1px; width: 114px; height: 15px; text: root.localize-runtime(j.message, I18n.locale); color: j.state == "failed" ? Tokens.danger-text : Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; font-weight: 400; vertical-alignment: center; horizontal-alignment: right; overflow: elide; }
                            }
                            if j.state == "queued" || j.state == "paused" : Rectangle {
                                x: 12px; y: 86px; width: 596px; height: 22px; background: transparent;
                                Rectangle {
                                    x: 0px; y: 0px; width: 88px; height: 22px; border-radius: 5px;
                                    background: priority_action.has-hover ? Tokens.row-hover : Tokens.surface-raised;
                                    border-width: 1px; border-color: priority_action.has-focus || j.priority == "high" ? Tokens.accent : Tokens.border;
                                    Text { text: (@tr("PRIORITY ")) + (j.priority == "high" ? (@tr("HIGH")) : (j.priority == "low" ? (@tr("LOW")) : (@tr("NORMAL")))); color: j.priority == "high" ? Tokens.accent-text : Tokens.text-sec; font-size: 8px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                    priority_action := KeyboardActionArea { accessible-name: @tr("Change priority for {}", j.name); clicked => { root.set-transfer-priority(j.id, j.priority == "normal" ? "high" : (j.priority == "high" ? "low" : "normal")); } }
                                }
                                Rectangle { x: 98px; width: 24px; height: 22px; border-radius: 5px; background: move_up_action.has-hover ? Tokens.row-hover : Tokens.surface-raised; border-width: 1px; border-color: move_up_action.has-focus ? Tokens.accent : Tokens.border; Text { text: "↑"; color: Tokens.text-sec; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; } move_up_action := KeyboardActionArea { accessible-name: @tr("Move transfer {} up", j.name); clicked => { root.move-transfer(j.id, -1); } } }
                                Rectangle { x: 128px; width: 24px; height: 22px; border-radius: 5px; background: move_down_action.has-hover ? Tokens.row-hover : Tokens.surface-raised; border-width: 1px; border-color: move_down_action.has-focus ? Tokens.accent : Tokens.border; Text { text: "↓"; color: Tokens.text-sec; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; } move_down_action := KeyboardActionArea { accessible-name: @tr("Move transfer {} down", j.name); clicked => { root.move-transfer(j.id, 1); } } }
                                Rectangle {
                                    x: 162px; width: 86px; height: 22px; border-radius: 5px; background: pause_one_action.has-hover ? Tokens.row-hover : Tokens.surface-raised; border-width: 1px; border-color: pause_one_action.has-focus ? Tokens.accent : Tokens.border;
                                    Text { text: j.state == "paused" ? (@tr("RESUME")) : (@tr("PAUSE")); color: j.state == "paused" ? Tokens.accent-text : Tokens.text-sec; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                    pause_one_action := KeyboardActionArea { accessible-name: j.state == "paused" ? @tr("Resume transfer {}", j.name) : @tr("Pause transfer {}", j.name); clicked => { root.pause-transfer(j.id, j.state != "paused"); } }
                                }
                            }
                        }
                    } }
                    Rectangle {
                        height: 52px; background: transparent;
                        border-width: 1px; border-color: Tokens.border;
                        Icon { kind: "activity"; fg: Tokens.text-ter; x: 18px; y: 18px; }
                        Text {
                            x: 44px; y: 0px; width: 320px; height: parent.height;
                            text: root.localize-runtime(root.transfer-summary, I18n.locale);
                            color: Tokens.text-sec; font-size: 11px; vertical-alignment: center; horizontal-alignment: left;
                        }
                        Text {
                            x: 365px; y: 0px; width: 52px; height: parent.height;
                            text: @tr("Parallel");
                            color: Tokens.text-ter; font-size: 10px; vertical-alignment: center; horizontal-alignment: right;
                        }
                        Rectangle {
                            x: 423px; y: 14px; width: 22px; height: 24px; border-radius: 5px;
                            background: decrease_parallel_action.has-hover ? Tokens.row-hover : Tokens.surface-raised;
                            border-width: 1px; border-color: decrease_parallel_action.has-focus ? Tokens.accent : Tokens.border;
                            Text { text: "-"; color: Tokens.text; font-size: 14px; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                            decrease_parallel_action := KeyboardActionArea { enabled: root.transfer-concurrency > 1; accessible-name: @tr("Decrease parallel transfers"); clicked => { root.set-transfer-concurrency(root.transfer-concurrency - 1); } }
                        }
                        Text {
                            x: 447px; y: 0px; width: 22px; height: parent.height;
                            text: root.transfer-concurrency; color: Tokens.text; font-family: "JetBrains Mono"; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center;
                        }
                        Rectangle {
                            x: 471px; y: 14px; width: 22px; height: 24px; border-radius: 5px;
                            background: increase_parallel_action.has-hover ? Tokens.row-hover : Tokens.surface-raised;
                            border-width: 1px; border-color: increase_parallel_action.has-focus ? Tokens.accent : Tokens.border;
                            Text { text: "+"; color: Tokens.text; font-size: 13px; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                            increase_parallel_action := KeyboardActionArea { enabled: root.transfer-concurrency < 6; accessible-name: @tr("Increase parallel transfers"); clicked => { root.set-transfer-concurrency(root.transfer-concurrency + 1); } }
                        }
                        Rectangle {
                            x: 533px; y: 12px; width: 89px; height: 28px; border-radius: 6px;
                            background: pause_all_action.has-hover ? Tokens.row-hover : Tokens.surface-raised;
                            border-width: 1px; border-color: pause_all_action.has-focus ? Tokens.accent : Tokens.border;
                            Icon { kind: root.transfers-paused ? "arrow-down-line" : "pause"; fg: root.transfers-paused ? Tokens.accent : Tokens.text-sec; width: 14px; height: 14px; x: 11px; y: 7px; }
                            Text { text: root.transfers-paused ? @tr("Resume all") : @tr("Pause all"); color: Tokens.text; font-size: 11px; font-weight: 500; x: 31px; y: 0px; width: 58px; height: parent.height; vertical-alignment: center; horizontal-alignment: left; }
                            pause_all_action := KeyboardActionArea { accessible-name: root.transfers-paused ? @tr("Resume all") : @tr("Pause all"); clicked => { root.transfers-paused = !root.transfers-paused; root.set-transfers-paused(root.transfers-paused); } }
                        }
                    }
                }
            }
        }

        // ── command palette ──
        if root.palette-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { root.palette-open = false; } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: 165px;
                width: 580px; height: 400px;
                    background: Tokens.card; border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                    drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: root.snapshot-mode ? transparent : #00000066;
                    clip: true;
                    TouchArea { clicked => { } }
                    VerticalLayout { padding: 0px; spacing: 0px;
                        Rectangle {
                            height: 52px; background: transparent;
                            Icon { kind: "search"; width: 18px; height: 18px; fg: Tokens.text-ter; x: 18px; y: 17px; }
                            TextInput {
                                x: 48px; y: 0px; width: 473px; height: 52px;
                                text <=> root.palette-query;
                                color: Tokens.text; font-size: 15px; single-line: true;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                                selection-background-color: Tokens.accent;
                                selection-foreground-color: #FFFFFF;
                                accessible-label: @tr("Command palette search");
                                accessible-placeholder-text: @tr("Search servers and actions");
                                edited => { root.filter-palette(root.palette-query); }
                            }
                            Rectangle {
                                x: 533px; y: 16px; width: 29px; height: 20px; border-radius: 4px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                                Text { text: "⌘K"; color: Tokens.text-sec; font-size: 10px; font-weight: 600; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                        }
                        ScrollView { height: 308px; VerticalLayout { padding: 6px; spacing: 2px;
                            Rectangle {
                                height: 28px;
                                Text { x: 12px; y: 0px; height: parent.height; text: @tr("CONNECT"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; vertical-alignment: center; }
                            }
                            for c[i] in root.palette-connections : Rectangle {
                                height: 50px; border-radius: 6px;
                                background: i == 0 || palette_server_action.has-hover || palette_server_action.has-focus ? Tokens.accent-soft : transparent;
                                palette_server_action := KeyboardActionArea { accessible-name: @tr("Connect to {}", c.label); accessible-help: c.sub; clicked => { root.connect-to(c.id); root.palette-open = false; } }
                                Rectangle {
                                    x: 10px; y: 7px; width: 36px; height: 36px; border-radius: 8px;
                                    background: i == 0 || palette_server_action.has-hover ? Tokens.accent : Tokens.surface;
                                    border-width: i == 0 || palette_server_action.has-hover ? 0px : 1px; border-color: Tokens.border;
                                    Icon { kind: "server"; fg: i == 0 || palette_server_action.has-hover ? #FFFFFF : Tokens.text-sec; width: 17px; height: 17px; x: 9.5px; y: 9.5px; }
                                }
                                Text { x: 58px; y: 6px; width: 330px; height: 19px; text: c.label; color: Tokens.text; font-size: 13px; font-weight: 700; overflow: elide; vertical-alignment: center; }
                                Text { x: 58px; y: 27px; width: 360px; height: 18px; text: c.sub + " · " + c.protocol; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; overflow: elide; vertical-alignment: center; }
                                Rectangle {
                                    x: 458px; y: 16px; width: 42px; height: 18px; border-radius: 4px; background: Tokens.accent-soft;
                                    Text { text: c.protocol; color: Tokens.accent; font-size: 9px; font-weight: 800; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                }
                                Icon { kind: "enter"; fg: i == 0 || palette_server_action.has-hover ? Tokens.accent : Tokens.text-sec; width: 14px; height: 14px; x: 518px; y: 18px; }
                            }
                            Rectangle {
                                height: 30px;
                                Text { x: 12px; y: 0px; height: parent.height; text: @tr("ACTIONS"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; vertical-alignment: center; }
                            }
                            Rectangle {
                                height: 42px; border-radius: 6px;
                                KeyboardActionArea { accessible-name: @tr("New connection"); clicked => { root.palette-open = false; root.new-connection(); } }
                                Rectangle {
                                    x: 10px; y: 5px; width: 32px; height: 32px; border-radius: 6px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                                    Icon { kind: "plus"; fg: Tokens.text-sec; width: 16px; height: 16px; x: 8px; y: 8px; }
                                }
                                Text { x: 54px; y: 0px; width: 390px; height: parent.height; text: @tr("New connection"); color: Tokens.text; font-size: 13px; font-weight: 500; vertical-alignment: center; }
                                Rectangle {
                                    x: 522px; y: 11px; width: 30px; height: 20px; border-radius: 4px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                                    Text { text: "⌘N"; color: Tokens.text-sec; font-size: 10px; font-weight: 600; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                            Rectangle {
                                height: 42px; border-radius: 6px;
                                KeyboardActionArea { accessible-name: I18n.import-cap; clicked => { root.import-forklift(); } }
                                Rectangle {
                                    x: 10px; y: 5px; width: 32px; height: 32px; border-radius: 6px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                                    Icon { kind: "download"; fg: Tokens.text-sec; width: 16px; height: 16px; x: 8px; y: 8px; }
                                }
                                Text { x: 54px; y: 0px; width: 390px; height: parent.height; text: I18n.import-cap; color: Tokens.text; font-size: 13px; font-weight: 500; vertical-alignment: center; }
                            }
                            Rectangle {
                                height: 42px; border-radius: 6px;
                                KeyboardActionArea { accessible-name: @tr("Toggle theme"); clicked => { root.toggle-theme(); } }
                                Rectangle {
                                    x: 10px; y: 5px; width: 32px; height: 32px; border-radius: 6px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                                    Icon { kind: "theme"; fg: Tokens.text-sec; width: 16px; height: 16px; x: 8px; y: 8px; }
                                }
                                Text { x: 54px; y: 0px; width: 390px; height: parent.height; text: @tr("Toggle theme"); color: Tokens.text; font-size: 13px; font-weight: 500; vertical-alignment: center; }
                                Rectangle {
                                    x: 522px; y: 11px; width: 30px; height: 20px; border-radius: 4px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                                    Text { text: "⌘T"; color: Tokens.text-sec; font-size: 10px; font-weight: 600; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        } }
                        Rectangle {
                            height: 40px; background: transparent; border-width: 1px; border-color: Tokens.border;
                            Rectangle { x: 16px; y: 10px; width: 18px; height: 20px; border-radius: 4px; background: Tokens.surface-raised; border-width: 1px; border-color: Tokens.border; Text { text: "↑"; color: Tokens.text-sec; font-size: 10px; font-weight: 600; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; } }
                            Rectangle { x: 34px; y: 10px; width: 18px; height: 20px; border-radius: 4px; background: Tokens.surface-raised; border-width: 1px; border-color: Tokens.border; Text { text: "↓"; color: Tokens.text-sec; font-size: 10px; font-weight: 600; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; } }
                            Text { x: 58px; y: 0px; height: parent.height; text: @tr("Navigate"); color: Tokens.text-ter; font-size: 11px; vertical-alignment: center; }
                            Rectangle { x: 132px; y: 10px; width: 22px; height: 20px; border-radius: 4px; background: Tokens.surface-raised; border-width: 1px; border-color: Tokens.border; Text { text: "↵"; color: Tokens.text-sec; font-size: 10px; font-weight: 600; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; } }
                            Text { x: 160px; y: 0px; height: parent.height; text: @tr("Select"); color: Tokens.text-ter; font-size: 11px; vertical-alignment: center; }
                            Rectangle { x: 210px; y: 10px; width: 28px; height: 20px; border-radius: 4px; background: Tokens.surface-raised; border-width: 1px; border-color: Tokens.border; Text { text: "esc"; color: Tokens.text-sec; font-size: 10px; font-weight: 600; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; } }
                            Text { x: 244px; y: 0px; height: parent.height; text: @tr("Close"); color: Tokens.text-ter; font-size: 11px; vertical-alignment: center; }
                            BrandWordmark { x: 526px; y: 4px; height: 20px; wordmark-size: 11px; wordmark-width: 54px; }
                        }
                    }
                }
        }

        // ── connection manager ──
        if root.manager-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { root.manager-open = false; } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: 36px;
                width: 720px; height: 470px; background: Tokens.card;
                    border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                    drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: #00000066;
                    clip: true;
                    TouchArea { clicked => { } }
                    VerticalLayout { padding: 0px; spacing: 0px;
                        // header bar — distinct surface + a hairline separator so it doesn't blend into the list
                        Rectangle {
                            height: 56px; background: Tokens.surface;
                            Rectangle {
                                x: 18px; y: 13px; width: 30px; height: 30px; border-radius: 6px; background: Tokens.accent-soft;
                                Icon { kind: "server"; fg: Tokens.accent; width: 17px; height: 17px; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                            }
                            Text { x: 58px; y: 0px; width: 120px; height: parent.height; text: @tr("Connections"); color: Tokens.text; font-size: 15px; font-weight: 700; vertical-alignment: center; horizontal-alignment: left; }
                            LabeledToolButton { x: 497px; y: 13px; width: 72px; icon: "plus"; icon-y-offset: 1px; text: I18n.new-cap; emphasized: true; clicked => { root.new-connection(); } }
                            LabeledToolButton { x: 579px; y: 13px; width: 83px; icon: "download"; text: @tr("Import"); clicked => { root.import-forklift(); } }
                            IconButton { icon: "x"; accessible-name: @tr("Close Connection Manager"); x: 672px; y: 13px; clicked => { root.manager-open = false; } }
                            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                        }
                        Text { text: root.localize-runtime(root.manager-message, I18n.locale); color: Tokens.accent; font-size: 11px; visible: root.manager-message != ""; }
                        ScrollView {
                            VerticalLayout {
                                padding-left: 12px; padding-right: 12px; padding-top: 12px; padding-bottom: 20px; spacing: 4px;
                                for c[i] in root.connections : Rectangle {
                                    width: 696px; height: 52px; border-radius: 8px;
                                    background: mrow.has-hover ? Tokens.row-hover : transparent;
                                    mrow := TouchArea { }
                                    ProtocolBadge { x: 10px; y: 15px; protocol: c.protocol; }
                                    Text { x: 68px; y: 10px; width: 362px; height: 16px; text: c.label; color: Tokens.text; font-size: 13px; font-weight: 600; vertical-alignment: center; horizontal-alignment: left; overflow: elide; }
                                    Text { x: 68px; y: 28px; width: 362px; height: 14px; text: c.sub; color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 10px; vertical-alignment: center; horizontal-alignment: left; overflow: elide; }
                                    ManagerActionButton { x: 442px; y: 12px; width: 88px; icon: "log-in"; text: I18n.connect; text-color: Tokens.accent-text; accent-color: Tokens.accent-text; clicked => { root.connect-to(c.id); root.manager-open = false; } }
                                    ManagerActionButton { x: 542px; y: 12px; width: 59px; icon: "edit"; text: I18n.edit-cap; text-color: Tokens.text-sec; accent-color: Tokens.text-sec; clicked => { root.edit-connection(c.id); } }
                                    ManagerActionButton { x: 613px; y: 12px; width: 73px; icon: "trash"; text: I18n.del-cap; text-color: Tokens.danger; accent-color: Tokens.danger; clicked => { root.delete-connection(c.id); } }
                                }
                            }
                        }
                    }
                }
        }

        // ── native Settings (Command-,) ──
        if root.settings-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 820px; height: 620px; background: Tokens.card;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: root.snapshot-mode ? transparent : #00000066;
                clip: true;
                TouchArea { clicked => { } }
                VerticalLayout { spacing: 0px;
                    Rectangle {
                        height: 54px; background: transparent;
                        Text { x: 22px; width: 500px; height: parent.height; text: @tr("gmacFTP Settings"); color: Tokens.text; font-size: 16px; font-weight: 700; vertical-alignment: center; }
                        IconButton { icon: "x"; accessible-name: @tr("Close Settings"); x: parent.width - 48px; y: 12px; clicked => { root.settings-open = false; } }
                        Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                    }
                    HorizontalLayout { spacing: 0px; vertical-stretch: 1;
                        Rectangle {
                            width: 178px; background: Tokens.bg-alt;
                            border-width: 1px; border-color: Tokens.border;
                            VerticalLayout { padding: 14px; spacing: 5px;
                                GhostButton { text: @tr("General"); checkable: true; active: root.settings-section == "general"; clicked => { root.settings-section = "general"; } }
                                GhostButton { text: @tr("Transfers"); checkable: true; active: root.settings-section == "transfers"; clicked => { root.settings-section = "transfers"; } }
                                GhostButton { text: @tr("Connections"); checkable: true; active: root.settings-section == "connections"; clicked => { root.settings-section = "connections"; } }
                                GhostButton { text: @tr("Sync"); checkable: true; active: root.settings-section == "sync"; clicked => { root.settings-section = "sync"; } }
                                GhostButton { text: @tr("Editors"); checkable: true; active: root.settings-section == "editors"; clicked => { root.settings-section = "editors"; } }
                                GhostButton { text: @tr("Privacy & Storage"); checkable: true; active: root.settings-section == "privacy"; clicked => { root.settings-section = "privacy"; } }
                                Rectangle { vertical-stretch: 1; }
                                Text { text: "gmacFTP " + root.app-version; color: Tokens.text-ter; font-size: 10px; horizontal-alignment: center; }
                            }
                        }
                        Rectangle {
                            horizontal-stretch: 1; background: Tokens.card;
                            if root.settings-section == "general" : ScrollView {
                              VerticalLayout {
                                padding-left: 24px; padding-right: 24px; padding-top: 24px; padding-bottom: 24px; spacing: 15px;
                                Text { text: @tr("GENERAL"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; letter-spacing: 1px; }
                                Text { text: @tr("Appearance"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for theme[i] in 3 : ChoiceSegment { text: i == 0 ? (@tr("SYSTEM")) : (i == 1 ? (@tr("LIGHT")) : (@tr("DARK"))); selected: root.settings-theme == (i == 0 ? "system" : (i == 1 ? "light" : "dark")); chosen => { root.settings-theme = i == 0 ? "system" : (i == 1 ? "light" : "dark"); } }
                                    }
                                }
                                Text { text: @tr("Language"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for language[i] in 3 : ChoiceSegment { text: i == 0 ? @tr("SYSTEM") : (i == 1 ? @tr("ENGLISH") : @tr("POLISH")); selected: root.settings-locale == (i == 0 ? "system" : (i == 1 ? "en" : "pl")); chosen => { root.settings-locale = i == 0 ? "system" : (i == 1 ? "en" : "pl"); } }
                                    }
                                }
                                SettingsToggleRow { title: @tr("Show hidden files"); checked <=> root.settings-show-hidden; }
                                SettingsToggleRow { title: @tr("Show owner, group and permission columns"); detail: @tr("Availability depends on metadata exposed by the FTP/SFTP server"); checked <=> root.settings-show-advanced-columns; }
                                SettingsToggleRow { title: @tr("Confirm deletions"); detail: @tr("Applies to local Trash and remote quarantine; permanent deletion always requires confirmation"); checked <=> root.settings-confirm-deletes; }
                                SettingsToggleRow { title: @tr("Use remote quarantine"); detail: @tr("Moves items to a hidden .gmacftp-trash folder; failure never falls back to permanent deletion"); checked <=> root.settings-remote-quarantine-deletes; }
                                SettingsToggleRow { title: @tr("Restore workspace"); detail: @tr("Pane paths and layout after relaunch"); checked <=> root.settings-restore-workspace; }
                                SettingsToggleRow { title: @tr("Open Connection Manager on launch"); checked <=> root.settings-open-manager-on-launch; }
                                SettingsToggleRow {
                                    title: @tr("Check for updates automatically");
                                    detail: root.settings-updates-supported
                                        ? (@tr("Opt-in: checks GitHub once after launch, sends no telemetry, and asks before every download"))
                                        : (@tr("Available only in the public gmacFTP build"));
                                    interactive: root.settings-updates-supported;
                                    checked <=> root.settings-check-updates-automatically;
                                }
                                VerticalLayout { spacing: 6px; Text { text: @tr("LEFT PANE PATH"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-left-path; placeholder: "~/Documents"; accessible-name: @tr("LEFT PANE PATH"); } }
                                VerticalLayout { spacing: 6px; Text { text: @tr("RIGHT PANE PATH"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-right-path; placeholder: "~/Downloads"; accessible-name: @tr("RIGHT PANE PATH"); } }
                                HorizontalLayout { spacing: 12px;
                                    VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("PANE SPLIT (PX)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-pane-split; placeholder: "440"; accessible-name: @tr("PANE SPLIT (PX)"); } }
                                    VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("WINDOW WIDTH"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-window-width; placeholder: "1180"; accessible-name: @tr("WINDOW WIDTH"); } }
                                    VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("WINDOW HEIGHT"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-window-height; placeholder: "740"; accessible-name: @tr("WINDOW HEIGHT"); } }
                                }
                                Text { text: @tr("Window position is saved after a clean exit and restored only when it remains visible on a connected display."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                              }
                            }
                            if root.settings-section == "transfers" : ScrollView {
                              VerticalLayout {
                                padding-left: 24px; padding-right: 24px; padding-top: 24px; padding-bottom: 24px; spacing: 15px;
                                Text { text: @tr("TRANSFERS"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; letter-spacing: 1px; }
                                Text { text: @tr("Total concurrent transfers"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for lane[i] in 6 : ChoiceSegment { text: "" + (i + 1); text-size: 11px; selected: root.settings-transfer-concurrency == i + 1; chosen => { root.settings-transfer-concurrency = i + 1; } }
                                    }
                                }
                                Text { text: @tr("Default per server"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for server-lane[i] in 4 : ChoiceSegment { text: "" + (i + 1); text-size: 11px; selected: root.settings-server-concurrency == i + 1; chosen => { root.settings-server-concurrency = i + 1; } }
                                    }
                                }
                                HorizontalLayout { spacing: 12px;
                                    VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("RETRIES"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-retry-count; placeholder: "3"; accessible-name: @tr("RETRIES"); } }
                                    VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("BACKOFF (MS)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-retry-backoff; placeholder: "1000"; accessible-name: @tr("BACKOFF (MS)"); } }
                                    VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("LIMIT (KiB/S)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-bandwidth-limit; placeholder: "0"; accessible-name: @tr("LIMIT (KiB/S)"); } }
                                }
                                Text { text: @tr("0 = unlimited; the limit is shared by all active servers."); color: Tokens.text-sec; font-size: 10px; }
                                Text { text: @tr("When a file already exists"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for conflict[i] in 4 : ChoiceSegment { text: i == 0 ? (@tr("ASK")) : (i == 1 ? (@tr("OVERWRITE")) : (i == 2 ? (@tr("KEEP BOTH")) : (@tr("SKIP")))); text-size: 9px; selected: root.settings-existing-file-policy == (i == 0 ? "ask" : (i == 1 ? "overwrite" : (i == 2 ? "keep_both" : "skip"))); chosen => { root.settings-existing-file-policy = i == 0 ? "ask" : (i == 1 ? "overwrite" : (i == 2 ? "keep_both" : "skip")); } }
                                    }
                                }
                                Text { text: @tr("One file fails in a batch"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for batch-policy[i] in 3 : ChoiceSegment { text: i == 0 ? (@tr("ASK")) : (i == 1 ? (@tr("SKIP & CONTINUE")) : (@tr("STOP BATCH"))); text-size: 9px; selected: root.settings-batch-error-policy == (i == 0 ? "ask" : (i == 1 ? "skip" : "stop")); chosen => { root.settings-batch-error-policy = i == 0 ? "ask" : (i == 1 ? "skip" : "stop"); } }
                                    }
                                }
                                Text { text: @tr("Queue recovered after a crash"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for recovery[i] in 3 : ChoiceSegment { text: i == 0 ? (@tr("ASK")) : (i == 1 ? (@tr("RESUME")) : (@tr("DISCARD"))); text-size: 9px; selected: root.settings-queue-recovery-policy == (i == 0 ? "ask" : (i == 1 ? "resume" : "discard")); chosen => { root.settings-queue-recovery-policy = i == 0 ? "ask" : (i == 1 ? "resume" : "discard"); } }
                                    }
                                }
                                SettingsToggleRow { title: @tr("Notify when the queue completes"); detail: @tr("The alert contains no file names, paths or server details"); checked <=> root.settings-notify-transfer-completion; }
                                SettingsToggleRow { title: @tr("Notify when a transfer fails"); detail: @tr("Error details remain inside the app"); checked <=> root.settings-notify-transfer-failure; }
                                SettingsToggleRow { title: @tr("Preserve modification times"); detail: @tr("SFTP: upload and download; FTP: download when the server supports MDTM"); checked <=> root.settings-preserve-transfer-timestamps; }
                                SettingsToggleRow { title: @tr("Preserve file permissions"); detail: @tr("rwx bits only; owner, group and special bits are never copied"); checked <=> root.settings-preserve-transfer-permissions; }
                                SettingsToggleRow { title: @tr("Atomic transfers"); detail: @tr("Always enabled — destination changes only after success"); interactive: false; checked: true; }
                                Text { text: @tr("A per-connection override is available in the Connection Manager."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                              }
                            }
                            if root.settings-section == "connections" : VerticalLayout {
                                padding: 24px; spacing: 16px;
                                Text { text: @tr("CONNECTIONS"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; letter-spacing: 1px; }
                                SettingsToggleRow { title: @tr("Background folder sizes"); detail: @tr("Off by default; at most two bounded scans"); checked <=> root.settings-background-metadata; }
                                Text { text: @tr("Endpoint, authentication, file-lane limit and TLS/SSH trust are stored per connection. Passwords never enter settings."); color: Tokens.text-sec; font-size: 11px; wrap: word-wrap; }
                                PrimaryButton { text: @tr("Open Connection Manager"); clicked => { root.settings-open = false; root.manager-open = true; } }
                                Rectangle { vertical-stretch: 1; }
                            }
                            if root.settings-section == "sync" : VerticalLayout {
                                padding: 24px; spacing: 15px;
                                Text { text: @tr("SYNC"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; letter-spacing: 1px; }
                                Text { text: @tr("Default comparison"); color: Tokens.text; font-size: 12px; font-weight: 600; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        ChoiceSegment { text: @tr("SIZE + TIME"); selected: root.settings-sync-comparison == "size_mtime"; chosen => { root.settings-sync-comparison = "size_mtime"; } }
                                        ChoiceSegment { text: @tr("SIZE"); selected: root.settings-sync-comparison == "size_only"; chosen => { root.settings-sync-comparison = "size_only"; } }
                                        ChoiceSegment { text: "SHA-256"; selected: root.settings-sync-comparison == "checksum"; chosen => { root.settings-sync-comparison = "checksum"; } }
                                    }
                                }
                                VerticalLayout { spacing: 6px; Text { text: @tr("CLOCK TOLERANCE (SECONDS)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-sync-tolerance; placeholder: "2"; accessible-name: @tr("CLOCK TOLERANCE (SECONDS)"); } }
                                VerticalLayout { spacing: 6px; Text { text: @tr("DEFAULT EXCLUSIONS"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-sync-exclusions; placeholder: ".git, .DS_Store, *.tmp"; accessible-name: @tr("DEFAULT EXCLUSIONS"); } }
                                Text { text: @tr("Sync always previews changes and never deletes without an explicit mirror mode."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                                Rectangle { vertical-stretch: 1; }
                            }
                            if root.settings-section == "editors" : VerticalLayout {
                                padding: 24px; spacing: 15px;
                                Text { text: @tr("EDITORS"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; letter-spacing: 1px; }
                                VerticalLayout { spacing: 6px; Text { text: @tr("EXTENSION MAPPINGS (EXT=APPLICATION; …)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-editor-mappings; placeholder: "rs=Visual Studio Code; txt=TextEdit"; accessible-name: @tr("EXTENSION MAPPINGS (EXT=APPLICATION; …)"); } }
                                VerticalLayout { spacing: 6px; Text { text: @tr("MAX AUTOMATIC DOWNLOAD (MiB)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; } Field { text <=> root.settings-editor-max-mib; placeholder: "64"; accessible-name: @tr("MAX AUTOMATIC DOWNLOAD (MiB)"); } }
                                SettingsToggleRow { title: @tr("Upload after save"); detail: @tr("Only after verifying the remote version did not change"); checked <=> root.settings-editor-auto-upload; }
                                Text { text: @tr("WHEN THE REMOTE FILE CHANGED WHILE EDITING"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for conflict[i] in 3 : ChoiceSegment { text: i == 0 ? (@tr("RETAIN LOCAL")) : (i == 1 ? (@tr("UPLOAD COPY")) : (@tr("OVERWRITE REMOTE"))); text-size: 9px; danger: i == 2; selected: root.settings-editor-conflict-action == (i == 0 ? "retain_local" : (i == 1 ? "upload_copy" : "overwrite")); chosen => { root.settings-editor-conflict-action = i == 0 ? "retain_local" : (i == 1 ? "upload_copy" : "overwrite"); } }
                                    }
                                }
                                Text { text: @tr("TEMPORARY FILES AFTER THE EDITOR CLOSES"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        for retention[i] in 3 : ChoiceSegment { text: i == 0 ? (@tr("CLEAN UP")) : (i == 1 ? (@tr("KEEP ON ERROR")) : (@tr("ALWAYS KEEP"))); text-size: 9px; selected: root.settings-editor-temp-retention == (i == 0 ? "cleanup" : (i == 1 ? "on_error" : "always")); chosen => { root.settings-editor-temp-retention = i == 0 ? "cleanup" : (i == 1 ? "on_error" : "always"); } }
                                    }
                                }
                                Text { text: @tr("Retain-local conflicts always protect your edit regardless of the cleanup policy."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                                Rectangle { vertical-stretch: 1; }
                            }
                            if root.settings-section == "privacy" : VerticalLayout {
                                padding: 24px; spacing: 13px;
                                Text { text: @tr("PRIVACY & STORAGE"); color: Tokens.text-ter; font-size: 10px; font-weight: 800; letter-spacing: 1px; }
                                Text { text: @tr("gmacFTP has no telemetry. Passwords remain in Keychain or the encrypted vault; the transfer queue contains no credentials."); color: Tokens.text-sec; font-size: 11px; wrap: word-wrap; }
                                Rectangle { height: 74px; border-radius: 7px; background: Tokens.surface; border-width: 1px; border-color: Tokens.border;
                                    Text { x: 12px; y: 7px; width: parent.width - 24px; height: parent.height - 14px; text: root.localize-runtime(root.settings-storage-summary, I18n.locale); color: Tokens.text-sec; font-family: "JetBrains Mono"; font-size: 9px; wrap: word-wrap; }
                                }
                                HorizontalLayout { spacing: 8px;
                                    GhostButton { horizontal-stretch: 1; text: @tr("Refresh Sizes"); clicked => { root.refresh-storage-stats(); } }
                                    GhostButton { horizontal-stretch: 1; text: @tr("Clear Caches"); clicked => { root.clear-performance-caches(); root.refresh-storage-stats(); } }
                                    GhostButton { horizontal-stretch: 1; text: @tr("Clean Abandoned Temp"); clicked => { root.cleanup-abandoned-temporary-files(); } }
                                }
                                VerticalLayout { spacing: 5px;
                                    Text { text: @tr("SYNC FOLDER (ICLOUD DRIVE / DROPBOX / OTHER)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; }
                                    HorizontalLayout { spacing: 8px;
                                        Field { horizontal-stretch: 1; text: root.settings-sync-folder; placeholder: @tr("Automatic iCloud Drive folder"); accessible-name: @tr("Automatic iCloud Drive folder"); }
                                        GhostButton { width: 88px; text: @tr("Choose…"); clicked => { root.choose-sync-folder(); } }
                                        GhostButton { width: 76px; text: @tr("Default"); clicked => { root.clear-sync-folder(); } }
                                    }
                                }
                                HorizontalLayout { spacing: 8px;
                                    GhostButton { horizontal-stretch: 1; text: @tr("Export Diagnostics"); clicked => { root.export-redacted-diagnostics(); } }
                                    GhostButton { horizontal-stretch: 1; text: @tr("Export Settings"); clicked => { root.export-encrypted-settings(); } }
                                    GhostButton { horizontal-stretch: 1; text: @tr("Import Settings"); clicked => { root.import-encrypted-settings(); } }
                                }
                                Text { text: @tr("Diagnostics are redacted. Settings exports are passphrase-encrypted and never include server passwords or vault keys."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                                Rectangle { vertical-stretch: 1; }
                            }
                        }
                    }
                    Rectangle {
                        height: 62px; background: Tokens.bg-alt; border-width: 1px; border-color: Tokens.border;
                        Text { x: 22px; y: 0px; width: 500px; height: parent.height; text: root.localize-runtime(root.settings-message, I18n.locale); color: Tokens.text-sec; font-size: 10px; vertical-alignment: center; overflow: elide; }
                        GhostButton { x: parent.width - 190px; y: 14px; width: 76px; text: I18n.cancel-cap; clicked => { root.reload-settings(); root.settings-open = false; } }
                        PrimaryButton { x: parent.width - 104px; y: 14px; width: 84px; text: I18n.save-cap; clicked => { root.save-settings(); } }
                    }
                }
            }
        }

        // ── connection editor ──
        if root.editor-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 520px; height: min(root.height - 24px, 696px); background: Tokens.card;
                    border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                    drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: root.snapshot-mode ? transparent : #00000066;
                    clip: true;
                    TouchArea { clicked => { } }
                    VerticalLayout { padding: 0px; spacing: 0px;
                        Rectangle {
                            height: 52px; background: transparent;
                            Rectangle {
                                x: 20px; y: 11px; width: 30px; height: 30px; border-radius: 6px; background: Tokens.accent-soft;
                                Icon { kind: "plug"; fg: Tokens.accent; width: Tokens.icon-regular; height: Tokens.icon-regular; x: 7px; y: 7px; }
                            }
                            Text { x: 60px; y: 0px; width: 260px; height: 52px; text: root.editor-id < 0 ? I18n.new-conn : I18n.edit-conn; color: Tokens.text; font-size: 15px; font-weight: 700; vertical-alignment: center; horizontal-alignment: left; }
                            IconButton { icon: "x"; accessible-name: @tr("Close connection editor"); x: parent.width - 50px; y: 11px; clicked => { root.editor-password = ""; root.editor-sftp-key-path = ""; root.editor-tls-client-cert = ""; root.editor-tls-client-key = ""; root.editor-open = false; } }
                            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: Tokens.border; }
                        }
                        ScrollView { vertical-stretch: 1;
                          VerticalLayout { padding-left: 20px; padding-right: 20px; padding-top: 18px; padding-bottom: 18px; spacing: 14px;
                            VerticalLayout { spacing: 6px;
                                Text { text: @tr("NAME"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Field { text <=> root.editor-name; placeholder: @tr("my server"); accessible-name: @tr("NAME"); }
                            }
                            HorizontalLayout { spacing: 14px;
                                VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("GROUP"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; } Field { text <=> root.editor-group; placeholder: @tr("Production"); accessible-name: @tr("GROUP"); } }
                                VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("TAGS"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; } Field { text <=> root.editor-tags; placeholder: "web, client-a"; accessible-name: @tr("TAGS"); } }
                            }
                            HorizontalLayout { spacing: 14px;
                                VerticalLayout { spacing: 6px; horizontal-stretch: 1;
                                    Text { text: @tr("PROTOCOL"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                    Rectangle {
                                        height: 34px; border-radius: 7px;
                                        background: Tokens.field-bg;
                                        border-width: 1px; border-color: Tokens.border-strong;
                                        HorizontalLayout { padding: 3px; spacing: 3px;
                                            ChoiceSegment { text: "FTP"; text-size: 13px; selected: root.editor-protocol != "sftp"; chosen => { root.editor-protocol = "ftp"; } }
                                            ChoiceSegment { text: "SFTP"; text-size: 13px; selected: root.editor-protocol == "sftp"; chosen => { root.editor-protocol = "sftp"; } }
                                        }
                                    }
                                }
                                VerticalLayout { spacing: 6px; width: 214px;
                                    Text { text: @tr("PORT"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                    Field { text <=> root.editor-port; placeholder: "21"; accessible-name: @tr("PORT"); }
                                }
                            }
                            VerticalLayout { spacing: 6px;
                                Text { text: @tr("HOST"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Field { text <=> root.editor-host; placeholder: "ftp.example.com"; accessible-name: @tr("HOST"); }
                            }
                            VerticalLayout { spacing: 6px;
                                Text { text: @tr("INITIAL REMOTE PATH"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Field { text <=> root.editor-initial-path; placeholder: "/var/www"; accessible-name: @tr("INITIAL REMOTE PATH"); }
                            }
                            HorizontalLayout { spacing: 14px;
                                VerticalLayout { spacing: 6px; horizontal-stretch: 1;
                                    Text { text: @tr("USER"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                    Field { text <=> root.editor-user; placeholder: @tr("username"); accessible-name: @tr("USER"); }
                                }
                                VerticalLayout { spacing: 6px; width: 184px;
                                    Text { text: @tr("FILES / SERVER"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                    Rectangle {
                                        height: 34px; border-radius: 7px; background: Tokens.field-bg;
                                        border-width: 1px; border-color: Tokens.border-strong;
                                        HorizontalLayout { padding: 3px; spacing: 2px;
                                            for lane[i] in 5 : ChoiceSegment { text: i == 0 ? "G" : "" + i; selected: root.editor-transfer-concurrency == i; chosen => { root.editor-transfer-concurrency = i; } }
                                        }
                                    }
                                }
                            }
                            HorizontalLayout { spacing: 14px;
                                VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("CONNECT TIMEOUT (SECONDS)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; } Field { text <=> root.editor-timeout-secs; placeholder: "0"; accessible-name: @tr("CONNECT TIMEOUT (SECONDS)"); } }
                                if root.editor-protocol == "sftp" : VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: @tr("KEEPALIVE (SECONDS)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; } Field { text <=> root.editor-keepalive-secs; placeholder: "20"; accessible-name: @tr("KEEPALIVE (SECONDS)"); } }
                            }
                            Text { text: @tr("0 timeout = protocol default; blank keepalive = default, 0 = disabled."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                            VerticalLayout { spacing: 6px;
                                Text { text: @tr("HTTP/SOCKS5 PROXY (OPTIONAL)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Field { text <=> root.editor-proxy-url; placeholder: "socks5://127.0.0.1:1080"; accessible-name: @tr("HTTP/SOCKS5 PROXY (OPTIONAL)"); }
                                Text { text: @tr("Supported: http://host:port and socks5://host:port. Credentials in URLs are rejected."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                            }
                            if root.editor-protocol == "sftp" : Rectangle {
                                height: 40px;
                                Text { x: 0px; y: 1px; width: 392px; height: 16px; text: @tr("Use alias from ~/.ssh/config"); color: Tokens.text; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: left; }
                                Text { x: 0px; y: 21px; width: 392px; height: 14px; text: @tr("HostName, User, Port, IdentityFile, timeout, keepalive and ProxyJump."); color: Tokens.text-sec; font-size: 10px; vertical-alignment: center; horizontal-alignment: left; overflow: elide; }
                                Rectangle {
                                    x: 402px; y: 8px; width: 38px; height: 22px; border-radius: 11px;
                                    background: root.editor-use-ssh-config ? Tokens.accent : Tokens.border-strong;
                                    forward-focus: ssh_config_action;
                                    accessible-role: switch;
                                    accessible-label: @tr("Use alias from ~/.ssh/config");
                                    accessible-checkable: true;
                                    accessible-checked: root.editor-use-ssh-config;
                                    accessible-action-default => { root.editor-use-ssh-config = !root.editor-use-ssh-config; }
                                    Rectangle { width: 16px; height: 16px; border-radius: 8px; x: root.editor-use-ssh-config ? 19px : 3px; y: 3px; background: #FFFFFF; }
                                    ssh_config_action := KeyboardActionArea { clicked => { root.editor-use-ssh-config = !root.editor-use-ssh-config; } }
                                }
                            }
                            if root.editor-protocol == "sftp" : VerticalLayout { spacing: 6px;
                                Text { text: @tr("PROXYJUMP (OPTIONAL)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Field { text <=> root.editor-ssh-proxy-jump; placeholder: "user@bastion.example:22"; accessible-name: @tr("PROXYJUMP (OPTIONAL)"); }
                                Text { text: @tr("One bastion or SSH alias. ProxyCommand and multi-hop chains are rejected."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                            }
                            if root.editor-protocol == "sftp" : VerticalLayout { spacing: 6px;
                                Text { text: @tr("AUTHENTICATION"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Rectangle {
                                    height: 34px; border-radius: 7px; background: Tokens.field-bg;
                                    border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        ChoiceSegment { text: @tr("PASSWORD"); selected: root.editor-sftp-auth == "password"; chosen => { root.editor-sftp-auth = "password"; } }
                                        ChoiceSegment { text: @tr("PRIVATE KEY"); selected: root.editor-sftp-auth == "private_key"; chosen => { root.editor-sftp-auth = "private_key"; } }
                                        ChoiceSegment { text: @tr("SSH AGENT"); selected: root.editor-sftp-auth == "agent"; chosen => { root.editor-sftp-auth = "agent"; root.editor-password = ""; } }
                                        ChoiceSegment { text: @tr("2FA / KBD"); text-size: 9px; selected: root.editor-sftp-auth == "keyboard_interactive"; chosen => { root.editor-sftp-auth = "keyboard_interactive"; root.editor-password = ""; } }
                                    }
                                }
                            }
                            if root.editor-protocol == "sftp" && root.editor-sftp-auth == "private_key" : VerticalLayout { spacing: 6px;
                                Text { text: @tr("PRIVATE KEY FILE"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                HorizontalLayout { spacing: 8px;
                                    Field { horizontal-stretch: 1; text <=> root.editor-sftp-key-path; placeholder: "~/.ssh/id_ed25519"; accessible-name: @tr("PRIVATE KEY FILE"); }
                                    GhostButton { width: 82px; height: 34px; text: @tr("Choose…"); clicked => { root.choose-private-key(); } }
                                }
                            }
                            if root.editor-protocol != "sftp" || (root.editor-sftp-auth != "agent" && root.editor-sftp-auth != "keyboard_interactive") : VerticalLayout { spacing: 6px;
                                Text { text: root.editor-protocol == "sftp" && root.editor-sftp-auth == "private_key" ? @tr("KEY PASSPHRASE (OPTIONAL)") : @tr("PASSWORD"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Rectangle {
                                    height: 34px;
                                    Field { width: parent.width; text <=> root.editor-password; placeholder: root.editor-protocol == "sftp" && root.editor-sftp-auth == "private_key" ? "leave empty for an unencrypted key" : "password"; accessible-name: root.editor-protocol == "sftp" && root.editor-sftp-auth == "private_key" ? @tr("KEY PASSPHRASE (OPTIONAL)") : @tr("PASSWORD"); input-type: password; }
                                    Icon { kind: "eye"; fg: Tokens.text-ter; x: parent.width - 28px; y: (parent.height - self.height) / 2; }
                                }
                            }
                            if root.editor-protocol == "ftp" && !root.editor-allow-plaintext-ftp : VerticalLayout { spacing: 6px;
                                Text { text: @tr("FTPS TLS MODE"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        ChoiceSegment { text: @tr("EXPLICIT (AUTH TLS)"); selected: root.editor-ftp-tls-mode == "explicit"; chosen => { if (root.editor-port == "990") { root.editor-port = "21"; } root.editor-ftp-tls-mode = "explicit"; } }
                                        ChoiceSegment { text: @tr("IMPLICIT TLS"); selected: root.editor-ftp-tls-mode == "implicit"; chosen => { if (root.editor-port == "21") { root.editor-port = "990"; } root.editor-allow-plaintext-ftp = false; root.editor-ftp-tls-mode = "implicit"; } }
                                    }
                                }
                                Text { text: @tr("Explicit is recommended. Implicit is for legacy servers and normally uses port 990."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                            }
                            if root.editor-protocol == "ftp" && !root.editor-allow-plaintext-ftp : VerticalLayout { spacing: 6px;
                                Text { text: @tr("TLS CLIENT CERTIFICATE (OPTIONAL)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                HorizontalLayout { spacing: 8px;
                                    Field { horizontal-stretch: 1; text <=> root.editor-tls-client-cert; placeholder: @tr("PEM certificate chain"); accessible-name: @tr("TLS CLIENT CERTIFICATE (OPTIONAL)"); }
                                    GhostButton { width: 82px; height: 34px; text: @tr("Choose…"); clicked => { root.choose-tls-client-cert(); } }
                                }
                                HorizontalLayout { spacing: 8px;
                                    Field { horizontal-stretch: 1; text <=> root.editor-tls-client-key; placeholder: @tr("PKCS#8 PEM private key"); accessible-name: @tr("PKCS#8 PEM private key"); }
                                    GhostButton { width: 82px; height: 34px; text: @tr("Choose…"); clicked => { root.choose-tls-client-key(); } }
                                }
                                Text { text: @tr("Both files are required. The key must be unencrypted PKCS#8 with mode 600; paths stay on this Mac only."); color: Tokens.text-sec; font-size: 10px; wrap: word-wrap; }
                            }
                            if root.editor-protocol == "ftp" : VerticalLayout { spacing: 6px;
                                Text { text: @tr("FTP DATA MODE"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        ChoiceSegment { text: @tr("PASSIVE"); selected: root.editor-ftp-data-mode == "passive"; chosen => { root.editor-ftp-data-mode = "passive"; } }
                                        ChoiceSegment { text: @tr("ACTIVE"); selected: root.editor-ftp-data-mode == "active"; chosen => { root.editor-ftp-data-mode = "active"; } }
                                    }
                                }
                                Text { text: @tr("Active mode opens a temporary inbound port and commonly needs firewall/NAT configuration."); color: Tokens.warning; font-size: 10px; wrap: word-wrap; }
                            }
                            if root.editor-protocol == "ftp" : VerticalLayout { spacing: 6px;
                                Text { text: @tr("FTP FILENAME ENCODING"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Rectangle { height: 34px; border-radius: 7px; background: Tokens.field-bg; border-width: 1px; border-color: Tokens.border-strong;
                                    HorizontalLayout { padding: 3px; spacing: 3px;
                                        ChoiceSegment { text: @tr("AUTO"); selected: root.editor-ftp-filename-encoding == "auto"; chosen => { root.editor-ftp-filename-encoding = "auto"; } }
                                        ChoiceSegment { text: "UTF-8"; selected: root.editor-ftp-filename-encoding == "utf8"; chosen => { root.editor-ftp-filename-encoding = "utf8"; } }
                                    }
                                }
                            }
                            if root.editor-protocol == "ftp" : Rectangle {
                                height: 38px;
                                Text { x: 0px; y: 2px; width: 392px; height: 15px; text: @tr("Use plaintext FTP only (unsafe)"); color: Tokens.danger; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: left; }
                                Text { x: 0px; y: 20px; width: 392px; height: 14px; text: @tr("Connect directly without TLS. Passwords and files are readable on the network."); color: Tokens.text-sec; font-size: 10px; vertical-alignment: center; horizontal-alignment: left; overflow: elide; }
                                Rectangle {
                                    x: 402px; y: 7px; width: 38px; height: 22px; border-radius: 11px;
                                    background: root.editor-allow-plaintext-ftp ? Tokens.danger : Tokens.border-strong;
                                    forward-focus: plaintext_ftp_action;
                                    accessible-role: switch;
                                    accessible-label: @tr("Use plaintext FTP only (unsafe)");
                                    accessible-checkable: true;
                                    accessible-checked: root.editor-allow-plaintext-ftp;
                                    accessible-action-default => { if (!root.editor-allow-plaintext-ftp) { root.editor-ftp-tls-mode = "explicit"; root.editor-tls-pin = ""; root.editor-legacy-invalid-tls = false; root.editor-tls-client-cert = ""; root.editor-tls-client-key = ""; } root.editor-allow-plaintext-ftp = !root.editor-allow-plaintext-ftp; }
                                    Rectangle {
                                        width: 16px; height: 16px; border-radius: 8px;
                                        x: root.editor-allow-plaintext-ftp ? 19px : 3px; y: 3px; background: #FFFFFF;
                                    }
                                    plaintext_ftp_action := KeyboardActionArea { clicked => { if (!root.editor-allow-plaintext-ftp) { root.editor-ftp-tls-mode = "explicit"; root.editor-tls-pin = ""; root.editor-legacy-invalid-tls = false; root.editor-tls-client-cert = ""; root.editor-tls-client-key = ""; } root.editor-allow-plaintext-ftp = !root.editor-allow-plaintext-ftp; } }
                                }
                            }
                            if root.editor-protocol == "ftp" && !root.editor-allow-plaintext-ftp : Rectangle {
                                height: 33px;
                                Text { x: 0px; y: 2px; width: parent.width; height: 15px; text: root.editor-legacy-invalid-tls ? (@tr("Certificate verification disabled (unsafe)")) : (root.editor-tls-pin != "" ? (@tr("Pinned server certificate")) : (@tr("Strict certificate verification"))); color: root.editor-legacy-invalid-tls ? Tokens.danger-text : (root.editor-tls-pin != "" ? Tokens.accent-text : Tokens.text); font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-alignment: left; }
                                Text { x: 0px; y: 19px; width: parent.width; height: 12px; text: @tr("A new certificate requires fingerprint review before trust is saved."); color: Tokens.text-sec; font-size: 10px; vertical-alignment: center; horizontal-alignment: left; }
                            }
                            if root.editor-protocol == "ftp" && !root.editor-allow-plaintext-ftp && (root.editor-tls-pin != "" || root.editor-legacy-invalid-tls) : VerticalLayout { spacing: 6px;
                                Text { text: @tr("ADVANCED TLS TRUST"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 1px; }
                                Text { text: root.editor-tls-pin != "" ? root.editor-tls-pin : (@tr("Legacy exception: certificate verification disabled")); color: root.editor-legacy-invalid-tls ? Tokens.danger-text : Tokens.accent-text; font-family: "JetBrains Mono"; font-size: 9px; wrap: word-wrap; }
                                GhostButton { text: @tr("Reset Saved Trust"); clicked => { root.reset-editor-tls-trust(); } }
                            }
                            if root.manager-message != "" : Text { text: root.localize-runtime(root.manager-message, I18n.locale); color: Tokens.accent-text; font-size: 10px; wrap: word-wrap; }
                          }
                        }
                        Rectangle {
                            height: 60px; background: transparent; border-width: 1px; border-color: Tokens.border;
                            GhostButton { x: 20px; y: 14px; width: 126px; text: root.editor-testing ? (@tr("Testing…")) : (@tr("Test Connection")); clicked => { if (!root.editor-testing) { root.test-connection(); } } }
                            GhostButton { x: parent.width - 180px; y: 13px; width: 68px; text: I18n.cancel-cap; clicked => { root.editor-password = ""; root.editor-sftp-key-path = ""; root.editor-tls-client-cert = ""; root.editor-tls-client-key = ""; root.editor-open = false; } }
                            PrimaryButton { x: parent.width - 102px; y: 13px; width: 82px; text: I18n.save-cap; clicked => { root.save-connection(); } }
                        }
                    }
                }
            }
        }

        // ── opt-in updater: release notes first, download only after explicit confirmation ──
        if root.update-open : Rectangle {
            background: Tokens.scrim;
            TouchArea { clicked => { } }
            Rectangle {
                x: (root.width - self.width) / 2;
                y: (root.height - self.height) / 2;
                width: 620px; height: 500px;
                background: Tokens.surface-raised;
                border-radius: 14px; border-width: 1px; border-color: Tokens.border-strong;
                drop-shadow-blur: 60px; drop-shadow-offset-y: 24px; drop-shadow-color: root.snapshot-mode ? transparent : #00000066;
                clip: true;
                TouchArea { clicked => { } }
                VerticalLayout { padding: 22px; spacing: 12px;
                    Text { text: @tr("Update available"); color: Tokens.text; font-size: 16px; font-weight: 700; }
                    Text { text: @tr("gmacFTP {} is available.", root.update-version); color: Tokens.accent-text; font-size: 13px; font-weight: 600; }
                    Text { text: @tr("Release notes from GitHub (shown as plain text)"); color: Tokens.text-ter; font-size: 9px; font-weight: 700; letter-spacing: 0.8px; }
                    Rectangle {
                        vertical-stretch: 1; background: Tokens.field-bg;
                        border-radius: 8px; border-width: 1px; border-color: Tokens.border;
                        clip: true;
                        ScrollView {
                            width: parent.width; height: parent.height;
                            Text {
                                width: parent.width - 24px;
                                text: root.update-notes == "No release notes were provided."
                                    ? (@tr("No release notes were provided."))
                                    : root.update-notes;
                                color: Tokens.text-sec; font-size: 11px; wrap: word-wrap;
                            }
                        }
                    }
                    Text {
                        text: @tr("The DMG opens only after its GitHub SHA-256 digest, Developer ID team, and stapled Apple notarization ticket are verified.");
                        color: Tokens.text-sec; font-size: 10px; wrap: word-wrap;
                    }
                    if root.update-message != "" : Text {
                        text: root.localize-runtime(root.update-message, I18n.locale);
                        color: root.update-busy ? Tokens.accent : Tokens.danger-text;
                        font-size: 10px; wrap: word-wrap;
                    }
                    HorizontalLayout { spacing: 10px; alignment: end;
                        GhostButton { text: @tr("Later"); disabled: root.update-busy; clicked => { root.dismiss-update(); } }
                        PrimaryButton {
                            text: root.update-busy ? (@tr("Downloading and verifying…")) : (@tr("Download & Verify"));
                            disabled: root.update-busy;
                            clicked => { root.download-update(); }
                        }
                    }
                }
            }
        }
    }
}
